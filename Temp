package com.cnb.reports.service;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import com.cnb.reports.constants.ReportPluginConstants;
import com.cnb.reports.p8.P8ContextUtil;
import com.cnb.reports.p8.ReportRequestDocumentHelper;
import com.ibm.ecm.extension.PluginResponseUtil;
import com.ibm.ecm.extension.PluginService;
import com.ibm.ecm.extension.PluginServiceCallbacks;
import com.ibm.ecm.json.JSONResponse;
import com.ibm.json.java.JSONObject;


/**
 * Returns metadata and parsed JSON for a {@code ReportRequest} document.
 */
public class GetReportRequestDetailsService extends PluginService {

	public static final String SERVICE_ID = ReportPluginConstants.SERVICE_GET_REPORT_REQUEST_DETAILS;

	private static final int SCAN_LIMIT = 150;

	@Override
	public String getId() {
		return SERVICE_ID;
	}

	@Override
	public void execute(final PluginServiceCallbacks callbacks, HttpServletRequest request, HttpServletResponse response)
			throws Exception {
		final String method = "execute";
		callbacks.getLogger().logEntry(this, method, request);
		try {
			String repositoryId = trim(request.getParameter("repositoryId"));
			if (repositoryId == null) {
				writeFailure(response, request, callbacks, "repositoryId is required.");
				return;
			}
			String documentId = trim(request.getParameter("documentId"));
			String reportRequestId = trim(request.getParameter("reportRequestId"));
			if (documentId == null && reportRequestId == null) {
				writeFailure(response, request, callbacks, "documentId or reportRequestId is required.");
				return;
			}
			// Copy/Reinitiate must load Version 1.0 request JSON, not Version 2 Excel/result content.
			final boolean versionOneOnly = isTrue(request.getParameter("useVersion1"))
					|| isTrue(request.getParameter("versionOneOnly"));

			JSONObject details;
			try {
				final String docId = documentId;
				final String rrId = reportRequestId;
				details = P8ContextUtil.runWithP8Context(callbacks, repositoryId,
						new P8ContextUtil.P8Callback<JSONObject>() {
							@Override
							public JSONObject run(com.filenet.api.core.ObjectStore objectStore) throws Exception {
								if (docId != null) {
									return ReportRequestDocumentHelper.loadDocumentJson(objectStore, docId,
											versionOneOnly);
								}
								JSONObject found = ReportRequestDocumentHelper.loadDocumentJsonByReportRequestId(
										objectStore, callbacks, rrId, SCAN_LIMIT);
								if (found == null) {
									throw new IllegalStateException(
											"No report request found for reportRequestId within recent items.");
								}
								return found;
							}
						});
			} catch (Exception e) {
				callbacks.getLogger().logError(this, method, request, e);
				writeFailure(response, request, callbacks,
						e.getMessage() != null ? e.getMessage() : "Unable to load report request.");
				return;
			}

			JSONResponse ok = new JSONResponse();
			ok.put("success", true);
			ok.put("details", details);
			PluginResponseUtil.writeJSONResponse(request, response, ok, callbacks, SERVICE_ID);
		} finally {
			callbacks.getLogger().logExit(this, method, request);
		}
	}

	private static void writeFailure(HttpServletResponse response, HttpServletRequest request,
			PluginServiceCallbacks callbacks, String message) throws Exception {
		JSONResponse err = new JSONResponse();
		err.put("success", false);
		err.put("message", message);
		PluginResponseUtil.writeJSONResponse(request, response, err, callbacks, SERVICE_ID);
	}

	private static String trim(String s) {
		if (s == null) {
			return null;
		}
		s = s.trim();
		return s.length() == 0 ? null : s;
	}

	private static boolean isTrue(String value) {
		if (value == null) {
			return false;
		}
		String text = value.trim();
		return "true".equalsIgnoreCase(text) || "1".equals(text) || "yes".equalsIgnoreCase(text);
	}
}




