        if (!Files.isRegularFile(sample)) {
            sample = Paths.get("D:", "Workspaces", "RASystemsWorkspace", "ReportsExecutionTool", "Sample",
                    "report-request-c47dfcd5-e46b-481b-b1af-a21bedc85ef7.json");
        }
        String json = new String(Files.readAllBytes(sample), StandardCharsets.UTF_8);
        ReportRequestPayload payload = new ReportRequestPayloadParser().parse(json, null);

        String sql = new FileNetQueryBuilder().buildFromPayload(payload);

        assertTrue(sql.startsWith("SELECT [DocumentTitle], [ContentSize], [LastModifier], [DateLastModified], [MajorVersionNumber]"));
        assertTrue(sql.contains("FROM [ClaimDocument]"));
        assertFalse(sql.contains("WITH EXCLUDESUBCLASSES"));
        assertTrue(sql.contains("[Author] LIKE 'User%'"));
        assertTrue(sql.contains("[AccountNum] LIKE '%524%'"));
        assertTrue(sql.contains("[BatchDocCount] = 58"));
        assertTrue(sql.contains("77 IN [PageNumberCountList]"));
        assertTrue(sql.contains("[Hidden] = FALSE"));
        assertTrue(sql.contains("[Amount] = 13192.34"));
        assertTrue(sql.contains("22426.34 IN [AmountM]"));
        assertTrue(sql.contains("[OriginalDateCreated] = 20260610T030000Z"));
        assertTrue(sql.contains("20180410T030000Z IN [OriginalHireDates]"));
