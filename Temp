package com.cnb.updater.config;

public enum PropertyCardinality {
    SINGLE,
    MULTI;

    public static PropertyCardinality fromConfig(String value) {
        if (value == null) {
            throw new IllegalArgumentException("Property cardinality is required.");
        }
        try {
            return PropertyCardinality.valueOf(value.trim().toUpperCase());
        } catch (IllegalArgumentException ex) {
            throw new IllegalArgumentException("Unsupported property cardinality: " + value
                    + ". Supported values: SINGLE, MULTI");
        }
    }
}



