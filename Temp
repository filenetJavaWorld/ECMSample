CREATE NONCLUSTERED INDEX IX_CC_Extract_Staging_ActiveBatching
ON CC_Extract_Staging
(
    claimNumber,
    CC_Extract_file_Name,
    externalID
)
INCLUDE
(
    claimID,
    gwDocumentID,
    contentFilePath
)
WHERE
    isIndexed = 0
    AND isProcessed = 0
    AND isDataMerged = 1
    AND claimID IS NOT NULL
    AND gwDocumentID IS NOT NULL
    AND contentFilePath IS NOT NULL;


DROP INDEX IX_CC_Extract_Staging_isIndexed ON CC_Extract_Staging;
DROP INDEX IX_CC_Extract_Staging_isProcessed ON CC_Extract_Staging;
DROP INDEX IX_CC_Extract_Staging_isDataMerged ON CC_Extract_Staging;
