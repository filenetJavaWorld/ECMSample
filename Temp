define([
	"dojo/_base/declare",
	"dojo/_base/array",
	"dojo/_base/lang",
	"dojo/aspect",
	"dojo/dom-style",
	"ecm/LoggerMixin",
	"ecm/MessagesMixin",
	"ecm/widget/dialog/BaseDialog",
	"ecm/widget/dialog/MessageDialog",
	"ecm/widget/search/BasicSearchDefinition",
	"dojo/text!./templates/ReportRequestDialog.html",
	"./ReportService"
], function(declare, array, lang, aspect, domStyle, LoggerMixin, MessagesMixin, BaseDialog, MessageDialog,
	BasicSearchDefinition, template, reportService) {

	function mapCriterionValues(criterion) {
		var vals = [];
		if (criterion.values && criterion.values.length) {
			array.forEach(criterion.values, function(v) {
				if (v && typeof v === "object" && v.value !== undefined && v.value !== null) {
					vals.push(v.value);
				} else if (v !== undefined && v !== null) {
					vals.push(v);
				}
			});
		} else if (criterion.value !== undefined && criterion.value !== null && criterion.value !== "") {
			vals.push(criterion.value);
		}
		return vals;
	}

	function mapCriteria(searchTemplate) {
		var list = searchTemplate.searchCriteria || [];
		return array.map(list, function(c, idx) {
			return {
				sequence: idx + 1,
				propertySymbolicName: c.id || "",
				propertyDisplayName: c.name || c.label || c.id || "",
				operator: c.selectedOperator || "",
				dataType: c.dataType || "",
				values: mapCriterionValues(c)
			};
		});
	}

	function mapResultDisplay(searchTemplate) {
		var rd = searchTemplate.resultsDisplay || {};
		var cols = array.map(rd.columns || [], function(colId) {
			return {
				propertySymbolicName: colId,
				propertyDisplayName: colId
			};
		});
		var sort = [];
		if (rd.sortBy) {
			sort.push({
				propertySymbolicName: rd.sortBy,
				direction: rd.sortAscending === false ? "DESC" : "ASC"
			});
		}
		return {
			columns: cols,
			sort: sort
		};
	}

	function mapSearchScope(searchTemplate) {
		var folders = searchTemplate.folders || [];
		if (!folders.length) {
			return "OBJECT_STORE";
		}
		return "FOLDER";
	}

	function mapVersionOption(searchTemplate) {
		if (!searchTemplate.moreOptions) {
			return "CURRENT_VERSION";
		}
		var v = searchTemplate.moreOptions.versionOption;
		if (!v) {
			return "CURRENT_VERSION";
		}
		return String(v).toUpperCase();
	}

	var EMAIL_SEPARATOR = ";";

	function parseSemicolonEmails(raw) {
		if (raw === undefined || raw === null) {
			return [];
		}
		var text = String(raw).trim();
		if (text.length === 0) {
			return [];
		}
		var seen = {};
		var emails = [];
		array.forEach(text.split(EMAIL_SEPARATOR), function(part) {
			var email = lang.trim(part);
			if (!email) {
				return;
			}
			var key = email.toLowerCase();
			if (!seen[key]) {
				seen[key] = true;
				emails.push(email);
			}
		});
		return emails;
	}

	function isValidEmailAddress(email) {
		return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
	}

	function findInvalidEmail(emails) {
		for (var i = 0; i < emails.length; i++) {
			if (!isValidEmailAddress(emails[i])) {
				return emails[i];
			}
		}
		return null;
	}

	function buildInvalidEmailMessage(invalidEmail) {
		return "Invalid email address detected:\n" + invalidEmail
			+ "\nPlease enter valid email addresses separated by semicolon (;).";
	}

	function buildPayload(repository, reportName, sendEmailTo, sendEmailCc, searchTemplate) {
		var os = (searchTemplate.objectStores && searchTemplate.objectStores[0]) || {};
		var targetSym = searchTemplate.className || "";
		var targetDisp = targetSym;
		if (repository && targetSym) {
			var cls = repository.getContentClass(targetSym);
			if (cls && cls.name) {
				targetDisp = cls.name;
			}
		}
		var repositoryName = (repository && (repository.name || repository.repositoryName))
			|| os.displayName
			|| (repository && repository.objectStoreDisplayName)
			|| (repository && repository.objectStoreName)
			|| "";
		return {
			reportName: reportName,
			sendEmailTo: sendEmailTo || [],
			sendEmailCC: sendEmailCc || [],
			repositoryId: repository.id,
			repositoryName: repositoryName,
			objectStoreId: os.id || repository.objectStoreName || "",
			objectStoreName: os.displayName || repository.objectStoreDisplayName || repository.objectStoreName || "",
			targetClassSymbolicName: targetSym,
			targetClassDisplayName: targetDisp,
			includeSubclasses: !!searchTemplate.includeSubclasses,
			searchScope: mapSearchScope(searchTemplate),
			versionOption: mapVersionOption(searchTemplate),
			criteria: mapCriteria(searchTemplate),
			resultDisplay: mapResultDisplay(searchTemplate)
		};
	}

	return declare("cNBReportsPluginDojo.ReportRequestDialog", [
		BaseDialog,
		LoggerMixin,
		MessagesMixin
	], {
		contentString: template,
		widgetsInTemplate: true,
		repository: null,
		cancelButtonLabel: "Cancel",

		postCreate: function() {
			this.inherited(arguments);
			this.setTitle("Create Report Request");
			this.setIntroText("");
			this.addButton("Submit Report Request", "_onSubmit", false, true);

			this.searchDefinition = new BasicSearchDefinition({
				displaySearchInCtrl: false,
				saveSupported: false
			});
			this.searchDefinitionHost.set("content", this.searchDefinition);
			this.searchDefinition.setRepository(this.repository);

			// Do not hide the whole buttonArea: OOTB "Results display" lives there (resultsDisplayButton /
			// SearchResultsDisplayOptions). Hide only actions we replace with the dialog workflow.
			this.own(aspect.after(this.searchDefinition, "onLoad", lang.hitch(this, function() {
				var sd = this.searchDefinition;
				var hideBtn = function(w) {
					if (w && w.domNode) {
						domStyle.set(w.domNode, "display", "none");
					}
				};
				hideBtn(sd.searchButton);
				hideBtn(sd.saveButton);
				hideBtn(sd.saveAsButton);
				hideBtn(sd.cancelButton);
				// Hide "Search in" folder selector row and "Search options" link.
				if (sd._moreOptions && sd._moreOptions.domNode) {
					domStyle.set(sd._moreOptions.domNode, "display", "none");
				}
				if (sd._moreOptionsNode) {
					domStyle.set(sd._moreOptionsNode, "display", "none");
				}
				if (sd._folderLabelNode && sd._folderLabelNode.parentNode) {
					var searchInRow = sd._folderLabelNode.parentNode.parentNode;
					if (searchInRow && searchInRow.tagName === "TR") {
						domStyle.set(searchInRow, "display", "none");
					}
				}
				if (sd.folderSelector && sd.folderSelector.domNode) {
					domStyle.set(sd.folderSelector.domNode, "display", "none");
				}
				if (sd.folderSelectorDropDown && sd.folderSelectorDropDown.domNode) {
					domStyle.set(sd.folderSelectorDropDown.domNode, "display", "none");
				}
				if (sd.searchInDropDown && sd.searchInDropDown.domNode) {
					domStyle.set(sd.searchInDropDown.domNode, "display", "none");
				}
				var k = sd.keepSearchCriteriaExpanded;
				if (k && k.domNode && k.domNode.parentNode) {
					domStyle.set(k.domNode.parentNode, "display", "none");
				}
			})));
		},

		show: function() {
			this.inherited(arguments);
			if (this.searchDefinition && this.searchDefinition.resize) {
				this.searchDefinition.resize();
			}
		},

		resize: function() {
			this.inherited(arguments);
			if (this.searchDefinition && this.searchDefinition.resize) {
				this.searchDefinition.resize();
			}
		},

		_onSubmit: function() {
			if (!this.reportNameField.validate()) {
				return;
			}
			var invalid = this.searchDefinition.attributeDefinitionFormWid
				&& this.searchDefinition.attributeDefinitionFormWid.validate();
			if (invalid) {
				if (invalid.focus) {
					invalid.focus();
				}
				return;
			}
			if (!this.searchDefinition._meetsMinimumCriteria()) {
				var msg = this.messages.search_insufficient_input || "Specify search criteria.";
				new MessageDialog({
					text: msg
				}).show();
				return;
			}

			var sendEmailTo = parseSemicolonEmails(this.sendEmailToField.get("value"));
			var invalidTo = findInvalidEmail(sendEmailTo);
			if (invalidTo) {
				new MessageDialog({
					text: buildInvalidEmailMessage(invalidTo)
				}).show();
				return;
			}
			var sendEmailCc = parseSemicolonEmails(this.sendEmailCcField.get("value"));
			var invalidCc = findInvalidEmail(sendEmailCc);
			if (invalidCc) {
				new MessageDialog({
					text: buildInvalidEmailMessage(invalidCc)
				}).show();
				return;
			}

			var searchTemplate = this.searchDefinition._prepareSearchTemplateForExecution();
			var reportName = this.reportNameField.get("value");
			var payload = buildPayload(this.repository, reportName, sendEmailTo, sendEmailCc, searchTemplate);

			var self = this;
			reportService.submitReportRequest(this.repository.id, payload, function(res) {
				if (self._submitMessageDialog) {
					self._submitMessageDialog.destroyRecursive();
				}
				self._submitMessageDialog = new MessageDialog({
					text: res.message || "Report request submitted successfully."
				});
				self._submitMessageDialog.show();
				if (lang.isFunction(self.onSubmitted)) {
					self.onSubmitted(res);
				}
				self.hide();
			}, function(res) {
				var msg = "Request failed.";
				if (res) {
					if (res.message) {
						msg = res.message;
					} else if (res.errors && res.errors.length) {
						msg = res.errors[0].text || msg;
					}
				}
				new MessageDialog({
					text: msg
				}).show();
			});
		},

		onSubmitted: function(response) {
		}
	});
});




