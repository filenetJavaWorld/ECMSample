            Map.entry("MODIFIED", "DateLastModified"),
            Map.entry("MAJORVERSION", "MajorVersionNumber"),
            Map.entry("MINORVERSION", "MinorVersionNumber"),
            Map.entry("CONTENTSIZE", "ContentSize"),
            Map.entry("ID", "Id"),
            Map.entry("MIMETYPE", "MimeType"),
            Map.entry("CLASS", "ClassDescription"));

    private static final Map<String, String> ICN_DISPLAY_NAMES = Map.ofEntries(
            Map.entry("NAME", "Document Title"),
            Map.entry("CREATOR", "Creator"),
            Map.entry("OWNER", "Owner"),
            Map.entry("DATECREATED", "Date Created"),
            Map.entry("CREATED", "Date Created"),
            Map.entry("DATEMODIFIED", "Date Last Modified"),
            Map.entry("MODIFIED", "Date Last Modified"),
            Map.entry("MAJORVERSION", "Major Version Number"),
            Map.entry("MINORVERSION", "Minor Version Number"),
            Map.entry("CONTENTSIZE", "Content Size"),
            Map.entry("ID", "Id"),
            Map.entry("MIMETYPE", "Mime Type"),
            Map.entry("CLASS", "Class"));

    private CePropertyNameResolver() {
    }

    public static ResultColumn toResultColumn(String rawToken) {
        String resolved = resolve(rawToken);
        return new ResultColumn(resolved, resolveDisplayName(rawToken, resolved));
    }

    public static String resolve(String rawPropertyName) {
        if (StringUtils.isBlank(rawPropertyName)) {
            return rawPropertyName;
        }

        String trimmed = rawPropertyName.trim();
        if (trimmed.startsWith("{") && trimmed.endsWith("}")) {
            String inner = trimmed.substring(1, trimmed.length() - 1).trim();
            String mapped = ICN_MACROS.get(inner.toUpperCase(Locale.ROOT));
            if (mapped != null) {
                return mapped;
            }
            if (isValidCePropertyName(inner)) {
                return inner;
            }
            throw new IllegalArgumentException("Unsupported ICN property token: " + trimmed);
        }

        return trimmed;
    }

    public static String resolveDisplayName(String rawToken, String resolvedSymbolicName) {
        if (StringUtils.isBlank(rawToken)) {
            return humanizePropertyName(resolvedSymbolicName);
        }

        String trimmed = rawToken.trim();
        if (trimmed.startsWith("{") && trimmed.endsWith("}")) {
            String inner = trimmed.substring(1, trimmed.length() - 1).trim().toUpperCase(Locale.ROOT);
            String display = ICN_DISPLAY_NAMES.get(inner);
            if (display != null) {
                return display;
            }
        }

        if (!trimmed.equals(resolvedSymbolicName) && !trimmed.startsWith("{")) {
            return trimmed;
        }

        return humanizePropertyName(resolvedSymbolicName);
    }

    private static String humanizePropertyName(String propertyName) {
        if (StringUtils.isBlank(propertyName)) {
            return propertyName;
        }
        return propertyName.replaceAll("([a-z])([A-Z])", "$1 $2");
    }

    private static boolean isValidCePropertyName(String propertyName) {
        return propertyName.matches("^[A-Za-z_][A-Za-z0-9_]*$");
    }
}


package com.cnb.reports.util;

import com.filenet.api.property.Properties;

import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

public final class P8PropertyReader {

    private P8PropertyReader() {
    }

    public static String asString(Properties props, String name) {
        if (props == null || !props.isPropertyPresent(name)) {
            return "";
        }
        try {
            String value = props.getStringValue(name);
            return value != null ? value : "";
        } catch (Exception ex) {
            try {
                Object value = props.getObjectValue(name);
                return value != null ? String.valueOf(value) : "";
            } catch (Exception ignored) {
                return "";
            }
        }
    }

    public static Date asDate(Properties props, String name) {
        if (props == null || !props.isPropertyPresent(name)) {
            return null;
        }
        try {
            return props.getDateTimeValue(name);
        } catch (Exception ex) {
            try {
                Object value = props.getObjectValue(name);
                if (value instanceof Date) {
                    return (Date) value;
                }
            } catch (Exception ignored) {
                // ignore
            }
            return null;
        }
    }

    public static String formatDateTime(Date date) {
        if (date == null) {
            return "";
        }
        SimpleDateFormat fmt = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
        fmt.setTimeZone(TimeZone.getDefault());
        return fmt.format(date);
    }

    public static Object readPropertyValue(Properties props, String propertyName) {
        if (props == null || !props.isPropertyPresent(propertyName)) {
            return "";
        }
        try {
            return props.getObjectValue(propertyName);
        } catch (Exception ex) {
            return asString(props, propertyName);
        }
    }
}


package com.cnb.reports.util;

import org.apache.commons.lang3.StringUtils;

import java.util.regex.Pattern;

public final class SqlValidationUtil {

    private static final Pattern CLASS_NAME = Pattern.compile("^[A-Za-z_][A-Za-z0-9_]*$");
    private static final Pattern PROPERTY_NAME = Pattern.compile("^[A-Za-z_][A-Za-z0-9_]*$");

    private SqlValidationUtil() {
    }

    public static void validateClassName(String className) {
        if (StringUtils.isBlank(className) || !CLASS_NAME.matcher(className.trim()).matches()) {
            throw new IllegalArgumentException("Invalid target class name: " + className);
        }
    }

    public static void validatePropertyName(String propertyName) {
        if (StringUtils.isBlank(propertyName) || !PROPERTY_NAME.matcher(propertyName.trim()).matches()) {
            throw new IllegalArgumentException("Invalid property symbolic name: " + propertyName);
        }
    }

    public static String escapeSqlString(String value) {
        if (value == null) {
            return "";
        }
        return value.replace("'", "''");
    }

    public static boolean isUsableSql(String sql) {
        if (StringUtils.isBlank(sql)) {
            return false;
        }
        String normalized = sql.trim().toUpperCase();
        return normalized.startsWith("SELECT") && normalized.contains(" FROM ");
    }
}



