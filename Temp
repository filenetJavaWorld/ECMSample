import java.util.List;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.LinkedBlockingQueue;
import java.util.concurrent.TimeUnit;

/**
 * Orchestrates concurrent document upload load testing using a fixed thread pool
 * and a shared class queue (producer-consumer model).
 */
public class UploadOrchestrator {

    private static final Logger LOG = LogManager.getLogger(UploadOrchestrator.class);

    private final AppConfig config;

    public UploadOrchestrator(AppConfig config) {
        this.config = config;
    }

    /**
     * Executes the upload load test.
     *
     * @return performance summary
     * @throws Exception if orchestration fails
     */
    public PerformanceSummary execute() throws Exception {
        List<ClassConfig> classConfigs = CsvDataReader.readClassConfig(config.getClassConfigFile());
        if (classConfigs.isEmpty()) {
            throw new IllegalStateException("No classes configured in " + config.getClassConfigFile());
        }

        int threadCount = config.getThreadCount();
        LOG.info("Starting upload load test - Total classes: {}, Thread count: {}",
                classConfigs.size(), threadCount);

        BlockingQueue<ClassConfig> classQueue = new LinkedBlockingQueue<>(classConfigs);
        LOG.info("Class queue loaded with {} entries", classQueue.size());
        MetricsCollector metricsCollector = new MetricsCollector();

        ExecutorService executorService = Executors.newFixedThreadPool(threadCount);

        long startMs = System.currentTimeMillis();

        for (int i = 0; i < threadCount; i++) {
            executorService.submit(new UploadWorker(classQueue, config, metricsCollector));
        }

        executorService.shutdown();
        boolean finished = executorService.awaitTermination(Long.MAX_VALUE, TimeUnit.NANOSECONDS);
        if (!finished) {
            LOG.warn("Upload executor did not terminate cleanly");
        }

        long totalExecutionMs = System.currentTimeMillis() - startMs;

        metricsCollector.writeUploadMetrics(config.getMetricsOutputFile());
        PerformanceSummary summary = metricsCollector.buildUploadSummary(totalExecutionMs, classConfigs.size());
        summary.printSummary();

        LOG.info("Upload load test completed");
        return summary;
    }
}



package com.filenet.loadtest.upload;

import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.connection.FileNetSession;
import com.filenet.loadtest.csv.CsvDataReader;
import com.filenet.loadtest.metrics.MetricsCollector;
import com.filenet.loadtest.model.ClassConfig;
import com.filenet.loadtest.model.UploadMetricRecord;
import com.filenet.loadtest.util.DateTimeUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.List;
import java.util.Map;
import java.util.concurrent.BlockingQueue;

/**
 * Worker thread that processes document classes from a shared queue.
 * Each worker maintains its own independent FileNet session.
 */
public class UploadWorker implements Runnable {

    private static final Logger LOG = LogManager.getLogger(UploadWorker.class);

    private final BlockingQueue<ClassConfig> classQueue;
    private final AppConfig config;
    private final MetricsCollector metricsCollector;

    public UploadWorker(BlockingQueue<ClassConfig> classQueue, AppConfig config,
                        MetricsCollector metricsCollector) {
        this.classQueue = classQueue;
        this.config = config;
        this.metricsCollector = metricsCollector;
    }

    @Override
    public void run() {
        String threadName = Thread.currentThread().getName();
        LOG.info("Thread started: {}", threadName);

        try {
            try (FileNetSession session = FileNetSession.create(config)) {
                DocumentUploader uploader = new DocumentUploader(session.getObjectStore(), config);

                ClassConfig classConfig;
                while ((classConfig = classQueue.poll()) != null) {
                    processClass(threadName, classConfig, uploader);
                }
            }
        } catch (Throwable ex) {
            LOG.error("Thread {} failed: {} - {}", threadName, ex.getClass().getName(), ex.getMessage(), ex);
        } finally {
            LOG.info("Thread completed: {}", threadName);
        }
    }

    private void processClass(String threadName, ClassConfig classConfig, DocumentUploader uploader) {
        String className = classConfig.getClassSymbolicName();
        String csvFile = classConfig.getCsvFile();

        LOG.info("Class started - Thread: {}, Class: {}, CSV: {}", threadName, className, csvFile);

        try {
            List<Map<String, String>> rows = CsvDataReader.readDocumentCsv(csvFile);
            LOG.info("Processing class {} with {} document rows", className, rows.size());

            int rowNumber = 0;
            for (Map<String, String> row : rows) {
                rowNumber++;
                processRow(threadName, className, csvFile, rowNumber, row, uploader);
            }

            LOG.info("Class completed - Thread: {}, Class: {}", threadName, className);

        } catch (Exception ex) {
            LOG.error("Failed to process class {} on thread {}: {}",
                    className, threadName, ex.getMessage(), ex);
        }
    }

    private void processRow(String threadName, String className, String csvFile,
                            int rowNumber, Map<String, String> row, DocumentUploader uploader) {
        long startMs = System.currentTimeMillis();
        String startTime = DateTimeUtil.formatTimestamp(startMs);
        String status = "SUCCESS";
        String documentId = "";
        String errorMessage = "";

        try {
            documentId = uploader.uploadDocument(className, row, rowNumber);
        } catch (Exception ex) {
            status = "FAILED";
            errorMessage = ex.getMessage() != null ? ex.getMessage() : ex.getClass().getSimpleName();
            LOG.error("Document upload failed - Thread: {}, Class: {}, Row: {}: {}",
                    threadName, className, rowNumber, errorMessage, ex);
        }

        long endMs = System.currentTimeMillis();
        String endTime = DateTimeUtil.formatTimestamp(endMs);

        metricsCollector.recordUpload(new UploadMetricRecord(
                threadName,
                className,
                csvFile,
                rowNumber,
                documentId,
                status,
                endMs - startMs,
                errorMessage,
                startTime,
                endTime
        ));
    }
}



package com.filenet.loadtest.util;

import java.text.ParseException;
import java.text.SimpleDateFormat;
import java.util.Arrays;
import java.util.Date;
import java.util.List;
import java.util.TimeZone;

/**
 * Utility for parsing and formatting dates used in CSV property mapping and metrics.
 */
public final class DateTimeUtil {

    private static final List<String> DATE_PATTERNS = Arrays.asList(
            "yyyy-MM-dd'T'HH:mm:ss",
            "yyyy-MM-dd HH:mm:ss",
            "yyyy-MM-dd"
    );

    private static final ThreadLocal<SimpleDateFormat> METRICS_FORMAT =
            ThreadLocal.withInitial(() -> {
                SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss.SSS");
                sdf.setTimeZone(TimeZone.getDefault());
                return sdf;
            });

    private DateTimeUtil() {
    }

    /**
     * Parses a date string using supported patterns.
     *
     * @param value date string from CSV
     * @return parsed date
     * @throws ParseException if no pattern matches
     */
    public static Date parseDate(String value) throws ParseException {
        String trimmed = value.trim();
        ParseException lastException = null;

        for (String pattern : DATE_PATTERNS) {
            SimpleDateFormat sdf = new SimpleDateFormat(pattern);
            sdf.setLenient(false);
            try {
                return sdf.parse(trimmed);
            } catch (ParseException ex) {
                lastException = ex;
            }
        }

        throw lastException != null ? lastException
                : new ParseException("Unable to parse date: " + value, 0);
    }

    /**
     * Formats a timestamp for metrics output.
     *
     * @param epochMs epoch milliseconds
     * @return formatted timestamp
     */
    public static String formatTimestamp(long epochMs) {
        return METRICS_FORMAT.get().format(new Date(epochMs));
    }
}




package com.filenet.loadtest.util;

/**
 * Utility for escaping values used in FileNet Search SQL WHERE clauses.
 */
public final class SqlEscapeUtil {

    private SqlEscapeUtil() {
    }

    /**
     * Escapes single quotes for SQL string literals.
     *
     * @param value raw value
     * @return escaped value
     */
    public static String escape(String value) {
        if (value == null) {
            return "";
        }
        return value.replace("'", "''");
    }
}




package com.filenet.loadtest.util;

import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.connection.FileNetSession;
import com.filenet.loadtest.csv.CsvDataReader;
import com.filenet.loadtest.model.ClassConfig;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.File;
import java.util.List;
import java.util.Map;

/**
 * Validates configuration, input files, and FileNet connectivity before load testing begins.
 */
public final class StartupValidator {

    private static final Logger LOG = LogManager.getLogger(StartupValidator.class);

    private StartupValidator() {
    }

    /**
     * Runs all startup checks and fails fast with a clear error message.
     *
     * @param config application configuration
     * @throws Exception if validation fails
     */
    public static void validate(AppConfig config) throws Exception {
        String workingDir = System.getProperty("user.dir");
        LOG.info("Working directory: {}", workingDir);

        validateFileExists("Sample content file", config.getSampleContentFile());

        List<ClassConfig> classConfigs = CsvDataReader.readClassConfig(config.getClassConfigFile());
        if (classConfigs.isEmpty()) {
            throw new IllegalStateException("No classes found in " + config.getClassConfigFile());
        }

        int totalRows = 0;
        for (ClassConfig classConfig : classConfigs) {
            validateFileExists("Document CSV for class " + classConfig.getClassSymbolicName(),
                    classConfig.getCsvFile());
            List<Map<String, String>> rows = CsvDataReader.readDocumentCsv(classConfig.getCsvFile());
            LOG.info("Class {} -> {} ({} document rows)",
                    classConfig.getClassSymbolicName(), classConfig.getCsvFile(), rows.size());
            totalRows += rows.size();
        }

        if (totalRows == 0) {
            throw new IllegalStateException("All document CSV files are empty. No documents to upload.");
        }

        LOG.info("Validated {} classes with {} total document rows", classConfigs.size(), totalRows);

        if (config.isSearchEnabled()) {
            validateFileExists("Search config file", config.getSearchConfigFile());
        }

        LOG.info("Testing FileNet connection to {} (object store: {})...",
                config.getCeUri(), config.getObjectStoreName());

        try (FileNetSession session = FileNetSession.create(config)) {
            LOG.info("FileNet preflight connection successful for object store: {}",
                    session.getObjectStore().get_Name());
        }
    }

    private static void validateFileExists(String description, String path) {
        File file = new File(path);
        if (!file.exists()) {
            throw new IllegalStateException(description + " not found: " + file.getAbsolutePath()
                    + " (check Eclipse Working directory is set to the project root)");
        }
    }
}





