package com.cnb.reports.mail;

import java.util.ArrayList;
import java.util.LinkedHashSet;
import java.util.List;
import java.util.Set;
import java.util.regex.Pattern;

/**
 * Validates and normalizes email addresses for report notifications.
 */
public final class EmailValidator {

	private static final Pattern EMAIL_PATTERN = Pattern.compile(
			"^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");

	private EmailValidator() {
	}

	public static boolean isValid(String email) {
		if (email == null) {
			return false;
		}
		String trimmed = email.trim();
		return trimmed.length() > 0 && EMAIL_PATTERN.matcher(trimmed).matches();
	}

	public static List<String> normalizeList(List<String> rawEmails) {
		Set<String> unique = new LinkedHashSet<String>();
		if (rawEmails == null) {
			return new ArrayList<String>();
		}
		for (String raw : rawEmails) {
			if (raw == null) {
				continue;
			}
			String trimmed = raw.trim();
			if (trimmed.length() == 0) {
				continue;
			}
			if (isValid(trimmed)) {
				unique.add(trimmed);
			}
		}
		return new ArrayList<String>(unique);
	}

	public static List<String> parseSemicolonSeparated(String value) {
		List<String> emails = new ArrayList<String>();
		if (value == null) {
			return emails;
		}
		String text = value.trim();
		if (text.length() == 0) {
			return emails;
		}
		String[] parts = text.split(";");
		for (int i = 0; i < parts.length; i++) {
			String part = parts[i];
			if (part != null) {
				String trimmed = part.trim();
				if (trimmed.length() > 0) {
					emails.add(trimmed);
				}
			}
		}
		return normalizeList(emails);
	}

	public static String firstInvalid(List<String> emails) {
		if (emails == null) {
			return null;
		}
		for (String email : emails) {
			if (email != null) {
				String trimmed = email.trim();
				if (trimmed.length() > 0 && !isValid(trimmed)) {
					return trimmed;
				}
			}
		}
		return null;
	}
}



package com.cnb.reports.mail;

import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.util.Properties;

/**
 * Loads SMTP and template settings shared with the Report Execution Tool.
 */
public final class MailConfig {

	public static final String DEFAULT_CONFIG_FILE =
			"D:/Rameshwar/ReportsExecutionTool/config/ReportsExecutionTool.properties";

	private final Properties properties;
	private final boolean mailEnabled;
	private final String mailSmtpHost;
	private final int mailSmtpPort;
	private final boolean mailSmtpAuth;
	private final boolean mailSmtpStartTlsEnable;
	private final String mailSmtpUsername;
	private final String mailSmtpPassword;
	private final String mailFromAddress;
	private final String mailFromName;
	private final File acknowledgementTemplateFile;

	public MailConfig() throws IOException {
		this(resolveConfigFilePath());
	}

	public MailConfig(String configFilePath) throws IOException {
		properties = new Properties();
		FileInputStream in = null;
		try {
			in = new FileInputStream(configFilePath);
			properties.load(in);
		} finally {
			if (in != null) {
				try {
					in.close();
				} catch (IOException e) {
					// ignore
				}
			}
		}

		mailEnabled = getBoolean("mail.enabled", false);
		mailSmtpHost = getString("mail.smtp.host", "");
		mailSmtpPort = getInt("mail.smtp.port", 587);
		mailSmtpAuth = getBoolean("mail.smtp.auth", true);
		mailSmtpStartTlsEnable = getBoolean("mail.smtp.starttls.enable", true);
		mailSmtpUsername = getString("mail.smtp.username", "");
		mailSmtpPassword = getString("mail.smtp.password", "");
		mailFromAddress = getString("mail.from.address", "");
		mailFromName = getString("mail.from.name", "Reports Notification");

		String configDir = getString("app.config.path", "D:/Rameshwar/ReportsExecutionTool/config/");
		acknowledgementTemplateFile = new File(configDir, "email-templates/acknowledgement.html");
	}

	public static String resolveConfigFilePath() {
		String configured = System.getProperty("reports.mail.config.file");
		if (configured != null && configured.trim().length() > 0) {
			return configured.trim();
		}
		configured = System.getProperty("config.file");
		if (configured != null && configured.trim().length() > 0) {
			return configured.trim();
		}
		return DEFAULT_CONFIG_FILE;
	}

	public boolean isMailEnabled() {
		return mailEnabled;
	}

	public String getMailSmtpHost() {
		return mailSmtpHost;
	}

	public int getMailSmtpPort() {
		return mailSmtpPort;
	}

	public boolean isMailSmtpAuth() {
		return mailSmtpAuth;
	}

	public boolean isMailSmtpStartTlsEnable() {
		return mailSmtpStartTlsEnable;
	}

	public String getMailSmtpUsername() {
		return mailSmtpUsername;
	}

	public String getMailSmtpPassword() {
		return mailSmtpPassword;
	}

	public String getMailFromAddress() {
		return mailFromAddress;
	}

	public String getMailFromName() {
		return mailFromName;
	}

	public File getAcknowledgementTemplateFile() {
		return acknowledgementTemplateFile;
	}

	private String getString(String key, String defaultValue) {
		String value = properties.getProperty(key);
		return value != null ? value.trim() : defaultValue;
	}

	private int getInt(String key, int defaultValue) {
		String value = properties.getProperty(key);
		if (value == null || value.trim().length() == 0) {
			return defaultValue;
		}
		try {
			return Integer.parseInt(value.trim());
		} catch (NumberFormatException e) {
			return defaultValue;
		}
	}

	private boolean getBoolean(String key, boolean defaultValue) {
		String value = properties.getProperty(key);
		if (value == null || value.trim().length() == 0) {
			return defaultValue;
		}
		return "true".equalsIgnoreCase(value.trim()) || "yes".equalsIgnoreCase(value.trim())
				|| "1".equals(value.trim());
	}
}




package com.cnb.reports.mail;

import com.ibm.json.java.JSONArray;
import com.ibm.json.java.JSONObject;

/**
 * Validates and normalizes email fields on report request payloads.
 */
public final class ReportEmailPayloadUtil {

	private ReportEmailPayloadUtil() {
	}

	public static String validatePayloadEmails(JSONObject payload) {
		String invalid = firstInvalidField(payload, "sendEmailTo");
		if (invalid != null) {
			return invalid;
		}
		invalid = firstInvalidField(payload, "sendEmailCC");
		if (invalid != null) {
			return invalid;
		}
		invalid = firstInvalidField(payload, "sendEmailCc");
		return invalid;
	}

	public static void normalizePayloadEmails(JSONObject payload) {
		putNormalizedArray(payload, "sendEmailTo", readRawEmails(payload, "sendEmailTo"));
		java.util.List<String> cc = readRawEmails(payload, "sendEmailCC");
		if (cc.isEmpty()) {
			cc = readRawEmails(payload, "sendEmailCc");
		}
		putNormalizedArray(payload, "sendEmailCC", cc);
		payload.remove("sendEmailCc");
	}

	private static String firstInvalidField(JSONObject payload, String key) {
		java.util.List<String> emails = readRawEmails(payload, key);
		return EmailValidator.firstInvalid(emails);
	}

	private static java.util.List<String> readRawEmails(JSONObject payload, String key) {
		java.util.List<String> emails = new java.util.ArrayList<String>();
		Object raw = payload.get(key);
		if (raw instanceof JSONArray) {
			JSONArray arr = (JSONArray) raw;
			for (int i = 0; i < arr.size(); i++) {
				Object value = arr.get(i);
				if (value != null) {
					emails.add(String.valueOf(value));
				}
			}
		} else if (raw instanceof String) {
			emails.addAll(EmailValidator.parseSemicolonSeparated((String) raw));
		}
		return emails;
	}

	private static void putNormalizedArray(JSONObject payload, String key, java.util.List<String> rawEmails) {
		java.util.List<String> normalized = EmailValidator.normalizeList(rawEmails);
		JSONArray arr = new JSONArray();
		for (int i = 0; i < normalized.size(); i++) {
			arr.add(normalized.get(i));
		}
		payload.put(key, arr);
	}
}



