import com.cnb.reports.constants.ReportPluginConstants;
import com.cnb.reports.mail.EmailValidator;
import com.filenet.api.collection.ContentElementList;
import com.filenet.api.collection.StringList;
import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.constants.AutoClassify;
import com.filenet.api.constants.CheckinType;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.core.ContentTransfer;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import com.filenet.api.util.Id;
import com.ibm.ecm.extension.PluginServiceCallbacks;
import com.ibm.json.java.JSON;
import com.ibm.json.java.JSONArray;
import com.ibm.json.java.JSONObject;

public final class ReportRequestDocumentHelper {

	private static final Charset UTF8 = Charset.forName("UTF-8");

	private ReportRequestDocumentHelper() {
	}

	public static JSONObject createReportRequestDocument(ObjectStore os, JSONObject payloadJson) throws Exception {
		String reportName = trim(payloadJson.get("reportName"));
		String reportRequestId = trim(payloadJson.get("reportRequestId"));
		if (reportRequestId == null || reportRequestId.length() == 0) {
			reportRequestId = UUID.randomUUID().toString();
			payloadJson.put("reportRequestId", reportRequestId);
		}

		String jsonText = payloadJson.serialize(true);
		byte[] bytes = jsonText.getBytes(UTF8);

		String retrievalName = ReportPluginConstants.JSON_FILENAME_PREFIX + reportRequestId
				+ ReportPluginConstants.JSON_FILENAME_SUFFIX;

		Document doc = Factory.Document.createInstance(os, ReportPluginConstants.REPORT_REQUEST_CLASS);
		Properties props = doc.getProperties();
		props.putValue("DocumentTitle", reportName);
		applyReportRequestMetadata(props, payloadJson);

		ContentTransfer ct = Factory.ContentTransfer.createInstance();
		ct.setCaptureSource(new ByteArrayInputStream(bytes));
		ct.set_RetrievalName(retrievalName);
		ct.set_ContentType(ReportPluginConstants.JSON_MIME_TYPE);

		ContentElementList cel = Factory.ContentElement.createList();
		cel.add(ct);
		doc.set_ContentElements(cel);
		doc.set_MimeType(ReportPluginConstants.JSON_MIME_TYPE);

		saveAsMajorVersion(doc);

		JSONObject out = new JSONObject();
		out.put("documentId", doc.get_Id().toString());
		out.put("reportRequestId", reportRequestId);
		return out;
	}

	private static JSONArray queryMyReportRequests(ObjectStore os, PluginServiceCallbacks callbacks, int maxResults)
			throws Exception {
		if (callbacks == null) {
			throw new IllegalArgumentException("callbacks is required.");
		}
		if (maxResults < 1) {
			maxResults = 1;
		}

		String sql = ReportPluginConstants.REPORT_REQUEST_LIST_SQL;

		PropertyFilter pf = newReportRequestListPropertyFilter();
		return fetchReportRequestRows(os, sql, maxResults, pf);
	}

	private static PropertyFilter newReportRequestListPropertyFilter() {
		PropertyFilter pf = new PropertyFilter();
		pf.addIncludeProperty(0, null, null, "This", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.ID, null);
		pf.addIncludeProperty(0, null, null, "DocumentTitle", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CREATOR, null);
		pf.addIncludeProperty(0, null, null, "DateCreated", null);
		pf.addIncludeProperty(0, null, null, "DateLastModified", null);
		pf.addIncludeProperty(0, null, null, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, null);
		pf.addIncludeProperty(0, null, null, "MimeType", null);
		return pf;
	}

	private static JSONArray fetchReportRequestRows(ObjectStore os, String sql, int maxRows, PropertyFilter pf)
			throws Exception {
		SearchSQL searchSQL = new SearchSQL(sql);
		SearchScope scope = new SearchScope(os);
		IndependentObjectSet set = scope.fetchObjects(searchSQL, maxRows, pf, Boolean.TRUE);
		JSONArray rows = new JSONArray();
		PageIterator pi = set.pageIterator();
		while (pi.nextPage()) {
			Object[] page = pi.getCurrentPage();
			if (page == null) {
				continue;
			}
			for (Object o : page) {
				if (!(o instanceof Document)) {
					continue;
				}
				rows.add(toListRow((Document) o));
			}
		}
		return rows;
	}

	private static JSONObject toListRow(Document d) {
		Properties p = d.getProperties();
		JSONObject row = new JSONObject();
		row.put("documentId", d.get_Id().toString());
		row.put("documentTitle", P8PropertyValues.asString(p, "DocumentTitle"));
		row.put("creator", P8PropertyValues.asString(p, PropertyNames.CREATOR));
		row.put("dateCreated", P8PropertyValues.asDateTimeIsoUtc(p, "DateCreated"));
		row.put("dateLastModified", P8PropertyValues.asDateTimeIsoUtc(p, "DateLastModified"));
		row.put("status", P8PropertyValues.asString(p, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS));
		row.put("contentType", ReportPluginConstants.JSON_MIME_TYPE);
		return row;
	}

	public static JSONObject loadDocumentJson(ObjectStore os, String documentId) throws Exception {
		PropertyFilter pf = new PropertyFilter();
		pf.addIncludeProperty(0, null, null, PropertyNames.ID, null);
		pf.addIncludeProperty(0, null, null, "DocumentTitle", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CREATOR, null);
		pf.addIncludeProperty(0, null, null, "DateCreated", null);
		pf.addIncludeProperty(0, null, null, "DateLastModified", null);
		pf.addIncludeProperty(0, null, null, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);

		Document doc = Factory.Document.fetchInstance(os, new Id(documentId), pf);
		JSONObject meta = new JSONObject();
		Properties mp = doc.getProperties();
		meta.put("documentId", doc.get_Id().toString());
		meta.put("documentTitle", P8PropertyValues.asString(mp, "DocumentTitle"));
		meta.put("creator", P8PropertyValues.asString(mp, PropertyNames.CREATOR));
		meta.put("dateCreated", P8PropertyValues.asDateTimeIsoUtc(mp, "DateCreated"));
		meta.put("dateLastModified", P8PropertyValues.asDateTimeIsoUtc(mp, "DateLastModified"));
		meta.put("status", P8PropertyValues.asString(mp, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS));

		JSONObject content = readFirstContentJson(doc);

		JSONObject out = new JSONObject();
		out.put("metadata", meta);
		out.put("reportRequest", content);
		return out;
	}

	public static JSONObject loadDocumentJsonByReportRequestId(ObjectStore os, PluginServiceCallbacks callbacks,
			String reportRequestId, int maxCandidates) throws Exception {
		JSONArray candidates = queryMyReportRequests(os, callbacks, maxCandidates);
		for (int i = 0; i < candidates.size(); i++) {
			JSONObject row = (JSONObject) candidates.get(i);
			String docId = trim(row.get("documentId"));
			if (docId == null) {
				continue;
			}
			try {
				JSONObject details = loadDocumentJson(os, docId);
				JSONObject rr = (JSONObject) details.get("reportRequest");
				if (rr != null && reportRequestId.equals(trim(rr.get("reportRequestId")))) {
					return details;
				}
			} catch (Exception e) {
				// skip unreadable rows
			}
		}
		return null;
	}

	private static JSONObject readFirstContentJson(Document doc) throws Exception {
		com.filenet.api.collection.ContentElementList cel = doc.get_ContentElements();
		if (cel == null || cel.size() == 0) {
			throw new IllegalStateException("Report request document has no content.");
		}
		Object first = cel.get(0);
		if (!(first instanceof ContentTransfer)) {
			throw new IllegalStateException("Unexpected content element type.");
		}
		ContentTransfer ct = (ContentTransfer) first;
		java.io.InputStream in = null;
		try {
			in = ct.accessContentStream();
			java.io.ByteArrayOutputStream bos = new java.io.ByteArrayOutputStream();
			byte[] buf = new byte[8192];
			int n;
			while ((n = in.read(buf)) != -1) {
				bos.write(buf, 0, n);
			}
			String text = bos.toString("UTF-8");
			Object parsed = JSON.parse(text);
			if (!(parsed instanceof JSONObject)) {
				throw new IllegalStateException("Report request content is not a JSON object.");
			}
			return (JSONObject) parsed;
		} finally {
			if (in != null) {
				try {
					in.close();
				} catch (Exception e) {
					// ignore
				}
			}
		}
	}

	/**
	 * Checks in as a major version so the document is released (not left in reservation) as version 1.0.
	 */
	private static void saveAsMajorVersion(Document doc) {
		doc.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
		doc.save(RefreshMode.REFRESH);
	}

	/**
	 * Sets {@link ReportPluginConstants} metadata on the new document. Full payload remains in JSON content.
	 */
	private static void applyReportRequestMetadata(Properties props, JSONObject payloadJson) throws Exception {
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS,
				ReportPluginConstants.REPORT_REQUEST_INITIAL_STATUS);

		String targetClass = trim(payloadJson.get("targetClassSymbolicName"));
		if (targetClass == null) {
			throw new IllegalArgumentException("targetClassSymbolicName is required to set TargetDocumentClass.");
		}
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS, targetClass);

		String repositoryName = resolveRepositoryName(payloadJson);
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPOSITORY_NAME, repositoryName);

		Object critObj = payloadJson.get("criteria");
		JSONArray criteria = critObj instanceof JSONArray ? (JSONArray) critObj : new JSONArray();
		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEARCH_CRITERIA_PARAMS,
				buildSearchCriteriaParams(criteria));

		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_RESULT_SET_COLUMNS,
				buildResultSetColumns(payloadJson));

		String sqlQuery = trim(payloadJson.get("sqlQuery"));
		if (sqlQuery != null) {
			putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SQL_QUERY, sqlQuery);
		}

		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEND_EMAIL_TO,
				buildEmailList(payloadJson, ReportPluginConstants.JSON_SEND_EMAIL_TO));
		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEND_EMAIL_CC,
				buildEmailList(payloadJson, ReportPluginConstants.JSON_SEND_EMAIL_CC));
	}

	private static String[] buildEmailList(JSONObject payloadJson, String jsonKey) {
		List<String> emails = new ArrayList<String>();
		Object raw = payloadJson.get(jsonKey);
		if (!(raw instanceof JSONArray)) {
			return new String[0];
		}
		JSONArray arr = (JSONArray) raw;
		java.util.HashSet<String> seen = new java.util.HashSet<String>();
		for (int i = 0; i < arr.size(); i++) {
			String email = trim(arr.get(i));
			if (email == null || !EmailValidator.isValid(email)) {
				continue;
			}
			String key = email.toLowerCase();
			if (seen.add(key)) {
				emails.add(email);
			}
		}
		return emails.toArray(new String[emails.size()]);
	}

	private static String resolveRepositoryName(JSONObject payloadJson) {
		String name = trim(payloadJson.get("repositoryName"));
		if (name != null) {
			return name;
		}
		name = trim(payloadJson.get("objectStoreName"));
		return name != null ? name : "";
	}

	private static String[] buildSearchCriteriaParams(JSONArray criteria) {
		List<String> entries = new ArrayList<String>();
		if (criteria == null) {
			return new String[0];
		}
		for (int i = 0; i < criteria.size(); i++) {
			Object row = criteria.get(i);
			if (!(row instanceof JSONObject)) {
				continue;
			}
			JSONObject c = (JSONObject) row;
			String prop = trim(c.get("propertySymbolicName"));
			String operator = trim(c.get("operator"));
			if (prop == null || operator == null) {
				continue;
			}
			String valuesPart = formatCriteriaValues(c.get("values"));
			entries.add(prop + "|" + operator + "|" + valuesPart);
		}
		return entries.toArray(new String[entries.size()]);
	}

	private static String formatCriteriaValues(Object valuesObj) {
		if (!(valuesObj instanceof JSONArray)) {
			return "";
		}
		JSONArray vals = (JSONArray) valuesObj;
		List<String> parts = new ArrayList<String>();
		for (int i = 0; i < vals.size(); i++) {
			Object v = vals.get(i);
			if (v == null) {
				continue;
			}
			String s = String.valueOf(v).trim();
			if (s.length() > 0) {
				parts.add(s);
			}
		}
		if (parts.isEmpty()) {
			return "";
		}
		StringBuilder sb = new StringBuilder();
		for (int i = 0; i < parts.size(); i++) {
			if (i > 0) {
				sb.append(',');
			}
			sb.append(parts.get(i));
		}
		return sb.toString();
	}

	private static String[] buildResultSetColumns(JSONObject payloadJson) {
		List<String> columns = new ArrayList<String>();
		Object rdObj = payloadJson.get("resultDisplay");
		if (!(rdObj instanceof JSONObject)) {
			return new String[0];
		}
		Object colsObj = ((JSONObject) rdObj).get("columns");
		if (!(colsObj instanceof JSONArray)) {
			return new String[0];
		}
		JSONArray cols = (JSONArray) colsObj;
		for (int i = 0; i < cols.size(); i++) {
			Object col = cols.get(i);
			if (col instanceof JSONObject) {
				String sym = trim(((JSONObject) col).get("propertySymbolicName"));
				if (sym != null) {
					columns.add(sym);
				}
			} else if (col != null) {
				String sym = String.valueOf(col).trim();
				if (sym.length() > 0) {
					columns.add(sym);
				}
			}
		}
		return columns.toArray(new String[columns.size()]);
	}

	private static void putStringProperty(Properties props, String propertyName, String value) throws Exception {
		try {
			props.putValue(propertyName, value != null ? value : "");
		} catch (RuntimeException e) {
			throw metadataAssignmentError(propertyName, e);
		}
	}

	private static void putStringListProperty(Properties props, String propertyName, String[] values) throws Exception {
		try {
			StringList list = Factory.StringList.createList();
			if (values != null) {
				for (String v : values) {
					if (v != null && v.length() > 0) {
						list.add(v);
					}
				}
			}
			props.putValue(propertyName, list);
		} catch (RuntimeException e) {
			throw metadataAssignmentError(propertyName, e);
		}
	}

	private static IllegalStateException metadataAssignmentError(String propertyName, RuntimeException cause) {
		String detail = cause.getMessage() != null ? cause.getMessage() : cause.toString();
		return new IllegalStateException(
				"Failed to set ReportRequest property '" + propertyName + "': " + detail
						+ ". Verify the property exists on class ReportRequest and the user has write access.",
				cause);
	}

	private static String trim(Object o) {
		if (o == null) {
			return null;
		}
		String s = String.valueOf(o).trim();
		return s.length() == 0 ? null : s;
	}
}




package com.cnb.reports.service;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Locale;

import org.apache.struts.util.MessageResources;

import com.cnb.reports.constants.ReportPluginConstants;
import com.cnb.reports.p8.P8PropertyValues;
import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.core.Document;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import com.ibm.ecm.extension.PluginServiceCallbacks;
import com.ibm.ecm.json.JSONResultSetColumn;
import com.ibm.ecm.json.JSONResultSetResponse;
import com.ibm.ecm.json.JSONResultSetRow;
import com.ibm.json.java.JSONArray;
import com.ibm.json.java.JSONObject;

/**
 * P8 execution for {@link com.cnb.reports.service.ReportRequestsSearchService}, modeled on IBM's
 * {@code SamplePluginSearchServiceP8}: run CE SQL, fill {@link JSONResultSetResponse}, drive {@code ContentList}.
 */
public final class ReportRequestsSearchServiceP8 {

	private static final int FETCH_PAGE_SIZE = 350;

	private ReportRequestsSearchServiceP8() {
	}

	@SuppressWarnings("rawtypes")
	public static void executeP8Search(String repositoryId, PluginServiceCallbacks callbacks,
			JSONResultSetResponse jsonResultSet, Locale clientLocale) throws Exception {
		ObjectStore objectStore = callbacks.getP8ObjectStore(repositoryId);

		buildResultStructure(jsonResultSet, callbacks.getResources(), clientLocale);

		SearchSQL searchSQL = new SearchSQL(ReportPluginConstants.REPORT_REQUEST_LIST_SQL);
		SearchScope searchScope = new SearchScope(objectStore);

		// Null filter: let CE hydrate the default property set for each row. Narrow ICN document filters plus a
		// projection-only SELECT routinely cause FNRCA0024E (MimeType, ClassDescription, ...) when calling
		// get_MimeType() / getP8PrivilegeMasks().
		List<Object> searchResults = new ArrayList<Object>(FETCH_PAGE_SIZE);
		IndependentObjectSet resultsObjectSet = searchScope.fetchObjects(searchSQL, FETCH_PAGE_SIZE, null,
				Boolean.TRUE);
		PageIterator pageIterator = resultsObjectSet.pageIterator();
		if (pageIterator.nextPage()) {
			for (Object obj : pageIterator.getCurrentPage()) {
				searchResults.add(obj);
			}
		}

		HashMap<Object, Long> privMasks = null;
		try {
			privMasks = callbacks.getP8PrivilegeMasks(repositoryId, searchResults);
		} catch (Exception e) {
			// If masks cannot be resolved, rows still render; privileges default below.
			privMasks = null;
		}

		for (Object searchResult : searchResults) {
			Document doc = (Document) searchResult;
			Properties props = doc.getProperties();

			StringBuffer sbId = new StringBuffer();
			sbId.append(doc.getClassName()).append(",").append(objectStore.get_Id().toString()).append(",")
					.append(doc.get_Id().toString());

			long privileges = 0L;
			if (privMasks != null) {
				Long pm = privMasks.get(doc);
				if (pm != null) {
					privileges = pm.longValue();
				}
			}

			String title = P8PropertyValues.asString(props, "DocumentTitle");
			if (title.length() == 0) {
				try {
					String n = doc.get_Name();
					if (n != null && n.length() > 0) {
						title = n;
					}
				} catch (RuntimeException e) {
					// Name not in cache for this row shape
				}
			}

			String mimeForRow = P8PropertyValues.asString(props, "MimeType");
			if (mimeForRow.length() == 0) {
				mimeForRow = ReportPluginConstants.JSON_MIME_TYPE;
			}

			boolean locked = false;
			String lockOwner = "";
			boolean currentVersion = true;
			try {
				locked = doc.isLocked();
				String lo = doc.get_LockOwner();
				lockOwner = lo != null ? lo : "";
				currentVersion = doc.get_IsCurrentVersion();
			} catch (RuntimeException e) {
				// Lock / version not in cache â€” safe defaults for the grid
			}

			JSONResultSetRow row = new JSONResultSetRow(sbId.toString(), title, mimeForRow, privileges);

			row.addAttribute("locked", locked, JSONResultSetRow.TYPE_BOOLEAN, null, Boolean.toString(locked));
			row.addAttribute("lockedUser", lockOwner, JSONResultSetRow.TYPE_STRING, null, lockOwner);
			row.addAttribute("currentVersion", currentVersion, JSONResultSetRow.TYPE_BOOLEAN, null,
					Boolean.toString(currentVersion));

			row.addAttribute("ID", doc.get_Id().toString(), JSONResultSetRow.TYPE_STRING, null, doc.get_Id()
					.toString());
			row.addAttribute("className", doc.getClassName(), JSONResultSetRow.TYPE_STRING, null, doc.getClassName());

			String targetClass = P8PropertyValues.asString(props,
					ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS);
			String status = P8PropertyValues.asString(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS);
			String dateCreated = P8PropertyValues.asDateTimeForResultSet(props,
					ReportPluginConstants.REPORT_REQUEST_PROPERTY_DATE_CREATED);
			String lastExecutionDate = P8PropertyValues.asDateTimeForResultSet(props,
					ReportPluginConstants.REPORT_REQUEST_PROPERTY_LAST_EXECUTION_DATE);
			String executionStartDate = P8PropertyValues.asDateTimeForResultSet(props,
					ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_START_DATE);
			String executionEndDate = P8PropertyValues.asDateTimeForResultSet(props,
					ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_END_DATE);

			row.addAttribute("DocumentTitle", title, JSONResultSetRow.TYPE_STRING, null, title);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS, targetClass,
					JSONResultSetRow.TYPE_STRING, null, targetClass);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, status, JSONResultSetRow.TYPE_STRING,
					null, status);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_DATE_CREATED, dateCreated,
					JSONResultSetRow.TYPE_STRING, null, dateCreated);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_LAST_EXECUTION_DATE, lastExecutionDate,
					JSONResultSetRow.TYPE_STRING, null, lastExecutionDate);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_START_DATE,
					executionStartDate, JSONResultSetRow.TYPE_STRING, null, executionStartDate);
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_END_DATE, executionEndDate,
					JSONResultSetRow.TYPE_STRING, null, executionEndDate);

			String downloadFlag = isCompletedStatus(status) ? "download" : "";
			row.addAttribute(ReportPluginConstants.REPORT_REQUEST_GRID_DOWNLOAD_FIELD, downloadFlag,
					JSONResultSetRow.TYPE_STRING, null, downloadFlag);

			jsonResultSet.addRow(row);
		}
	}

	private static void buildResultStructure(JSONResultSetResponse jsonResultSet, MessageResources resources,
			Locale clientLocale) throws Exception {
		String[] states = new String[1];
		states[0] = JSONResultSetColumn.STATE_LOCKED;

		jsonResultSet.addColumn(new JSONResultSetColumn("&nbsp;", "36px",
				ReportPluginConstants.REPORT_REQUEST_GRID_DOWNLOAD_FIELD, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("&nbsp;", "multiStateIcon", false, states));
		jsonResultSet.addColumn(new JSONResultSetColumn("&nbsp;", "17px", "mimeTypeIcon", null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Report Name", "220px", "DocumentTitle", null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Target Document Class", "180px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Status", "100px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Date created", "170px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_DATE_CREATED, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Last Execution Date", "170px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_LAST_EXECUTION_DATE, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Report Execution Start Date", "190px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_START_DATE, null, false));
		jsonResultSet.addColumn(new JSONResultSetColumn("Report Execution End Date", "190px",
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_END_DATE, null, false));

		JSONArray fieldsToDisplay = new JSONArray();
		fieldsToDisplay.add(fieldDisplay("DocumentTitle", "Report Name"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS,
				"Target Document Class"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, "Status"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_DATE_CREATED, "Date created"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_LAST_EXECUTION_DATE,
				"Last Execution Date"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_START_DATE,
				"Report Execution Start Date"));
		fieldsToDisplay.add(fieldDisplay(ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_END_DATE,
				"Report Execution End Date"));

		jsonResultSet.addMagazineColumn(new JSONResultSetColumn("content", "100%", "content", fieldsToDisplay,
				new JSONArray()));
	}

	private static boolean isCompletedStatus(String status) {
		return status != null
				&& ReportPluginConstants.REPORT_REQUEST_STATUS_COMPLETED.equalsIgnoreCase(status.trim());
	}

	private static JSONObject fieldDisplay(String field, String displayName) throws Exception {
		JSONObject o = new JSONObject();
		o.put("field", field);
		o.put("displayName", displayName);
		return o;
	}
}




package com.cnb.reports.service;

import java.io.BufferedReader;
import java.io.IOException;

import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import com.cnb.reports.constants.ReportPluginConstants;
import com.cnb.reports.mail.EmailService;
import com.cnb.reports.mail.MailConfig;
import com.cnb.reports.mail.ReportEmailPayloadUtil;
import com.cnb.reports.mail.ReportRequestEmailContext;
import com.cnb.reports.p8.P8ContextUtil;
import com.cnb.reports.p8.ReportRequestDocumentHelper;
import com.ibm.ecm.extension.PluginResponseUtil;
import com.ibm.ecm.extension.PluginService;
import com.ibm.ecm.extension.PluginServiceCallbacks;
import com.ibm.ecm.json.JSONResponse;
import com.ibm.json.java.JSONArray;
import com.ibm.json.java.JSONObject;


/**
 * Accepts a JSON body describing the report request, persists it as content on a {@code ReportRequest} document.
 * <p>
 * All CE access uses the logged-in user's context from {@link com.ibm.ecm.extension.PluginServiceCallbacks} (see
 * {@link com.cnb.reports.p8.P8ContextUtil}); no dedicated service connection is created for this flow.
 * </p>
 */
public class SubmitReportRequestService extends PluginService {

	public static final String SERVICE_ID = ReportPluginConstants.SERVICE_SUBMIT_REPORT_REQUEST;

	@Override
	public String getId() {
		return SERVICE_ID;
	}

	@Override
	public void execute(PluginServiceCallbacks callbacks, HttpServletRequest request, HttpServletResponse response)
			throws Exception {
		final String method = "execute";
		callbacks.getLogger().logEntry(this, method, request);
		try {
			String body = readBody(request);
			if (body == null || body.trim().isEmpty()) {
				writeFailure(response, request, callbacks, "Request body is empty.");
				return;
			}

			Object parsed;
			try {
				parsed = com.ibm.json.java.JSON.parse(body);
			} catch (Exception e) {
				writeFailure(response, request, callbacks, "Invalid JSON: " + safeMsg(e));
				return;
			}
			if (!(parsed instanceof JSONObject)) {
				writeFailure(response, request, callbacks, "Request body must be a JSON object.");
				return;
			}
			final JSONObject payload = (JSONObject) parsed;

			String repositoryId = trimString(payload.get("repositoryId"));
			if (repositoryId == null) {
				writeFailure(response, request, callbacks, "repositoryId is required.");
				return;
			}

			String reportName = trimString(payload.get("reportName"));
			if (reportName == null) {
				writeFailure(response, request, callbacks, "reportName is required.");
				return;
			}

			String targetClass = trimString(payload.get("targetClassSymbolicName"));
			if (targetClass == null) {
				writeFailure(response, request, callbacks, "targetClassSymbolicName is required.");
				return;
			}

			Object critObj = payload.get("criteria");
			if (!(critObj instanceof JSONArray)) {
				writeFailure(response, request, callbacks, "criteria must be a JSON array.");
				return;
			}

			String submittedBy = callbacks.getUserId() != null ? callbacks.getUserId() : "";
			payload.put("submittedBy", submittedBy);
			payload.put("submittedOn", nowIsoUtc());
			if (trimString(payload.get("status")) == null) {
				payload.put("status", ReportPluginConstants.REPORT_REQUEST_INITIAL_STATUS);
			}

			String invalidEmail = ReportEmailPayloadUtil.validatePayloadEmails(payload);
			if (invalidEmail != null) {
				writeFailure(response, request, callbacks,
						"Invalid email address: " + invalidEmail + ". Use semicolon (;) to separate addresses.");
				return;
			}
			ReportEmailPayloadUtil.normalizePayloadEmails(payload);

			// Persist on CE using the interactive user's P8 subject and object store from callbacks only (no service
			// connection, no alternate CE login).
			JSONObject created;
			try {
				created = P8ContextUtil.runWithP8Context(callbacks, repositoryId,
						new P8ContextUtil.P8Callback<JSONObject>() {
							@Override
							public JSONObject run(com.filenet.api.core.ObjectStore objectStore) throws Exception {
								return ReportRequestDocumentHelper.createReportRequestDocument(objectStore, payload);
							}
						});
			} catch (Exception e) {
				callbacks.getLogger().logError(this, method, request, e);
				writeFailure(response, request, callbacks, friendlyCreateError(e));
				return;
			}

			sendAcknowledgementEmailSafely(callbacks, payload);

			JSONResponse ok = new JSONResponse();
			ok.put("success", true);
			ok.put("reportRequestId", created.get("reportRequestId"));
			ok.put("documentId", created.get("documentId"));
			ok.put("message", "Report request submitted successfully.");
			PluginResponseUtil.writeJSONResponse(request, response, ok, callbacks, SERVICE_ID);
		} finally {
			callbacks.getLogger().logExit(this, method, request);
		}
	}

	private static void sendAcknowledgementEmailSafely(PluginServiceCallbacks callbacks, JSONObject payload) {
		try {
			MailConfig mailConfig = new MailConfig();
			EmailService emailService = new EmailService(mailConfig, callbacks);
			ReportRequestEmailContext context = EmailService.buildAcknowledgementContext(payload);
			emailService.sendAcknowledgementEmail(context);
		} catch (Exception ex) {
			callbacks.getLogger().logError(SubmitReportRequestService.class, "sendAcknowledgementEmailSafely", "", ex);
		}
	}

	private static String nowIsoUtc() {
		java.text.SimpleDateFormat fmt = new java.text.SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss.SSS'Z'");
		fmt.setTimeZone(java.util.TimeZone.getTimeZone("UTC"));
		return fmt.format(new java.util.Date());
	}

	private static String friendlyCreateError(Exception e) {
		String m = e.getMessage();
		if (m != null && m.length() > 0) {
			return m;
		}
		Throwable c = e.getCause();
		if (c != null && c.getMessage() != null) {
			return c.getMessage();
		}
		return "Unable to create report request document. Check class ReportRequest, security, and CE connectivity.";
	}

	private static void writeFailure(HttpServletResponse response, HttpServletRequest request,
			PluginServiceCallbacks callbacks, String message) throws Exception {
		JSONResponse err = new JSONResponse();
		err.put("success", false);
		err.put("message", message);
		PluginResponseUtil.writeJSONResponse(request, response, err, callbacks, SERVICE_ID);
	}

	private static String readBody(HttpServletRequest request) throws IOException {
		StringBuilder sb = new StringBuilder();
		BufferedReader reader = request.getReader();
		String line;
		while ((line = reader.readLine()) != null) {
			sb.append(line);
		}
		return sb.toString();
	}

	private static String trimString(Object o) {
		if (o == null) {
			return null;
		}
		String s = String.valueOf(o).trim();
		return s.length() == 0 ? null : s;
	}

	private static String safeMsg(Exception e) {
		return e.getMessage() != null ? e.getMessage() : e.toString();
	}
}




package com.cnb.reports.constants;

/**
 * Central constants for the CNB Reports plug-in (service ids, FileNet class, content naming).
 */
public final class ReportPluginConstants {

	public static final String SERVICE_SUBMIT_REPORT_REQUEST = "submitReportRequest";
	public static final String SERVICE_GET_REPORT_REQUEST_DETAILS = "getReportRequestDetails";
	/** Plugin service id: {@code JSONResultSetResponse} for {@code ecm.widget.listView.ContentList} (sample plug-in style). */
	public static final String SERVICE_REPORT_REQUESTS_SEARCH = "reportRequestsSearchService";

	public static final String REPORT_REQUEST_CLASS = "ReportRequest";

	/** Symbolic name of the custom document property for workflow state on {@link #REPORT_REQUEST_CLASS}. */
	public static final String REPORT_REQUEST_PROPERTY_STATUS = "Status";

	/** Initial value for {@link #REPORT_REQUEST_PROPERTY_STATUS} when the request is first created. */
	public static final String REPORT_REQUEST_INITIAL_STATUS = "Pending";

	/** Status value when the report output is ready to download from the grid. */
	public static final String REPORT_REQUEST_STATUS_COMPLETED = "Completed";

	/** Grid column field id for the conditional download action icon. */
	public static final String REPORT_REQUEST_GRID_DOWNLOAD_FIELD = "reportDownload";

	public static final String REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS = "TargetDocumentClass";
	public static final String REPORT_REQUEST_PROPERTY_REPOSITORY_NAME = "RepositoryName";
	public static final String REPORT_REQUEST_PROPERTY_SEND_EMAIL_TO = "SendEmailTo";
	public static final String REPORT_REQUEST_PROPERTY_SEND_EMAIL_CC = "SendEmailCC";

	/** JSON payload key for {@link #REPORT_REQUEST_PROPERTY_SEND_EMAIL_TO}. */
	public static final String JSON_SEND_EMAIL_TO = "sendEmailTo";
	/** JSON payload key for {@link #REPORT_REQUEST_PROPERTY_SEND_EMAIL_CC}. */
	public static final String JSON_SEND_EMAIL_CC = "sendEmailCC";
	public static final String REPORT_REQUEST_PROPERTY_SEARCH_CRITERIA_PARAMS = "SearchCriteriaParams";
	public static final String REPORT_REQUEST_PROPERTY_RESULT_SET_COLUMNS = "ResultSetColumns";
	public static final String REPORT_REQUEST_PROPERTY_SQL_QUERY = "SQLQuery";

	public static final String REPORT_REQUEST_PROPERTY_LAST_EXECUTION_DATE = "LastExecutionDate";
	public static final String REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_START_DATE = "ReportExecutionStartDate";
	public static final String REPORT_REQUEST_PROPERTY_REPORT_EXECUTION_END_DATE = "ReportExecutionEndDate";

	/** System property used for list sort order ({@code ORDER BY DateCreated DESC}). */
	public static final String REPORT_REQUEST_PROPERTY_DATE_CREATED = "DateCreated";

	/** Display format for date/time columns in {@code JSONResultSetResponse} grids. */
