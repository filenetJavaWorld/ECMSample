package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.Date;
import java.util.Set;

/**
 * Claims a ReportRequest for processing by atomically moving it to InProgress.
 */
public final class ReportRequestClaimService {

    private static final Logger LOGGER = LogManager.getLogger(ReportRequestClaimService.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportRequestClaimService(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public boolean tryClaim(String documentId) throws Exception {
        Document document = fetchLatest(documentId);
        String currentStatus = document.getProperties().getStringValue(config.getStatusProperty());
        Set<String> processableStatuses = config.getProcessableStatuses();

        if (!processableStatuses.contains(currentStatus)) {
            LOGGER.info("Skipping ReportRequest {} because status is {} (not processable)", documentId, currentStatus);
            return false;
        }

        Date now = new Date();
        document.getProperties().putValue(config.getStatusProperty(), config.getInProgressStatus());
        document.getProperties().putValue(config.getStartDateProperty(), now);
        document.save(RefreshMode.REFRESH);

        LOGGER.info("Claimed ReportRequest {} ({} -> {}) at {}", documentId, currentStatus,
                config.getInProgressStatus(), now);
        return true;
    }

    private Document fetchLatest(String documentId) {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), filter);
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.util.P8PropertyReader;
import com.cnb.reports.util.SqlValidationUtil;
import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.collection.StringList;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.core.Document;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.ArrayList;
import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

/**
 * Finds processable ReportRequest documents in FileNet.
 */
public final class ReportRequestFinder {

    private static final Logger LOGGER = LogManager.getLogger(ReportRequestFinder.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportRequestFinder(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public List<ReportRequestSummary> findProcessableRequests() throws Exception {
        String sql = buildFindSql(config.getProcessableStatuses());
        LOGGER.info("Searching for processable ReportRequest documents using SQL: {}", sql);

        SearchSQL searchSQL = new SearchSQL(sql);
        SearchScope scope = new SearchScope(objectStore);
        PropertyFilter filter = buildPropertyFilter();
        IndependentObjectSet resultSet = scope.fetchObjects(searchSQL, config.getPollBatchSize(), filter, Boolean.TRUE);

        List<ReportRequestSummary> summaries = new ArrayList<>();
        PageIterator pageIterator = resultSet.pageIterator();
        if (pageIterator.nextPage()) {
            Object[] page = pageIterator.getCurrentPage();
            if (page != null) {
                for (Object item : page) {
                    if (item instanceof Document) {
                        summaries.add(toSummary((Document) item));
                    }
                }
            }
        }
        LOGGER.info("Found {} processable ReportRequest documents", summaries.size());
        return summaries;
    }

    private String buildFindSql(Set<String> statuses) {
        String statusClause;
        if (statuses.size() == 1) {
            statusClause = config.getStatusProperty() + " = '"
                    + SqlValidationUtil.escapeSqlString(statuses.iterator().next()) + "'";
        } else {
            statusClause = config.getStatusProperty() + " IN ("
                    + statuses.stream()
                            .map(status -> "'" + SqlValidationUtil.escapeSqlString(status) + "'")
                            .collect(Collectors.joining(", "))
                    + ")";
        }

        return "SELECT [This], Id, DocumentTitle, DateCreated, "
                + config.getStatusProperty() + ", "
                + config.getTargetClassProperty() + ", "
                + config.getRepositoryNameProperty() + ", "
                + config.getCriteriaProperty() + ", "
                + config.getResultColumnsProperty() + ", "
                + config.getSqlQueryProperty() + ", "
                + config.getSendEmailToProperty() + ", "
                + config.getSendEmailCcProperty() + ", "
                + config.getStartDateProperty() + ", "
                + config.getEndDateProperty()
                + " FROM " + config.getReportClass()
                + " WHERE " + statusClause
                + " ORDER BY DateCreated ASC";
    }

    private PropertyFilter buildPropertyFilter() {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, "DocumentTitle", null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getTargetClassProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getRepositoryNameProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getCriteriaProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getResultColumnsProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSqlQueryProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSendEmailToProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSendEmailCcProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        return filter;
    }

    private ReportRequestSummary toSummary(Document document) {
        Properties props = document.getProperties();
        return new ReportRequestSummary(
                document.get_Id().toString(),
                P8PropertyReader.asString(props, "DocumentTitle"),
                P8PropertyReader.asString(props, config.getStatusProperty()),
                P8PropertyReader.asString(props, config.getTargetClassProperty()),
                P8PropertyReader.asString(props, config.getRepositoryNameProperty()),
                "",
                readStringList(props, config.getCriteriaProperty()),
                readStringList(props, config.getResultColumnsProperty()),
                P8PropertyReader.asString(props, config.getSqlQueryProperty()),
                readStringList(props, config.getSendEmailToProperty()),
                readStringList(props, config.getSendEmailCcProperty()),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getStartDateProperty())),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getEndDateProperty())));
    }

    private List<String> readStringList(Properties props, String propertyName) {
        List<String> values = new ArrayList<>();
        if (!props.isPropertyPresent(propertyName)) {
            return values;
        }
        try {
            StringList list = props.getStringListValue(propertyName);
            if (list != null) {
                for (Object item : list) {
                    if (item != null) {
                        String text = String.valueOf(item).trim();
                        if (!text.isEmpty()) {
                            values.add(text);
                        }
                    }
                }
            }
        } catch (Exception ex) {
            String single = P8PropertyReader.asString(props, propertyName);
            if (!single.isEmpty()) {
                values.add(single);
            }
        }
        return values;
    }
}


package com.cnb.reports;

import com.cnb.reports.email.EmailValidator;
import com.cnb.reports.model.ReportRequestPayload;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.model.SearchCriterion;
import com.cnb.reports.model.SortOption;
import com.cnb.reports.util.CePropertyNameResolver;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.apache.commons.lang3.StringUtils;

import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;

/**
 * Parses ReportRequest JSON payloads and metadata fallbacks into a normalized model.
 */
public final class ReportRequestPayloadParser {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    public ReportRequestPayload parse(String jsonText, ReportRequestSummary summary) throws Exception {
        ReportRequestPayload payload = new ReportRequestPayload();
        if (summary != null) {
            payload.setReportName(summary.getDocumentTitle());
            payload.setTargetClassSymbolicName(summary.getTargetDocumentClass());
            payload.setRepositoryName(summary.getRepositoryName());
            payload.setRepositoryId(summary.getRepositoryId());
            payload.setSqlQuery(StringUtils.trimToNull(summary.getSqlQuery()));
            payload.setResultColumns(mapResultColumnsFromMetadata(summary.getResultSetColumns()));
            payload.setCriteria(mapCriteriaFromMetadata(summary.getSearchCriteriaParams()));
            payload.setSendEmailTo(summary.getSendEmailTo());
            payload.setSendEmailCC(summary.getSendEmailCC());
        }

        if (StringUtils.isNotBlank(jsonText)) {
            JsonNode root = MAPPER.readTree(jsonText);
            mergeJsonPayload(payload, root);
        }

        if (StringUtils.isBlank(payload.getTargetClassSymbolicName())) {
            throw new IllegalArgumentException("Target document class is missing from payload and metadata.");
        }
        if (payload.getResultColumns().isEmpty()) {
            payload.setResultColumns(defaultResultColumns(payload.getTargetClassSymbolicName()));
        }
        payload.setResultColumns(normalizeResultColumns(payload.getResultColumns()));
        return payload;
    }

    private List<ResultColumn> normalizeResultColumns(List<ResultColumn> columns) {
        List<ResultColumn> normalized = new ArrayList<>();
        for (ResultColumn column : columns) {
            normalized.add(CePropertyNameResolver.toResultColumn(column.getPropertySymbolicName()));
            if (StringUtils.isNotBlank(column.getPropertyDisplayName())
                    && !column.getPropertyDisplayName().equals(column.getPropertySymbolicName())) {
                normalized.set(normalized.size() - 1,
                        new ResultColumn(normalized.get(normalized.size() - 1).getPropertySymbolicName(),
                                column.getPropertyDisplayName()));
            }
        }
        return normalized;
    }

    private void mergeJsonPayload(ReportRequestPayload payload, JsonNode root) {
        if (root == null || root.isNull()) {
            return;
        }

        setIfPresent(payload::setReportName, firstNonBlank(text(root, "reportName"), text(root, "name")));
        setIfPresent(payload::setTargetClassSymbolicName,
                firstNonBlank(text(root, "targetClassSymbolicName"), text(root, "template_name"), text(root, "className")));
        setIfPresent(payload::setRepositoryName, text(root, "repositoryName"));
        setIfPresent(payload::setRepositoryId, text(root, "repositoryId"));
        setIfPresent(payload::setSubmittedOn, text(root, "submittedOn"));
        setIfPresent(payload::setSqlQuery, text(root, "sqlQuery"));
        setIfPresent(payload::setSearchScope, text(root, "searchScope"));
        setIfPresent(payload::setVersionOption, text(root, "versionOption"));

        if (root.has("includeSubclasses")) {
            payload.setIncludeSubclasses(root.path("includeSubclasses").asBoolean(false));
        } else if (root.has("searchSubclasses")) {
            payload.setIncludeSubclasses(root.path("searchSubclasses").asBoolean(false));
        }

        JsonNode moreOptions = root.path("moreOptions");
        if (!moreOptions.isMissingNode() && moreOptions.has("versionOption")) {
            payload.setVersionOption(moreOptions.path("versionOption").asText(null));
        }

        if (root.has("criteria")) {
            payload.setCriteria(parsePluginCriteria(root.path("criteria")));
        } else if (root.has("searchCriteria")) {
            payload.setCriteria(parseIcnCriteria(root.path("searchCriteria")));
        }

        if (root.has("resultDisplay")) {
            payload.setResultColumns(parsePluginResultColumns(root.path("resultDisplay")));
            payload.setSortOptions(parsePluginSort(root.path("resultDisplay")));
        } else if (root.has("resultsDisplay")) {
            payload.setResultColumns(parseIcnResultColumns(root.path("resultsDisplay")));
            payload.setSortOptions(parseIcnSort(root.path("resultsDisplay")));
        }

        payload.setSendEmailTo(readEmailArray(root.get("sendEmailTo")));
        payload.setSendEmailCC(readEmailArray(root.get("sendEmailCC")));
        if (payload.getSendEmailCC().isEmpty()) {
            payload.setSendEmailCC(readEmailArray(root.get("sendEmailCc")));
        }
    }

    private List<String> readEmailArray(com.fasterxml.jackson.databind.JsonNode node) {
        if (node == null || !node.isArray()) {
            return List.of();
        }
        List<String> emails = new ArrayList<>();
        for (com.fasterxml.jackson.databind.JsonNode value : node) {
            if (value != null && !value.isNull()) {
                emails.add(value.asText());
            }
        }
        return EmailValidator.normalizeList(emails);
    }

    private List<SearchCriterion> parsePluginCriteria(JsonNode criteriaNode) {
        List<SearchCriterion> criteria = new ArrayList<>();
        if (!criteriaNode.isArray()) {
            return criteria;
        }
        for (JsonNode node : criteriaNode) {
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(text(node, "propertySymbolicName"));
            criterion.setPropertyDisplayName(text(node, "propertyDisplayName"));
            criterion.setOperator(text(node, "operator"));
            criterion.setDataType(text(node, "dataType"));
            criterion.setValues(readValues(node.path("values")));
            if (StringUtils.isNotBlank(criterion.getPropertySymbolicName())
                    && StringUtils.isNotBlank(criterion.getOperator())) {
                criteria.add(criterion);
            }
        }
        return criteria;
    }

    private List<SearchCriterion> parseIcnCriteria(JsonNode criteriaNode) {
        List<SearchCriterion> criteria = new ArrayList<>();
        if (!criteriaNode.isArray()) {
            return criteria;
        }
        for (JsonNode node : criteriaNode) {
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(text(node, "id"));
            criterion.setPropertyDisplayName(firstNonBlank(text(node, "name"), text(node, "label")));
            criterion.setOperator(text(node, "selectedOperator"));
            criterion.setDataType(text(node, "dataType"));
            criterion.setValues(readValues(node.path("values")));
            if (StringUtils.isNotBlank(criterion.getPropertySymbolicName())
                    && StringUtils.isNotBlank(criterion.getOperator())) {
                criteria.add(criterion);
            }
        }
        return criteria;
    }

    private List<ResultColumn> parsePluginResultColumns(JsonNode resultDisplay) {
        List<ResultColumn> columns = new ArrayList<>();
        JsonNode cols = resultDisplay.path("columns");
        if (!cols.isArray()) {
            return columns;
        }
        for (JsonNode col : cols) {
            if (col.isObject()) {
                columns.add(CePropertyNameResolver.toResultColumn(
                        firstNonBlank(text(col, "propertySymbolicName"), text(col, "propertyDisplayName"))));
            } else {
                String symbolic = col.asText(null);
                if (StringUtils.isNotBlank(symbolic)) {
                    columns.add(CePropertyNameResolver.toResultColumn(symbolic));
                }
            }
        }
        return columns;
    }

    private List<ResultColumn> parseIcnResultColumns(JsonNode resultsDisplay) {
        List<ResultColumn> columns = new ArrayList<>();
        JsonNode cols = resultsDisplay.path("columns");
        if (!cols.isArray()) {
            return columns;
        }
        for (JsonNode col : cols) {
            String symbolic = col.asText(null);
            if (StringUtils.isNotBlank(symbolic)) {
                columns.add(CePropertyNameResolver.toResultColumn(symbolic));
            }
        }
        return columns;
    }

    private List<SortOption> parsePluginSort(JsonNode resultDisplay) {
        List<SortOption> sortOptions = new ArrayList<>();
        JsonNode sort = resultDisplay.path("sort");
        if (!sort.isArray()) {
            return sortOptions;
        }
        for (JsonNode node : sort) {
            sortOptions.add(new SortOption(text(node, "propertySymbolicName"), text(node, "direction")));
        }
        return sortOptions;
    }

    private List<SortOption> parseIcnSort(JsonNode resultsDisplay) {
        List<SortOption> sortOptions = new ArrayList<>();
        String sortBy = text(resultsDisplay, "sortBy");
        if (StringUtils.isNotBlank(sortBy)) {
            String direction = resultsDisplay.path("sortAsc").asBoolean(true) ? "ASC" : "DESC";
            sortOptions.add(new SortOption(sortBy, direction));
        }
        return sortOptions;
    }

    private List<SearchCriterion> mapCriteriaFromMetadata(List<String> encodedCriteria) {
        List<SearchCriterion> criteria = new ArrayList<>();
        for (String entry : encodedCriteria) {
            String[] parts = entry.split("\\|", 3);
            if (parts.length < 2) {
                continue;
            }
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(parts[0].trim());
            criterion.setOperator(parts[1].trim());
            if (parts.length == 3 && StringUtils.isNotBlank(parts[2])) {
                List<String> values = new ArrayList<>();
                for (String value : parts[2].split(",")) {
                    if (StringUtils.isNotBlank(value)) {
                        values.add(value.trim());
                    }
                }
                criterion.setValues(values);
            }
            criteria.add(criterion);
        }
        return criteria;
    }

    private List<ResultColumn> mapResultColumnsFromMetadata(List<String> columns) {
        List<ResultColumn> result = new ArrayList<>();
        for (String column : columns) {
            if (StringUtils.isNotBlank(column)) {
                result.add(CePropertyNameResolver.toResultColumn(column.trim()));
            }
        }
        return result;
    }

    private List<ResultColumn> defaultResultColumns(String targetClass) {
        List<ResultColumn> columns = new ArrayList<>();
        columns.add(new ResultColumn("Id", "Id"));
        columns.add(new ResultColumn("DocumentTitle", "DocumentTitle"));
        columns.add(new ResultColumn(targetClass, targetClass));
        return columns;
    }

    private List<String> readValues(JsonNode valuesNode) {
        List<String> values = new ArrayList<>();
        if (!valuesNode.isArray()) {
            return values;
        }
        for (JsonNode valueNode : valuesNode) {
            if (valueNode == null || valueNode.isNull()) {
                continue;
            }
            if (valueNode.isObject() && valueNode.has("value")) {
                addIfPresent(values, valueNode.path("value").asText(null));
            } else {
                addIfPresent(values, valueNode.asText(null));
            }
        }
        return values;
    }

    private void addIfPresent(List<String> values, String value) {
        if (StringUtils.isNotBlank(value)) {
            values.add(value.trim());
        }
    }

    private String text(JsonNode node, String field) {
        if (node == null || node.isMissingNode() || node.isNull()) {
            return null;
        }
        JsonNode value = node.get(field);
        if (value == null || value.isNull()) {
            return null;
        }
        String text = value.asText(null);
        return StringUtils.isBlank(text) ? null : text.trim();
    }

    private String firstNonBlank(String... values) {
        for (String value : values) {
            if (StringUtils.isNotBlank(value)) {
                return value.trim();
            }
        }
        return null;
    }

    private void setIfPresent(java.util.function.Consumer<String> setter, String value) {
        if (StringUtils.isNotBlank(value)) {
            setter.accept(value.trim());
        }
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.util.P8PropertyReader;
import com.filenet.api.collection.ContentElementList;
import com.filenet.api.collection.StringList;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.core.ContentTransfer;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.ByteArrayOutputStream;
import java.io.InputStream;
import java.nio.charset.StandardCharsets;
import java.util.ArrayList;
import java.util.List;

/**
 * Reads ReportRequest metadata and attached JSON payload from FileNet.
 */
public final class ReportRequestPayloadReader {

    private static final Logger LOGGER = LogManager.getLogger(ReportRequestPayloadReader.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportRequestPayloadReader(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public ReportRequestSummary readSummary(String documentId) throws Exception {
        Document document = fetchDocument(documentId);
        return toSummary(document);
    }

    public String readJsonPayload(String documentId) throws Exception {
        Document document = fetchDocument(documentId);
        return readJsonContent(document);
    }

    private ReportRequestSummary toSummary(Document document) {
        Properties props = document.getProperties();
        return new ReportRequestSummary(
                document.get_Id().toString(),
                P8PropertyReader.asString(props, "DocumentTitle"),
                P8PropertyReader.asString(props, config.getStatusProperty()),
                P8PropertyReader.asString(props, config.getTargetClassProperty()),
                P8PropertyReader.asString(props, config.getRepositoryNameProperty()),
                "",
                readStringList(props, config.getCriteriaProperty()),
                readStringList(props, config.getResultColumnsProperty()),
                P8PropertyReader.asString(props, config.getSqlQueryProperty()),
                readStringList(props, config.getSendEmailToProperty()),
                readStringList(props, config.getSendEmailCcProperty()),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getStartDateProperty())),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getEndDateProperty())));
    }

    private Document fetchDocument(String documentId) {
        PropertyFilter pf = new PropertyFilter();
        pf.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        pf.addIncludeProperty(0, null, null, "DocumentTitle", null);
        pf.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getTargetClassProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getRepositoryNameProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getCriteriaProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getResultColumnsProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getSqlQueryProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getSendEmailToProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getSendEmailCcProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        pf.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        pf.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), pf);
    }

    private List<String> readStringList(Properties props, String propertyName) {
        List<String> values = new ArrayList<>();
        if (!props.isPropertyPresent(propertyName)) {
            return values;
        }
        try {
            StringList list = props.getStringListValue(propertyName);
            if (list != null) {
                for (Object item : list) {
                    if (item != null) {
                        String text = String.valueOf(item).trim();
                        if (!text.isEmpty()) {
                            values.add(text);
                        }
                    }
                }
            }
        } catch (Exception ex) {
            String single = P8PropertyReader.asString(props, propertyName);
            if (!single.isEmpty()) {
                values.add(single);
            }
        }
        return values;
    }

    private String readJsonContent(Document document) throws Exception {
        ContentElementList elements = document.get_ContentElements();
        if (elements == null || elements.isEmpty()) {
            throw new IllegalStateException("ReportRequest document has no content elements.");
        }

        for (Object element : elements) {
            if (!(element instanceof ContentTransfer)) {
                continue;
            }
            ContentTransfer transfer = (ContentTransfer) element;
            String retrievalName = transfer.get_RetrievalName();
            String contentType = transfer.get_ContentType();
            if (isJsonContent(retrievalName, contentType)) {
                return readStream(transfer);
            }
        }

        Object first = elements.get(0);
        if (!(first instanceof ContentTransfer)) {
            throw new IllegalStateException("Unexpected content element type on ReportRequest document.");
        }
        return readStream((ContentTransfer) first);
    }

    private boolean isJsonContent(String retrievalName, String contentType) {
        if (contentType != null && contentType.toLowerCase().contains("json")) {
            return true;
        }
        return retrievalName != null && retrievalName.toLowerCase().endsWith(".json");
    }

    private String readStream(ContentTransfer transfer) throws Exception {
        try (InputStream in = transfer.accessContentStream();
                ByteArrayOutputStream out = new ByteArrayOutputStream()) {
            byte[] buffer = new byte[8192];
            int read;
            while ((read = in.read(buffer)) != -1) {
                out.write(buffer, 0, read);
            }
            String text = out.toString(StandardCharsets.UTF_8);
            LOGGER.debug("Read JSON payload ({} bytes) from content element {}", text.length(),
                    transfer.get_RetrievalName());
            return text;
        }
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.core.VersionSeries;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.Date;

/**
 * Updates ReportRequest status and execution date properties.
 */
public final class ReportStatusService {

    private static final Logger LOGGER = LogManager.getLogger(ReportStatusService.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportStatusService(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public void markInProgress(String documentId, Date startDate) throws Exception {
        updateStatus(fetchCurrentVersionDocument(documentId), config.getInProgressStatus(), startDate, null, null);
    }

    public void markCompleted(String documentId, Date endDate) throws Exception {
        updateStatus(fetchCurrentVersionDocument(documentId), config.getCompletedStatus(), null, endDate, endDate);
    }

    public void markFailed(String documentId, Date endDate) throws Exception {
        updateStatus(fetchCurrentVersionDocument(documentId), config.getFailedStatus(), null, endDate, endDate);
    }

    public void markCompletedOnDocument(Document document, Date endDate) throws Exception {
        applyCompletedStatus(document, endDate);
        document.save(RefreshMode.REFRESH);
    }

    public void applyCompletedStatus(Document document, Date endDate) {
        if (endDate != null) {
            document.getProperties().putValue(config.getEndDateProperty(), endDate);
            document.getProperties().putValue(config.getLastExecutionDateProperty(), endDate);
        }
        document.getProperties().putValue(config.getStatusProperty(), config.getCompletedStatus());
    }

    private void updateStatus(Document document, String status, Date startDate, Date endDate, Date lastExecutionDate)
            throws Exception {
        if (startDate != null) {
            document.getProperties().putValue(config.getStartDateProperty(), startDate);
        }
        if (endDate != null) {
            document.getProperties().putValue(config.getEndDateProperty(), endDate);
        }
        if (lastExecutionDate != null) {
            document.getProperties().putValue(config.getLastExecutionDateProperty(), lastExecutionDate);
        }
        document.getProperties().putValue(config.getStatusProperty(), status);
        document.save(RefreshMode.REFRESH);
        LOGGER.info("Updated ReportRequest {} status to {}", document.get_Id(), status);
    }

    public String readStatus(String documentId) {
        Document document = fetchDocument(documentId);
        return document.getProperties().getStringValue(config.getStatusProperty());
    }

    private Document fetchCurrentVersionDocument(String documentId) {
        Document document = fetchDocument(documentId);
        VersionSeries versionSeries = document.get_VersionSeries();
        if (versionSeries != null) {
            Object currentVersion = versionSeries.get_CurrentVersion();
            if (currentVersion instanceof Document) {
                return fetchDocument(((Document) currentVersion).get_Id().toString());
            }
        }
        return document;
    }

    private Document fetchDocument(String documentId) {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getLastExecutionDateProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), filter);
    }
}


