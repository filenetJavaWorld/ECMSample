    }

    public void sendCompletionEmail(ReportRequestEmailContext context) {
        sendSafely("completion", () -> {
            String subject = "Report Completed - " + safe(context.getReportName());
            String defaultBody = StringUtils.isBlank(context.getBookmarkUrl())
                    ? DEFAULT_COMPLETION_BODY_NO_BOOKMARK
                    : DEFAULT_COMPLETION_BODY;
            String body = EmailTemplateRenderer.render(
                    config.getCompletionTemplatePath(), defaultBody, context);
            sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc(), null);
        });
    }

    public void sendFailureEmail(ReportRequestEmailContext context) {
        sendSafely("failure", () -> {
            String subject = "Report Failed - " + safe(context.getReportName());
            String body = EmailTemplateRenderer.render(
                    config.getFailureTemplatePath(), DEFAULT_FAILURE_BODY, context);
            sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc(), null);
        });
    }

    private void sendSafely(String type, EmailAction action) {
        try {
            action.run();
        } catch (Exception ex) {
            LOGGER.error("Failed to send {} email.", type, ex);
        }
    }

    private static String safe(String value) {
        return value != null ? value : "Report Request";
    }

    @FunctionalInterface
    private interface EmailAction {
        void run() throws Exception;
    }
}


package com.cnb.reports.email;

import org.apache.commons.lang3.StringUtils;

import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;

public final class EmailTemplateRenderer {

    private EmailTemplateRenderer() {
    }

    public static String render(Path templateFile, String defaultTemplate, ReportRequestEmailContext context)
            throws IOException {
        String template = defaultTemplate;
        if (templateFile != null && Files.isRegularFile(templateFile)) {
            template = Files.readString(templateFile, StandardCharsets.UTF_8);
        }
        return applyPlaceholders(template, context);
    }

    public static String applyPlaceholders(String template, ReportRequestEmailContext context) {
        if (template == null) {
            return "";
        }
        String rendered = template;
        rendered = replace(rendered, "reportName", context.getReportName());
        rendered = replace(rendered, "targetDocumentClass", context.getTargetDocumentClass());
        rendered = replace(rendered, "repositoryName", context.getRepositoryName());
        rendered = replace(rendered, "status", context.getStatus());
        rendered = replace(rendered, "submittedOn", context.getSubmittedOn());
        rendered = replace(rendered, "executionStartDate", context.getExecutionStartDate());
        rendered = replace(rendered, "executionEndDate", context.getExecutionEndDate());
        rendered = replace(rendered, "bookmarkUrl", context.getBookmarkUrl());
        rendered = replace(rendered, "repositoryId", context.getRepositoryId());
        rendered = replace(rendered, "documentId", context.getDocumentId());
        rendered = replace(rendered, "latestVersionId", context.getLatestVersionId());
        return rendered;
    }

    private static String replace(String template, String key, String value) {
        return template.replace("${" + key + "}", StringUtils.defaultString(value));
    }
}


package com.cnb.reports.email;

import org.apache.commons.lang3.StringUtils;

import java.util.ArrayList;
import java.util.LinkedHashSet;
import java.util.List;
import java.util.Set;
import java.util.regex.Pattern;

public final class EmailValidator {

    private static final Pattern EMAIL_PATTERN = Pattern.compile(
            "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");

    private EmailValidator() {
    }

    public static boolean isValid(String email) {
        return StringUtils.isNotBlank(email) && EMAIL_PATTERN.matcher(email.trim()).matches();
    }

    public static List<String> normalizeList(List<String> rawEmails) {
        Set<String> unique = new LinkedHashSet<>();
        if (rawEmails == null) {
            return List.of();
        }
        for (String raw : rawEmails) {
            if (StringUtils.isBlank(raw)) {
                continue;
            }
            String trimmed = raw.trim();
            if (isValid(trimmed)) {
                unique.add(trimmed);
            }
        }
        return new ArrayList<>(unique);
    }

    public static List<String> parseSemicolonSeparated(String value) {
        List<String> emails = new ArrayList<>();
        if (StringUtils.isBlank(value)) {
            return emails;
        }
        for (String part : value.split(";")) {
            if (StringUtils.isNotBlank(part)) {
                emails.add(part.trim());
            }
        }
        return normalizeList(emails);
    }

    public static String invalidEmailMessage(String email) {
        return "Invalid email address: " + email;
    }

    public static String firstInvalid(List<String> emails) {
        if (emails == null) {
            return null;
        }
        for (String email : emails) {
            if (StringUtils.isNotBlank(email) && !isValid(email.trim())) {
                return email.trim();
            }
        }
        return null;
    }
}


