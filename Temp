import com.filenet.api.collection.ContentElementList;
import com.filenet.api.constants.AutoClassify;
import com.filenet.api.constants.CheckinType;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.core.ContentTransfer;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.Id;
import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.mapper.PropertyMapper;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.File;
import java.io.FileInputStream;
import java.util.Map;

/**
 * Creates and checks in FileNet documents from CSV row data.
 */
public class DocumentUploader {

    private static final Logger LOG = LogManager.getLogger(DocumentUploader.class);
    private static final String DOCUMENT_TITLE = "DocumentTitle";

    private final ObjectStore objectStore;
    private final AppConfig config;

    public DocumentUploader(ObjectStore objectStore, AppConfig config) {
        this.objectStore = objectStore;
        this.config = config;
    }

    /**
     * Creates a document from a CSV row, attaches content, and checks it in as a major version.
     *
     * @param className document class symbolic name
     * @param row       CSV row data
     * @param rowNumber row number for default title generation
     * @return created document ID
     * @throws Exception if document creation fails
     */
    public String uploadDocument(String className, Map<String, String> row, int rowNumber) throws Exception {
        Document document = Factory.Document.createInstance(objectStore, className);

        String title = row.containsKey(DOCUMENT_TITLE) && row.get(DOCUMENT_TITLE) != null
                && !row.get(DOCUMENT_TITLE).trim().isEmpty()
                ? row.get(DOCUMENT_TITLE).trim()
                : className + "_Doc_" + rowNumber;

        document.getProperties().putValue(DOCUMENT_TITLE, title);
        document.set_MimeType(config.getMimeType());

        PropertyMapper.applyProperties(document, objectStore, className, row);
        attachContent(document);

        document.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
        document.save(RefreshMode.REFRESH);

        Id documentId = document.get_Id();
        LOG.info("Document uploaded - Class: {}, Title: {}, ID: {}", className, title, documentId);
        return documentId.toString();
    }

    private void attachContent(Document document) throws Exception {
        File contentFile = new File(config.getSampleContentFile());
        if (!contentFile.exists()) {
            throw new IllegalStateException("Sample content file not found: " + contentFile.getAbsolutePath());
        }

        ContentTransfer contentTransfer = Factory.ContentTransfer.createInstance();
        contentTransfer.setCaptureSource(new FileInputStream(contentFile));
        contentTransfer.set_RetrievalName(contentFile.getName());
        contentTransfer.set_ContentType(config.getMimeType());

        ContentElementList contentList = Factory.ContentElement.createList();
        contentList.add(contentTransfer);
        document.set_ContentElements(contentList);
    }
}




