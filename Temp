package com.cnb.updater.config;

public enum CisExistenceCheck {
    ANY_VALUE,
    VALUE_IN_LIST;

    public static CisExistenceCheck fromConfig(String value) {
        if (value == null) {
            throw new IllegalArgumentException("target.cis.existenceCheck is required.");
        }
        try {
            return CisExistenceCheck.valueOf(value.trim().toUpperCase());
        } catch (IllegalArgumentException ex) {
            throw new IllegalArgumentException("Unsupported target.cis.existenceCheck: " + value
                    + ". Supported values: ANY_VALUE, VALUE_IN_LIST");
        }
    }

    public boolean isExisting(java.util.List<String> currentValues, String excelCisValue) {
        if (currentValues == null || currentValues.isEmpty()) {
            return false;
        }

        if (this == ANY_VALUE) {
            return true;
        }

        if (excelCisValue == null || excelCisValue.trim().isEmpty()) {
            return false;
        }

        String normalizedExcelValue = excelCisValue.trim();
        for (String currentValue : currentValues) {
            if (currentValue != null && normalizedExcelValue.equals(currentValue.trim())) {
                return true;
            }
        }
        return false;
    }
}




