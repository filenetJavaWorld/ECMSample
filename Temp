define([
	"dojo/_base/declare",
	"dojo/_base/lang",
	"dojo/aspect",
	"dojo/dom-class",
	"dojo/dom-style",
	"dijit/form/RadioButton",
	"ecm/LoggerMixin",
	"ecm/MessagesMixin",
	"ecm/widget/dialog/BaseDialog",
	"ecm/widget/dialog/MessageDialog",
	"ecm/widget/search/BasicSearchDefinition",
	"dojo/text!./templates/ReportRequestDialog.html",
	"./ReportService",
	"./ReportRequestDialogHelper"
], function(declare, lang, aspect, domClass, domStyle, RadioButton, LoggerMixin, MessagesMixin, BaseDialog,
	MessageDialog, BasicSearchDefinition, template, reportService, dialogHelper) {

	return declare("cNBReportsPluginDojo.ReportRequestDialog", [
		BaseDialog,
		LoggerMixin,
		MessagesMixin
	], {
		contentString: template,
		widgetsInTemplate: true,
		repository: null,
		cancelButtonLabel: "Cancel",
		editMode: false,
		documentId: null,
		details: null,
		/** Optional details used to prefill Create dialog (Copy / Reinitiate). */
		prefillDetails: null,

		postCreate: function() {
			this.inherited(arguments);
			var title = this.editMode ? "Edit Request" : "Create Report Request";
			var buttonLabel = this.editMode ? "Save Report Request" : "Submit Report Request";
			this.setTitle(title);
			this.setIntroText("");
			this.addButton(buttonLabel, "_onSubmit", false, true);

			this.searchDefinition = new BasicSearchDefinition({
				displaySearchInCtrl: false,
				saveSupported: false
			});
			this.searchDefinitionHost.set("content", this.searchDefinition);
			this.searchDefinition.setRepository(this.repository);

			this.own(this.sendEmailYesRadio.on("change", lang.hitch(this, "_onSendEmailChoiceChanged")));
			this.own(this.sendEmailNoRadio.on("change", lang.hitch(this, "_onSendEmailChoiceChanged")));
			this._updateEmailFieldsState();

			this.own(aspect.after(this.searchDefinition, "onLoad", lang.hitch(this, function() {
				this._configureSearchDefinitionUi();
				// Apply JSON after BasicSearchDefinition finishes its initial load.
				if (this._pendingEditPopulate) {
					this._populateFromDetails();
				}
			})));
			if (this.searchDefinition.contentClassSelector) {
				this.own(this.connect(this.searchDefinition.contentClassSelector, "onContentClassSelected",
					lang.hitch(this, function() {
						setTimeout(lang.hitch(this, "_configureSearchDefinitionUi"), 50);
						setTimeout(lang.hitch(this, "_configureSearchDefinitionUi"), 300);
					})));
			}
			if (lang.isFunction(this.searchDefinition._setAttributeDefinitionFormFields)) {
				this.own(aspect.after(this.searchDefinition, "_setAttributeDefinitionFormFields",
					lang.hitch(this, function() {
						setTimeout(lang.hitch(this, "_configureSearchDefinitionUi"), 0);
					})));
			}
		},

		_configureSearchDefinitionUi: function() {
			var sd = this.searchDefinition;
			if (!sd) {
				return;
			}
			var hideNode = function(node) {
				if (node) {
					domStyle.set(node, "display", "none");
				}
			};
			var hideBtn = function(w) {
				if (w && w.domNode) {
					hideNode(w.domNode);
				}
			};
			hideBtn(sd.searchButton);
			hideBtn(sd.saveButton);
			hideBtn(sd.saveAsButton);
			hideBtn(sd.cancelButton);
			hideBtn(sd.showAllLink);
			hideBtn(sd.resetButton);
			hideBtn(sd._addGroupButton);
			if (sd._propertyOptions && sd._propertyOptions.domNode) {
				hideNode(sd._propertyOptions.domNode);
			}
			if (sd._moreOptions && sd._moreOptions.domNode) {
				hideNode(sd._moreOptions.domNode);
			}
			if (sd._moreOptionsNode) {
				hideNode(sd._moreOptionsNode);
			}
			if (sd._folderLabelNode && sd._folderLabelNode.parentNode) {
				var searchInRow = sd._folderLabelNode.parentNode.parentNode;
				if (searchInRow && searchInRow.tagName === "TR") {
					hideNode(searchInRow);
				}
			}
			if (sd.folderSelector && sd.folderSelector.domNode) {
				hideNode(sd.folderSelector.domNode);
			}
			if (sd.folderSelectorDropDown && sd.folderSelectorDropDown.domNode) {
				hideNode(sd.folderSelectorDropDown.domNode);
			}
			if (sd.searchInDropDown && sd.searchInDropDown.domNode) {
				hideNode(sd.searchInDropDown.domNode);
			}
			var k = sd.keepSearchCriteriaExpanded;
			if (k && k.domNode && k.domNode.parentNode) {
				hideNode(k.domNode.parentNode);
			}
			if (sd._displayAllPropsArea) {
				hideNode(sd._displayAllPropsArea);
			} else if (sd._displayAllProps && sd._displayAllProps.domNode && sd._displayAllProps.domNode.parentNode) {
				hideNode(sd._displayAllProps.domNode.parentNode);
			}
			// Hide text search block ("Find items with the following terms", combination/terms options).
			// Works across ICN 2.0.3 and 3.2 attach-point naming.
			if (sd._textSearchNode) {
				hideNode(sd._textSearchNode);
				domClass.add(sd._textSearchNode, "dijitHidden");
			}
			if (sd.textSearchContainer) {
				hideNode(sd.textSearchContainer);
				domClass.add(sd.textSearchContainer, "dijitHidden");
			}
			if (sd._textSearchOptions && sd._textSearchOptions.domNode) {
				hideNode(sd._textSearchOptions.domNode);
				domClass.add(sd._textSearchOptions.domNode, "dijitHidden");
			}
			if (sd.matchAllCriteriaMessageNode) {
				hideNode(sd.matchAllCriteriaMessageNode);
				domClass.add(sd.matchAllCriteriaMessageNode, "dijitHidden");
			}
			this._showAddPropertyButton(sd);
			this._showResultsDisplayButton(sd);
		},

		_showAddPropertyButton: function(searchDefinition) {
			var sd = searchDefinition || this.searchDefinition;
			if (!sd || !sd.addPropertyButton || !sd.addPropertyButton.domNode) {
				return;
			}
			var node = sd.addPropertyButton.domNode;
			domClass.remove(node, "dijitHidden");
			domClass.add(node, "cnbShowAddProperty");
			domStyle.set(node, "display", "inline-block");
			domStyle.set(node, "visibility", "visible");
		},

		_showResultsDisplayButton: function(searchDefinition) {
			var sd = searchDefinition || this.searchDefinition;
			if (!sd || !sd.resultsDisplayButton || !sd.resultsDisplayButton.domNode) {
				return;
			}
			var node = sd.resultsDisplayButton.domNode;
			domClass.remove(node, "dijitHidden");
			domClass.add(node, "cnbShowResultsDisplay");
			domStyle.set(node, "display", "inline-block");
			domStyle.set(node, "visibility", "visible");
			// Keep Results Display usable for column selection (not overridden by "display all").
			if (sd._displayAllProps) {
				sd._displayAllProps.set("value", false);
			}
			sd.resultsDisplayButton.set("disabled", false);
		},

		show: function() {
			this.inherited(arguments);
			var details = this.editMode ? this.details : this.prefillDetails;
			if (details) {
				this._pendingEditPopulate = true;
				// Prefer onLoad-driven populate; fall back if onLoad already fired.
				if (this.searchDefinition && this.searchDefinition._loaded) {
					this._populateFromDetails();
				} else {
					setTimeout(lang.hitch(this, function() {
						if (this._pendingEditPopulate) {
							this._populateFromDetails();
						}
					}), 750);
				}
			} else {
				this.sendEmailYesRadio.set("checked", true);
				this.sendEmailNoRadio.set("checked", false);
				this._updateEmailFieldsState();
			}
			setTimeout(lang.hitch(this, "_configureSearchDefinitionUi"), 100);
			if (this.searchDefinition && this.searchDefinition.resize) {
				this.searchDefinition.resize();
			}
		},

		_populateFromDetails: function() {
			var details = this.editMode ? this.details : this.prefillDetails;
			if (!details || this._editPopulateInProgress) {
				return;
			}
			var reportRequest = details.reportRequest || {};
			var metadata = details.metadata || {};
			if (!reportRequest || (!reportRequest.targetClassSymbolicName && !(reportRequest.criteria && reportRequest.criteria.length))) {
				// details.reportRequest may be missing if JSON failed to parse; still fill basic fields.
				dialogHelper.populateBasicFieldsFromPayload(this, reportRequest, metadata);
				this._pendingEditPopulate = false;
				return;
			}

			this._editPopulateInProgress = true;
			dialogHelper.populateBasicFieldsFromPayload(this, reportRequest, metadata);

			var self = this;
			dialogHelper.applyPayloadToSearchDefinition(this.searchDefinition, this.repository, reportRequest,
				function() {
					self._editPopulateInProgress = false;
					self._pendingEditPopulate = false;
					self._configureSearchDefinitionUi();
					if (self.searchDefinition && self.searchDefinition.resize) {
						self.searchDefinition.resize();
					}
				});
		},

		_isSendEmailEnabled: function() {
			return this.sendEmailYesRadio.get("checked");
		},

		_onSendEmailChoiceChanged: function(checked) {
			if (!checked) {
				return;
			}
			this._updateEmailFieldsState();
		},

		_updateEmailFieldsState: function() {
			var enabled = this._isSendEmailEnabled();
			this.sendEmailToField.set("disabled", !enabled);
			this.sendEmailCcField.set("disabled", !enabled);
			if (!enabled) {
				this.sendEmailToField.set("value", "");
				this.sendEmailCcField.set("value", "");
			}
		},

		resize: function() {
			this.inherited(arguments);
			if (this.searchDefinition && this.searchDefinition.resize) {
				this.searchDefinition.resize();
			}
		},

		_onSubmit: function() {
			if (!this.reportNameField.validate()) {
				return;
			}
			var invalid = this.searchDefinition.attributeDefinitionFormWid
				&& this.searchDefinition.attributeDefinitionFormWid.validate();
			if (invalid) {
				if (invalid.focus) {
					invalid.focus();
				}
				return;
			}
			if (!this.searchDefinition._meetsMinimumCriteria()) {
				var msg = this.messages.search_insufficient_input || "Specify search criteria.";
				new MessageDialog({
					text: msg
				}).show();
				return;
			}

			var sendEmail = this._isSendEmailEnabled();
			var sendEmailTo = [];
			var sendEmailCc = [];
			if (sendEmail) {
				sendEmailTo = dialogHelper.parseSemicolonEmails(this.sendEmailToField.get("value"));
				var invalidTo = dialogHelper.findInvalidEmail(sendEmailTo);
				if (invalidTo) {
					new MessageDialog({
						text: dialogHelper.buildInvalidEmailMessage(invalidTo)
					}).show();
					return;
				}
				sendEmailCc = dialogHelper.parseSemicolonEmails(this.sendEmailCcField.get("value"));
				var invalidCc = dialogHelper.findInvalidEmail(sendEmailCc);
				if (invalidCc) {
					new MessageDialog({
						text: dialogHelper.buildInvalidEmailMessage(invalidCc)
					}).show();
					return;
				}
			}

			var searchTemplate = this.searchDefinition._prepareSearchTemplateForExecution();
			var reportName = this.reportNameField.get("value");
			var extras = null;
			if (this.editMode) {
				var existing = (this.details && this.details.reportRequest) || {};
				extras = {
					documentId: this.documentId,
					reportRequestId: existing.reportRequestId,
					submittedBy: existing.submittedBy,
					submittedOn: existing.submittedOn
				};
			}
			var payload = dialogHelper.buildPayload(this.repository, reportName, sendEmail, sendEmailTo, sendEmailCc,
				searchTemplate, extras);

			var self = this;
			var onSuccess = function(res) {
				if (self._submitMessageDialog) {
					self._submitMessageDialog.destroyRecursive();
				}
				self._submitMessageDialog = new MessageDialog({
					text: res.message || (self.editMode
						? "Report request updated successfully."
						: "Report request submitted successfully.")
				});
				self._submitMessageDialog.show();
				if (lang.isFunction(self.onSubmitted)) {
					self.onSubmitted(res);
				}
				self.hide();
			};
			var onError = function(res) {
				var msg = self.editMode ? "Update failed." : "Request failed.";
				if (res) {
					if (res.message) {
						msg = res.message;
					} else if (res.errors && res.errors.length) {
						msg = res.errors[0].text || msg;
					}
				}
				new MessageDialog({
					text: msg
				}).show();
			};

			if (this.editMode) {
				reportService.updateReportRequest(this.repository.id, payload, onSuccess, onError);
			} else {
				reportService.submitReportRequest(this.repository.id, payload, onSuccess, onError);
			}
		},

		onSubmitted: function(response) {
		}
	});
});




.CNBReportsPluginLaunchIcon {
	width: 32px;
	height: 32px;
	background: url('images/AdminDashboardFeatureIcon.svg') no-repeat;
	background-position: -16px -16px;
}

.cnbReportsFeatureRoot,
.cnbReportsFeatureMainPane {
	width: 100%;
	height: 100%;
	box-sizing: border-box;
}

.cnbReportsTopPane {
	padding: 8px 12px !important;
}

.cnbReportsHeaderBar {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 12px;
}

.cnbReportsHeaderTitle {
	margin: 0;
	font-size: 1.25rem;
	font-weight: 600;
	line-height: 1.2;
}

.cnbReportsHeaderActions {
	display: flex;
	align-items: center;
	gap: 8px;
	flex-shrink: 0;
}

.cnbReportsRepoRow {
	display: flex;
	align-items: center;
	margin-top: 8px;
}

.cnbReportsRepoLabel {
	margin-right: 6px;
}

.cnbReportsGridPane {
	display: flex;
	flex-direction: column;
	padding: 0 8px 8px 8px !important;
}

.cnbReportsGridHost .ecmContentList .ecmDocInfoPane,
.cnbReportsGridHost .ecmContentList .dijitBorderContainerPane.ecmDocInfoPane {
	display: none !important;
}

.cnbReportsGridHost {
	flex: 1 1 auto;
	width: 100%;
	min-height: 200px;
	padding: 0 !important;
}

.cnbReportsGridHost .ecmContentList .topContainer {
	display: none !important;
}

.cnbReportsGridHost .ecmContentList .gridx .gridxHeaderRow .gridxCell,
.cnbReportsGridHost .ecmContentList .gridxAlternatingRows .gridxBody .gridxRow .gridxCell {
	padding-left: 3px !important;
	padding-right: 3px !important;
}

.cnbReportsGridHost .ecmContentList .gridx .gridxHeaderRow .gridxCell .gridxSortNode {
	padding-left: 3px;
	padding-right: 3px;
}

.cnbReportDownloadIcon {
	cursor: pointer;
	vertical-align: middle;
}

.cnbReportDownloadIcon:focus {
	outline: 1px dotted #333;
}

.cnbReportsGridHint {
	font-size: 0.9em;
	color: #555;
	margin: 4px 0 0 0;
}

.cnbReportDetailsJson {
	max-height: 360px;
	overflow: auto;
	font-family: monospace;
	font-size: 12px;
	white-space: pre-wrap;
}

.cnbReportRequestDialog .propertyRow {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: 8px 12px;
	margin-bottom: 12px;
}

.cnbReportRequestDialog .cnbSendEmailRadioGroup {
	display: flex;
	align-items: center;
	gap: 16px;
	flex: 1 1 480px;
	min-width: 420px;
}

.cnbReportRequestDialog .cnbSendEmailRadioOption {
	display: inline-flex;
	align-items: center;
	gap: 4px;
	white-space: nowrap;
}

.cnbReportRequestDialog .cnbSendEmailRadioOption label {
	margin: 0;
}

.cnbReportRequestDialog .propertyRow label {
	flex: 0 0 auto;
	white-space: nowrap;
}

.cnbReportRequestDialog .propertyRow > .dijit,
.cnbReportRequestDialog .propertyRow > div {
	flex: 1 1 480px;
	min-width: 420px;
	max-width: 100%;
}

.cnbReportRequestDialog .propertyRow .dijitTextBox,
.cnbReportRequestDialog .propertyRow .dijitValidationTextBox {
	width: 100%;
}

.cnbReportRequestDialog .ecmBasicSearchBuilder .buttonArea {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: 6px 10px;
}

/* Hide bottom search-builder actions; Add Property + Results Display stay visible via JS */
.cnbReportRequestDialog .ecmBasicSearchBuilder .buttonArea .dijitButton,
.cnbReportRequestDialog .ecmBasicSearchBuilder .buttonArea .ecmKeepSearchCriteriaExpandedCheckBox,
.cnbReportRequestDialog .ecmBasicSearchBuilder .buttonArea .ecmDisplayAllPropertiesCheckBox {
	display: none !important;
}

.cnbReportRequestDialog .ecmBasicSearchBuilder .buttonArea .cnbShowResultsDisplay {
	display: inline-block !important;
	visibility: visible !important;
}

.cnbReportRequestDialog .ecmBasicSearchBuilder .propertyOptions {
	display: block;
	min-height: 28px;
}

.cnbReportRequestDialog .ecmBasicSearchBuilder .propertyOptions .cnbShowAddProperty {
	display: inline-block !important;
	visibility: visible !important;
}

/* ICN 2.0.3 / 3.2: hide text-search UI ("Find items with the following terms", combination/terms) */
.cnbReportRequestDialog .ecmBasicSearchBuilder .textSearch,
.cnbReportRequestDialog .ecmBasicSearchBuilder .textSearchCriteria {
	display: none !important;
}

/* Keep Add Property; hide Add Group (JS also hides _addGroupButton) */
.cnbReportRequestDialog .ecmBasicSearchBuilder .propertyOptions .dijitButton:not(.cnbShowAddProperty) {
	display: none !important;
}

.cnbReportDetailsSection {
	margin-top: 12px;
}

.cnbReportsGridHost .gridx .cnbReportStatusCell .cnbReportStatus,
.cnbReportsGridHost .gridx .gridxCell .cnbReportStatus {
	font-weight: bold !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusCompleted {
	color: #228B22 !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusInprogress {
	color: #D4A017 !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusPending {
	color: #FF8C00 !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusCancelled {
	color: #000000 !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusHold {
	color: #0000CD !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusFailed {
	color: #CC0000 !important;
}

.cnbReportsGridHost .gridx .cnbReportStatus.cnbReportStatusDefault {
	color: #333333 !important;
}
