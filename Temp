			}
			if (!repo.connected) {
				this.own(this.connect(repo, "onConnected", lang.hitch(this, function() {
					this.refreshGrid();
				})));
				return;
			}
			this._contentList.setGridExtensionModules(this.getContentListGridModules());
			this._contentList.setContentListModules(this.getContentListModules());

			var self = this;
			reportService.listReportRequests(repo.id, function(response) {
				response.repository = repo;
				var resultSet = new ResultSet(response);
				self._contentList.setResultSet(resultSet);
			}, function(response) {
				var msg = "Unable to load report requests.";
				if (response && response.message) {
					msg = response.message;
				} else if (response && response.errors && response.errors.length) {
					msg = response.errors[0].text || msg;
				}
				new MessageDialog({
					text: msg
				}).show();
				self._contentList.reset();
			});
		},

		_onCreateClicked: function() {
			var repo = this.getSelectedRepository();
			if (!repo) {
				new MessageDialog({
					text: "Select a FileNet repository."
				}).show();
				return;
			}
			var dlg = new ReportRequestDialog({
				repository: repo,
				style: "width: 90%; height: 90%;"
			});
			dlg.onSubmitted = lang.hitch(this, function() {
				this.refreshGrid();
			});
			dlg.show();
		},

		_onViewReport: function(summary) {
			var repo = this.getSelectedRepository();
			if (!repo || !summary || !summary.documentId) {
				return;
			}
			var self = this;
			reportService.getReportRequestDetails(repo.id, summary.documentId, null, function(res) {
				if (!self._detailsDialog) {
					self._detailsDialog = new ReportRequestDetailsDialog({
						style: "width: 720px; height: 520px;"
					});
				}
				self._detailsDialog.setDetails(res.details || {});
				self._detailsDialog.show();
			}, function(res) {
				var msg = "Unable to load details.";
				if (res && res.message) {
					msg = res.message;
				}
				new MessageDialog({
					text: msg
				}).show();
			});
		}
	});
});




define([
	"dojo/_base/lang"
], function(lang) {

	var STATUS_FIELD = "Status";

	var STATUS_STYLE_MAP = {
		"completed": "cnbReportStatusCompleted",
		"inprogress": "cnbReportStatusInprogress",
		"pending": "cnbReportStatusPending",
		"cancelled": "cnbReportStatusCancelled",
		"canceled": "cnbReportStatusCancelled",
		"hold": "cnbReportStatusHold",
		"failed": "cnbReportStatusFailed"
	};

	function normalizeStatus(value) {
		if (value == null) {
			return "";
		}
		if (typeof value === "object") {
			if (value.displayName !== undefined && value.displayName !== null) {
				return String(value.displayName).trim();
			}
			if (value.value !== undefined && value.value !== null) {
				return String(value.value).trim();
			}
		}
		return String(value).trim();
	}

	function statusLookupKey(statusText) {
		return statusText.toLowerCase().replace(/[\s_-]+/g, "");
	}

	function resolveStatusClass(statusText) {
		return STATUS_STYLE_MAP[statusLookupKey(statusText)] || "cnbReportStatusDefault";
	}

	function escapeHtml(text) {
		return String(text)
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;");
	}

	function resolveContentList(context) {
		if (!context) {
			return null;
		}
		if (context.grid && context.setResultSet) {
			return context;
		}
		if (context.contentList) {
			return context.contentList;
		}
		return context;
	}

	/**
	 * Grid cell decorator for the Status column. Applies bold, status-specific colors.
	 */
	var ReportStatusDecorator = {
		STATUS_FIELD: STATUS_FIELD,

		/**
		 * Invoked with {@code this} = {@code ecm.widget.listView.ContentList} or grid module.
		 */
		decorateCell: function(data, rowId, rowIndex) {
			var contentList = resolveContentList(this);
			var statusText = ReportStatusDecorator.resolveStatusText(contentList, data, rowId);
			if (!statusText) {
				return "&nbsp;";
			}
			var cssClass = resolveStatusClass(statusText);
			return "<span class=\"cnbReportStatus " + cssClass + "\">"
				+ escapeHtml(statusText) + "</span>";
		},

		resolveStatusText: function(contentList, data, rowId) {
			var statusText = normalizeStatus(data);
			if (statusText) {
				return statusText;
			}
			if (!contentList || !contentList.grid || !rowId) {
				return "";
			}
			try {
				var item = contentList.grid.row(rowId).item();
				if (!item) {
					return "";
				}
				var status = item.attributes ? item.attributes[STATUS_FIELD] : null;
				if (status == null && item.getValue) {
					status = item.getValue(STATUS_FIELD);
				}
				if (status == null && item.getDisplayValue) {
					status = item.getDisplayValue(STATUS_FIELD);
				}
				return normalizeStatus(status);
			} catch (e) {
				return "";
			}
		},

		/**
		 * Returns a grid column decorator function bound for ICN {@code ContentList}.
		 */
		getDecorator: function() {
			return function(data, rowId, rowIndex) {
				return ReportStatusDecorator.decorateCell.call(this, data, rowId, rowIndex);
			};
		}
	};

	lang.setObject("cNBReportsPluginDojo.ReportStatusDecorator", ReportStatusDecorator);

	return ReportStatusDecorator;
});




