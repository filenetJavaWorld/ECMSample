define([
	"dojo/_base/declare",
	"dojo/_base/lang",
	"dojo/_base/event",
	"dojo/dom-class",
	"gridx/core/_Module",
	"ecm/model/Desktop",
	"./ReportDownloadDecorator"
], function(declare, lang, event, domClass, _Module, Desktop, ReportDownloadDecorator) {

	/**
	 * Handles clicks on the report download icon and delegates to {@code CommonActionsHandler.actionDownloadAll}.
	 */
	return declare(_Module, {
		name: "reportRequestDownload",

		preload: function() {
			this.inherited(arguments);
			this.connect(this.grid, "onCellClick", lang.hitch(this, "_onCellClick"));
		},

		_onCellClick: function(evt) {
			var column = this._getColumnDef(evt.columnId);
			if (!column || column.field !== ReportDownloadDecorator.DOWNLOAD_FIELD) {
				return;
			}
			var target = evt.target;
			if (!this._isDownloadIconClick(target)) {
				return;
			}
			event.stop(evt);
			var cl = this.grid.contentList;
			if (!ReportDownloadDecorator.shouldShowDownload(cl, this._getCellData(evt), evt.rowId)) {
				return;
			}
			var item = this.grid.row(evt.rowId).item();
			if (!item || !item.repository) {
				return;
			}
			this._downloadReport(item);
		},

		_isDownloadIconClick: function(node) {
			while (node && node !== this.grid.domNode) {
				if (node.nodeType === 1 && (domClass.contains(node, "cnbReportDownloadIcon")
						|| domClass.contains(node, "ecmDownloadIcon"))) {
					return true;
				}
				node = node.parentNode;
			}
			return false;
		},

		_getCellData: function(evt) {
			try {
				var cell = this.grid.cell(evt.rowId, evt.columnId);
				return cell ? cell.data() : null;
			} catch (e) {
				return null;
			}
		},

		_getColumnDef: function(columnId) {
			var columns = this.grid._columns;
			if (!columns) {
				return null;
			}
			for (var i = 0; i < columns.length; i++) {
				if (columns[i].id === columnId) {
					return columns[i];
				}
			}
			return null;
		},

		_downloadReport: function(item) {
			var resultSet = this.grid.contentList ? this.grid.contentList.getResultSet() : null;
			Desktop.getActionsHandler(lang.hitch(this, function(actionsHandler) {
				// Download all content elements (JSON request + generated Excel report).
				actionsHandler.actionDownloadAll(item.repository, [item], null, null, resultSet, null, null, "current");
			}));
		}
	});
});
