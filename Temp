		EMAIL_SEPARATOR: EMAIL_SEPARATOR,
		parseSemicolonEmails: parseSemicolonEmails,
		formatEmailsForField: formatEmailsForField,
		resolveSendEmailsFromPayload: resolveSendEmailsFromPayload,
		isValidEmailAddress: isValidEmailAddress,
