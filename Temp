					msg = response.message;
				} else if (response && response.errors && response.errors.length) {
					msg = response.errors[0].text || msg;
				}
				new MessageDialog({
					text: msg
				}).show();
				self._contentList.reset();
			});
		},

		_onCreateClicked: function() {
			var repo = this.getSelectedRepository();
			if (!repo) {
				new MessageDialog({
					text: "Select a FileNet repository."
				}).show();
				return;
			}
			var dlg = new ReportRequestDialog({
				repository: repo,
				style: "width: 90%; height: 90%;"
			});
			dlg.onSubmitted = lang.hitch(this, function() {
				this.refreshGrid();
			});
			dlg.show();
		},

		_onViewReport: function(summary) {
			var repo = this.getSelectedRepository();
			if (!repo || !summary || !summary.documentId) {
				return;
			}
			var self = this;
			reportService.getReportRequestDetails(repo.id, summary.documentId, null, function(res) {
				if (!self._detailsDialog) {
					self._detailsDialog = new ReportRequestDetailsDialog({
						style: "width: 720px; height: 520px;"
					});
				}
				self._detailsDialog.setDetails(res.details || {});
				self._detailsDialog.show();
			}, function(res) {
				var msg = "Unable to load details.";
				if (res && res.message) {
					msg = res.message;
				}
				new MessageDialog({
					text: msg
				}).show();
			});
		}
	});
});
