define([
	"dojo/_base/declare",
	"dojo/json",
	"dijit/_TemplatedMixin",
	"dijit/_WidgetsInTemplateMixin",
	"ecm/widget/admin/PluginConfigurationPane",
	"dojo/text!./templates/ConfigurationPane.html"
], function(
	declare,
	dojoJson,
	_TemplatedMixin,
	_WidgetsInTemplateMixin,
	PluginConfigurationPane,
	template
) {

	return declare("searchPluginDojo.ConfigurationPane", [
		PluginConfigurationPane,
		_TemplatedMixin,
		_WidgetsInTemplateMixin
	], {

		templateString: template,
		widgetsInTemplate: true,

		load: function(callback) {

			if (this.configurationString) {

				try {

					var jsonConfig = dojoJson.parse(this.configurationString);

					this.edsLookupConfigurationField.value =
						jsonConfig.edsLookupConfiguration || "";

				} catch (e) {

					this.logError(
						"load",
						"Failed to load configuration: " + e.message
					);
				}
			}

			if (callback) {
				callback();
			}
		},

		_onParamChange: function() {

			var configJson = {

				edsLookupConfiguration:
					this.edsLookupConfigurationField.value
			};

			this.configurationString =
				JSON.stringify(configJson);

			this.onSaveNeeded(true);
		},

		validate: function() {

			try {

				JSON.parse(
					this.edsLookupConfigurationField.value || "{}"
				);

			} catch (e) {

				alert("Invalid JSON configuration.");

				return false;
			}

			return true;
		}
	});
});




