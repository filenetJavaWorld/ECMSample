package com.cnb.reports;

import com.cnb.reports.email.EmailValidator;
import com.cnb.reports.model.PropertyCardinality;
import com.cnb.reports.model.ReportRequestPayload;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.model.SearchCriterion;
import com.cnb.reports.model.SortOption;
import com.cnb.reports.util.CePropertyNameResolver;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.apache.commons.lang3.StringUtils;

import java.util.ArrayList;
import java.util.List;

/**
 * Parses ReportRequest JSON payloads and metadata fallbacks into a normalized model.
 */
public final class ReportRequestPayloadParser {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    public ReportRequestPayload parse(String jsonText, ReportRequestSummary summary) throws Exception {
        ReportRequestPayload payload = new ReportRequestPayload();
        if (summary != null) {
            payload.setReportName(summary.getDocumentTitle());
            payload.setTargetClassSymbolicName(summary.getTargetDocumentClass());
            payload.setRepositoryName(summary.getRepositoryName());
            payload.setRepositoryId(summary.getRepositoryId());
            payload.setSqlQuery(StringUtils.trimToNull(summary.getSqlQuery()));
            payload.setResultColumns(mapResultColumnsFromMetadata(summary.getResultSetColumns()));
            payload.setCriteria(mapCriteriaFromMetadata(summary.getSearchCriteriaParams()));
            payload.setSendEmailTo(summary.getSendEmailTo());
            payload.setSendEmailCC(summary.getSendEmailCC());
        }

        if (StringUtils.isNotBlank(jsonText)) {
            JsonNode root = MAPPER.readTree(jsonText);
            mergeJsonPayload(payload, root);
        }

        if (StringUtils.isBlank(payload.getTargetClassSymbolicName())) {
            throw new IllegalArgumentException("Target document class is missing from payload and metadata.");
        }
        if (payload.getResultColumns().isEmpty()) {
            payload.setResultColumns(defaultResultColumns(payload.getTargetClassSymbolicName()));
        }
        payload.setResultColumns(normalizeResultColumns(payload.getResultColumns()));
        return payload;
    }

    private List<ResultColumn> normalizeResultColumns(List<ResultColumn> columns) {
        List<ResultColumn> normalized = new ArrayList<>();
        for (ResultColumn column : columns) {
            normalized.add(CePropertyNameResolver.toResultColumn(column.getPropertySymbolicName()));
            if (StringUtils.isNotBlank(column.getPropertyDisplayName())
                    && !column.getPropertyDisplayName().equals(column.getPropertySymbolicName())) {
                normalized.set(normalized.size() - 1,
                        new ResultColumn(normalized.get(normalized.size() - 1).getPropertySymbolicName(),
                                column.getPropertyDisplayName()));
            }
        }
        return normalized;
    }

    private void mergeJsonPayload(ReportRequestPayload payload, JsonNode root) {
        if (root == null || root.isNull()) {
            return;
        }

        setIfPresent(payload::setReportName, firstNonBlank(text(root, "reportName"), text(root, "name")));
        setIfPresent(payload::setReportRequestId, text(root, "reportRequestId"));
        setIfPresent(payload::setTargetClassSymbolicName,
                firstNonBlank(text(root, "targetClassSymbolicName"), text(root, "template_name"), text(root, "className")));
        setIfPresent(payload::setRepositoryName, text(root, "repositoryName"));
        setIfPresent(payload::setRepositoryId, text(root, "repositoryId"));
        setIfPresent(payload::setObjectStoreName,
                firstNonBlank(text(root, "objectStoreName"), text(root, "objectStoreId")));
        setIfPresent(payload::setSubmittedOn, text(root, "submittedOn"));
        setIfPresent(payload::setSqlQuery, text(root, "sqlQuery"));
        setIfPresent(payload::setSearchScope, text(root, "searchScope"));
        setIfPresent(payload::setVersionOption, text(root, "versionOption"));
        setIfPresent(payload::setFolderId, firstNonBlank(
                text(root, "folderId"),
                text(root, "selectedFolderId"),
                text(root, "searchFolderId"),
                text(root, "folderGUID"),
                text(root, "folderGuid")));
        setIfPresent(payload::setFolderPath, firstNonBlank(
                text(root, "folderPath"),
                text(root, "selectedFolderPath"),
                text(root, "searchFolderPath"),
                text(root, "folderName")));

        if (root.has("includeSubclasses")) {
            payload.setIncludeSubclasses(root.path("includeSubclasses").asBoolean(false));
        } else if (root.has("searchSubclasses")) {
            payload.setIncludeSubclasses(root.path("searchSubclasses").asBoolean(false));
        }

        if (root.has("searchSubfolders")) {
            payload.setSearchSubfolders(root.path("searchSubfolders").asBoolean(false));
        } else if (root.has("includeSubfolders")) {
            payload.setSearchSubfolders(root.path("includeSubfolders").asBoolean(false));
        }

        JsonNode moreOptions = root.path("moreOptions");
        if (!moreOptions.isMissingNode() && moreOptions.has("versionOption")) {
            payload.setVersionOption(moreOptions.path("versionOption").asText(null));
        }
        if (!moreOptions.isMissingNode()) {
            setIfPresent(payload::setFolderId, firstNonBlank(payload.getFolderId(),
                    text(moreOptions, "folderId"), text(moreOptions, "selectedFolderId")));
            setIfPresent(payload::setFolderPath, firstNonBlank(payload.getFolderPath(),
                    text(moreOptions, "folderPath"), text(moreOptions, "selectedFolderPath")));
            if (moreOptions.has("searchSubfolders")) {
                payload.setSearchSubfolders(moreOptions.path("searchSubfolders").asBoolean(payload.isSearchSubfolders()));
            }
        }

        if (root.has("criteria")) {
            payload.setCriteria(parsePluginCriteria(root.path("criteria")));
        } else if (root.has("searchCriteria")) {
            payload.setCriteria(parseIcnCriteria(root.path("searchCriteria")));
        }

        if (root.has("resultDisplay")) {
            payload.setResultColumns(parsePluginResultColumns(root.path("resultDisplay")));
            payload.setSortOptions(parsePluginSort(root.path("resultDisplay")));
        } else if (root.has("resultsDisplay")) {
            payload.setResultColumns(parseIcnResultColumns(root.path("resultsDisplay")));
            payload.setSortOptions(parseIcnSort(root.path("resultsDisplay")));
        }

        payload.setSendEmailTo(readEmailArray(root.get("sendEmailTo")));
        payload.setSendEmailCC(readEmailArray(root.get("sendEmailCC")));
        if (payload.getSendEmailCC().isEmpty()) {
            payload.setSendEmailCC(readEmailArray(root.get("sendEmailCc")));
        }
    }

    private List<String> readEmailArray(com.fasterxml.jackson.databind.JsonNode node) {
        if (node == null || !node.isArray()) {
            return List.of();
        }
        List<String> emails = new ArrayList<>();
        for (com.fasterxml.jackson.databind.JsonNode value : node) {
            if (value != null && !value.isNull()) {
                emails.add(value.asText());
            }
        }
        return EmailValidator.normalizeList(emails);
    }

    private List<SearchCriterion> parsePluginCriteria(JsonNode criteriaNode) {
        List<SearchCriterion> criteria = new ArrayList<>();
        if (!criteriaNode.isArray()) {
            return criteria;
        }
        for (JsonNode node : criteriaNode) {
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(text(node, "propertySymbolicName"));
            criterion.setPropertyDisplayName(text(node, "propertyDisplayName"));
            criterion.setOperator(text(node, "operator"));
            criterion.setDataType(text(node, "dataType"));
            criterion.setCardinality(readCardinality(node));
            criterion.setValues(readValues(node.path("values")));
            if (StringUtils.isNotBlank(criterion.getPropertySymbolicName())
                    && StringUtils.isNotBlank(criterion.getOperator())) {
                criteria.add(criterion);
            }
        }
        return criteria;
    }

    private List<SearchCriterion> parseIcnCriteria(JsonNode criteriaNode) {
        List<SearchCriterion> criteria = new ArrayList<>();
        if (!criteriaNode.isArray()) {
            return criteria;
        }
        for (JsonNode node : criteriaNode) {
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(text(node, "id"));
            criterion.setPropertyDisplayName(firstNonBlank(text(node, "name"), text(node, "label")));
            criterion.setOperator(text(node, "selectedOperator"));
            criterion.setDataType(text(node, "dataType"));
            criterion.setCardinality(readCardinality(node));
            criterion.setValues(readValues(node.path("values")));
            if (StringUtils.isNotBlank(criterion.getPropertySymbolicName())
                    && StringUtils.isNotBlank(criterion.getOperator())) {
                criteria.add(criterion);
            }
        }
        return criteria;
    }

    private PropertyCardinality readCardinality(JsonNode node) {
        if (node == null || node.isMissingNode() || node.isNull()) {
            return PropertyCardinality.UNKNOWN;
        }
        if (node.has("multiValued")) {
            return node.path("multiValued").asBoolean(false) ? PropertyCardinality.LIST : PropertyCardinality.SINGLE;
        }
        if (node.has("isList")) {
            return node.path("isList").asBoolean(false) ? PropertyCardinality.LIST : PropertyCardinality.SINGLE;
        }
        if (node.has("list")) {
            return node.path("list").asBoolean(false) ? PropertyCardinality.LIST : PropertyCardinality.SINGLE;
        }
        return PropertyCardinality.fromRaw(firstNonBlank(
                text(node, "cardinality"),
                text(node, "cardinalityName"),
                text(node, "propertyCardinality")));
    }

    private List<ResultColumn> parsePluginResultColumns(JsonNode resultDisplay) {
        List<ResultColumn> columns = new ArrayList<>();
        JsonNode cols = resultDisplay.path("columns");
        if (!cols.isArray()) {
            return columns;
        }
        for (JsonNode col : cols) {
            if (col.isObject()) {
                columns.add(CePropertyNameResolver.toResultColumn(
                        firstNonBlank(text(col, "propertySymbolicName"), text(col, "propertyDisplayName"))));
            } else {
                String symbolic = col.asText(null);
                if (StringUtils.isNotBlank(symbolic)) {
                    columns.add(CePropertyNameResolver.toResultColumn(symbolic));
                }
            }
        }
        return columns;
    }

    private List<ResultColumn> parseIcnResultColumns(JsonNode resultsDisplay) {
        List<ResultColumn> columns = new ArrayList<>();
        JsonNode cols = resultsDisplay.path("columns");
        if (!cols.isArray()) {
            return columns;
        }
        for (JsonNode col : cols) {
            String symbolic = col.asText(null);
            if (StringUtils.isNotBlank(symbolic)) {
                columns.add(CePropertyNameResolver.toResultColumn(symbolic));
            }
        }
        return columns;
    }

    private List<SortOption> parsePluginSort(JsonNode resultDisplay) {
        List<SortOption> sortOptions = new ArrayList<>();
        JsonNode sort = resultDisplay.path("sort");
        if (!sort.isArray()) {
            return sortOptions;
        }
        for (JsonNode node : sort) {
            sortOptions.add(new SortOption(text(node, "propertySymbolicName"), text(node, "direction")));
        }
        return sortOptions;
    }

    private List<SortOption> parseIcnSort(JsonNode resultsDisplay) {
        List<SortOption> sortOptions = new ArrayList<>();
        String sortBy = text(resultsDisplay, "sortBy");
        if (StringUtils.isNotBlank(sortBy)) {
            String direction = resultsDisplay.path("sortAsc").asBoolean(true) ? "ASC" : "DESC";
            sortOptions.add(new SortOption(sortBy, direction));
        }
        return sortOptions;
    }

    private List<SearchCriterion> mapCriteriaFromMetadata(List<String> encodedCriteria) {
        List<SearchCriterion> criteria = new ArrayList<>();
        for (String entry : encodedCriteria) {
            String[] parts = entry.split("\\|", 3);
            if (parts.length < 2) {
                continue;
            }
            SearchCriterion criterion = new SearchCriterion();
            criterion.setPropertySymbolicName(parts[0].trim());
            criterion.setOperator(parts[1].trim());
            if (parts.length == 3 && StringUtils.isNotBlank(parts[2])) {
                List<String> values = new ArrayList<>();
                for (String value : parts[2].split(",")) {
                    if (StringUtils.isNotBlank(value)) {
                        values.add(value.trim());
                    }
                }
                criterion.setValues(values);
            }
            criteria.add(criterion);
        }
        return criteria;
    }

    private List<ResultColumn> mapResultColumnsFromMetadata(List<String> columns) {
        List<ResultColumn> result = new ArrayList<>();
        for (String column : columns) {
            if (StringUtils.isNotBlank(column)) {
                result.add(CePropertyNameResolver.toResultColumn(column.trim()));
            }
        }
        return result;
    }

    private List<ResultColumn> defaultResultColumns(String targetClass) {
        List<ResultColumn> columns = new ArrayList<>();
        columns.add(new ResultColumn("Id", "Id"));
        columns.add(new ResultColumn("DocumentTitle", "DocumentTitle"));
        columns.add(new ResultColumn(targetClass, targetClass));
        return columns;
    }

    private List<String> readValues(JsonNode valuesNode) {
        List<String> values = new ArrayList<>();
        if (!valuesNode.isArray()) {
            return values;
        }
        for (JsonNode valueNode : valuesNode) {
            if (valueNode == null || valueNode.isNull()) {
                continue;
            }
            if (valueNode.isObject() && valueNode.has("value")) {
                addIfPresent(values, valueNode.path("value").asText(null));
            } else {
                addIfPresent(values, valueNode.asText(null));
            }
        }
        return values;
    }

    private void addIfPresent(List<String> values, String value) {
        if (StringUtils.isNotBlank(value)) {
            values.add(value.trim());
        }
    }

    private String text(JsonNode node, String field) {
        if (node == null || node.isMissingNode() || node.isNull()) {
            return null;
        }
        JsonNode value = node.get(field);
        if (value == null || value.isNull()) {
            return null;
        }
        String text = value.asText(null);
        return StringUtils.isBlank(text) ? null : text.trim();
    }

    private String firstNonBlank(String... values) {
        for (String value : values) {
            if (StringUtils.isNotBlank(value)) {
                return value.trim();
            }
        }
        return null;
    }

    private void setIfPresent(java.util.function.Consumer<String> setter, String value) {
        if (StringUtils.isNotBlank(value)) {
            setter.accept(value.trim());
        }
    }
}



