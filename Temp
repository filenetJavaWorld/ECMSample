define([
	"dojo/_base/declare",
	"dojo/_base/lang",
	"ecm/model/Action"
], function(declare, lang, Action) {

	function resolveItemStatus(item) {
		if (!item) {
			return "";
		}
		var status = null;
		if (lang.isFunction(item.getValue)) {
			status = item.getValue("Status");
		}
		if ((status == null || status === "") && item.attributes) {
			status = item.attributes.Status;
		}
		if ((status == null || status === "") && lang.isFunction(item.getDisplayValue)) {
			status = item.getDisplayValue("Status");
		}
		return status != null ? String(status).trim() : "";
	}

	function isPendingStatus(status) {
		return status != null && String(status).toLowerCase() === "pending";
	}

	/**
	 * Enables Edit Report Request only when exactly one Pending report request is selected.
	 */
	return declare("cNBReportsPluginDojo.EditReportRequestAction", [
		Action
	], {
		isEnabled: function(repository, listType, items, teamspace, resultSet) {
			var enabled = this.inherited(arguments);
			if (!enabled) {
				return false;
			}
			if (!items || items.length !== 1 || !items[0]) {
				return false;
			}
			return isPendingStatus(resolveItemStatus(items[0]));
		}
	});
});





