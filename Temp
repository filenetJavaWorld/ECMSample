    padding: 0 !important;
    margin: 0 !important;
}

.cNBMultiRepoSearchPluginDojo_MultiRepoSearchFeature .ecmCenterPane,
.cNBMultiRepoSearchPluginDojo_MultiRepoSearchFeature > div {
    padding: 0 !important;
    margin: 0 !important;
