package com.cnb.reports.email;

import com.cnb.reports.config.AppConfig;
import org.apache.commons.lang3.StringUtils;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;

public final class BookmarkUrlBuilder {

    private static final Logger LOGGER = LogManager.getLogger(BookmarkUrlBuilder.class);

    private BookmarkUrlBuilder() {
    }

    public static String build(AppConfig config, String repositoryId, String documentId) {
        if (StringUtils.isAnyBlank(config.getIcnBaseUrl(), config.getIcnDesktopId(), repositoryId, documentId)) {
            LOGGER.warn("Bookmark URL not generated. icn.base.url, icn.desktop.id, repositoryId, and documentId are required.");
            return null;
        }
        try {
            String base = trimTrailingSlash(config.getIcnBaseUrl());
            return base + "/bookmark.jsp?desktop="
                    + encode(config.getIcnDesktopId())
                    + "&repositoryId=" + encode(repositoryId)
                    + "&docid=" + encode(documentId);
        } catch (Exception ex) {
            LOGGER.error("Failed to build bookmark URL for document {}", documentId, ex);
            return null;
        }
    }

    private static String trimTrailingSlash(String baseUrl) {
        String value = baseUrl.trim();
        while (value.endsWith("/")) {
            value = value.substring(0, value.length() - 1);
        }
        return value;
    }

    private static String encode(String value) {
        return URLEncoder.encode(value, StandardCharsets.UTF_8);
    }
}


