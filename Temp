package com.filenet.loadtest.config;

import java.io.FileInputStream;
import java.io.IOException;
import java.io.InputStream;
import java.util.Properties;

/**
 * Loads application configuration from a properties file.
 */
public final class ConfigLoader {

    private static final String DEFAULT_CONFIG = "config.properties";

    private ConfigLoader() {
    }

    /**
     * Loads configuration from the default config.properties file in the working directory.
     *
     * @return application configuration
     * @throws IOException if the file cannot be read
     */
    public static AppConfig load() throws IOException {
        return load(DEFAULT_CONFIG);
    }

    /**
     * Loads configuration from the specified properties file path.
     *
     * @param configFilePath path to config.properties
     * @return application configuration
     * @throws IOException if the file cannot be read
     */
    public static AppConfig load(String configFilePath) throws IOException {
        Properties props = new Properties();
        try (InputStream input = new FileInputStream(configFilePath)) {
            props.load(input);
        }

        return new AppConfig(
                trimTrailingSlash(require(props, "ce.uri")),
                require(props, "ce.username"),
                require(props, "ce.password"),
                require(props, "ce.objectStore"),
                parseInt(props, "thread.count", 5),
                require(props, "sample.content.file"),
                require(props, "sample.mimeType"),
                require(props, "output.metrics.file"),
                require(props, "class.config.file"),
                parseBoolean(props, "search.enabled", false),
                parseInt(props, "search.thread.count", 5),
                parseInt(props, "search.iterations", 10),
                props.getProperty("search.config.file", "search-config.csv"),
                props.getProperty("search.output.metrics.file", "search-test-results.csv")
        );
    }

    private static String require(Properties props, String key) {
        String value = props.getProperty(key);
        if (value == null || value.trim().isEmpty()) {
            throw new IllegalArgumentException("Missing required configuration property: " + key);
        }
        return value.trim();
    }

    private static int parseInt(Properties props, String key, int defaultValue) {
        String value = props.getProperty(key);
        if (value == null || value.trim().isEmpty()) {
            return defaultValue;
        }
        return Integer.parseInt(value.trim());
    }

    private static boolean parseBoolean(Properties props, String key, boolean defaultValue) {
        String value = props.getProperty(key);
        if (value == null || value.trim().isEmpty()) {
            return defaultValue;
        }
        return Boolean.parseBoolean(value.trim());
    }

    private static String trimTrailingSlash(String uri) {
        if (uri == null) {
            return null;
        }
        while (uri.endsWith("/")) {
            uri = uri.substring(0, uri.length() - 1);
        }
        return uri;
    }
}



package com.filenet.loadtest.connection;

import com.filenet.api.core.Connection;
import com.filenet.api.core.Domain;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.UserContext;
import com.filenet.loadtest.config.AppConfig;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import javax.security.auth.Subject;

/**
 * Encapsulates an independent FileNet CE session for a single worker thread.
 * Each instance creates its own Connection, authenticates, and manages UserContext lifecycle.
 */
public class FileNetSession implements AutoCloseable {

    private static final Logger LOG = LogManager.getLogger(FileNetSession.class);

    private final Connection connection;
    private final Subject subject;
    private final Domain domain;
    private final ObjectStore objectStore;
    private final String threadName;

    private FileNetSession(Connection connection, Subject subject, Domain domain,
                           ObjectStore objectStore, String threadName) {
        this.connection = connection;
        this.subject = subject;
        this.domain = domain;
        this.objectStore = objectStore;
        this.threadName = threadName;
    }

    /**
     * Creates a new independent FileNet session for the current thread.
     *
     * @param config application configuration
     * @return new session with UserContext pushed
     * @throws Exception if connection or authentication fails
     */
    public static FileNetSession create(AppConfig config) throws Exception {
        String threadName = Thread.currentThread().getName();
        LOG.debug("[{}] Creating independent FileNet connection to {}", threadName, config.getCeUri());

        Connection connection = Factory.Connection.getConnection(config.getCeUri());

        Subject subject = UserContext.createSubject(
                connection,
                config.getUsername(),
                config.getPassword(),
                null
        );

        if (subject == null) {
            throw new IllegalStateException("FileNet authentication failed: UserContext.createSubject returned null. "
                    + "Check ce.username and ce.password in config.properties.");
        }

        UserContext.get().pushSubject(subject);

        Domain domain = Factory.Domain.fetchInstance(connection, null, null);
        ObjectStore objectStore = Factory.ObjectStore.fetchInstance(
                domain,
                config.getObjectStoreName(),
                null
        );

        LOG.info("[{}] FileNet session established for object store: {}",
                threadName, config.getObjectStoreName());

        return new FileNetSession(connection, subject, domain, objectStore, threadName);
    }

    public Connection getConnection() {
        return connection;
    }

    public Domain getDomain() {
        return domain;
    }

    public ObjectStore getObjectStore() {
        return objectStore;
    }

    public Subject getSubject() {
        return subject;
    }

    /**
     * Pops the UserContext Subject for this thread. Must be called when the session is no longer needed.
     */
    @Override
    public void close() {
        try {
            UserContext.get().popSubject();
            LOG.debug("[{}] FileNet session closed and UserContext popped", threadName);
        } catch (Exception ex) {
            LOG.warn("[{}] Error while closing FileNet session: {}", threadName, ex.getMessage(), ex);
        }
    }
}




package com.filenet.loadtest.csv;

import com.filenet.loadtest.model.ClassConfig;
import com.filenet.loadtest.model.SearchQueryConfig;
import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVParser;
import org.apache.commons.csv.CSVRecord;

import java.io.FileReader;
import java.io.IOException;
import java.io.Reader;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

/**
 * Reads class configuration and document CSV files using Apache Commons CSV.
 */
public final class CsvDataReader {

    private CsvDataReader() {
    }

    /**
     * Reads class-config.csv with columns: ClassSymbolicName, CSVFile.
     *
     * @param filePath path to class-config.csv
     * @return list of class configurations
     * @throws IOException if the file cannot be read
     */
    public static List<ClassConfig> readClassConfig(String filePath) throws IOException {
        List<ClassConfig> configs = new ArrayList<>();

        try (Reader reader = new FileReader(filePath);
             CSVParser parser = CSVFormat.DEFAULT
                     .withFirstRecordAsHeader()
                     .withIgnoreEmptyLines()
                     .withTrim()
                     .parse(reader)) {

            for (CSVRecord record : parser) {
                String className = getRequired(record, "ClassSymbolicName");
                String csvFile = getRequired(record, "CSVFile");
                configs.add(new ClassConfig(className, csvFile));
            }
        }

        return configs;
    }

    /**
     * Reads a document CSV file. Header columns map to FileNet property symbolic names.
     *
     * @param filePath path to document CSV
     * @return list of row maps keyed by column name
     * @throws IOException if the file cannot be read
     */
    public static List<Map<String, String>> readDocumentCsv(String filePath) throws IOException {
        List<Map<String, String>> rows = new ArrayList<>();

        try (Reader reader = new FileReader(filePath);
             CSVParser parser = CSVFormat.DEFAULT
                     .withFirstRecordAsHeader()
                     .withIgnoreEmptyLines()
                     .withTrim()
                     .parse(reader)) {

            Map<String, Integer> headerMap = parser.getHeaderMap();

            for (CSVRecord record : parser) {
                Map<String, String> row = new LinkedHashMap<>();
                for (String header : headerMap.keySet()) {
                    row.put(header, record.isMapped(header) ? record.get(header) : "");
                }
                rows.add(row);
            }
        }

        return rows;
    }

    /**
     * Reads search-config.csv with columns: SearchType, ClassName, PropertyName, SearchValue.
     *
     * @param filePath path to search-config.csv
     * @return list of search query configurations
     * @throws IOException if the file cannot be read
     */
    public static List<SearchQueryConfig> readSearchConfig(String filePath) throws IOException {
        List<SearchQueryConfig> queries = new ArrayList<>();

        try (Reader reader = new FileReader(filePath);
             CSVParser parser = CSVFormat.DEFAULT
                     .withFirstRecordAsHeader()
                     .withIgnoreEmptyLines()
                     .withTrim()
                     .parse(reader)) {

            for (CSVRecord record : parser) {
                String typeStr = getRequired(record, "SearchType");
                SearchQueryConfig.SearchType searchType;
                try {
                    searchType = SearchQueryConfig.SearchType.valueOf(typeStr.trim().toUpperCase());
                } catch (IllegalArgumentException ex) {
                    throw new IOException("Invalid SearchType in search config: " + typeStr, ex);
                }

                String className = getRequired(record, "ClassName");
                String propertyName = record.isMapped("PropertyName") ? record.get("PropertyName") : "";
                String searchValue = record.isMapped("SearchValue") ? record.get("SearchValue") : "";

                queries.add(new SearchQueryConfig(searchType, className, propertyName, searchValue));
            }
        }

        return queries;
    }

    private static String getRequired(CSVRecord record, String column) throws IOException {
        if (!record.isMapped(column)) {
            throw new IOException("Missing required CSV column: " + column);
        }
        String value = record.get(column);
        if (value == null || value.trim().isEmpty()) {
            throw new IOException("Empty value for required column '" + column + "' at record " + record.getRecordNumber());
        }
        return value.trim();
    }
}



