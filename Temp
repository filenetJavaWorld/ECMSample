package com.cnb.updater.model;

public final class SearchResultRecord {

    public static final String STATUS_EXIST = "EXIST";
    public static final String STATUS_DOES_NOT_EXIST = "DOES_NOT_EXIST";
    public static final String STATUS_DOCUMENT_NOT_FOUND = "DOCUMENT_NOT_FOUND";

    public static final String COMMENT_EXIST = "CIS Number Already Exist";
    public static final String COMMENT_DOES_NOT_EXIST = "User Provided CIS Number";
    public static final String COMMENT_DOCUMENT_NOT_FOUND = "No matching documents found";

    private final String accountNumber;
    private final String documentClass;
    private final String documentGuid;
    private final String cis;
    private final String status;
    private String comments;
    private String updateStatus;

    public SearchResultRecord(String accountNumber,
                              String documentClass,
                              String documentGuid,
                              String cis,
                              String status,
                              String comments,
                              String updateStatus) {
        this.accountNumber = accountNumber;
        this.documentClass = documentClass;
        this.documentGuid = documentGuid;
        this.cis = cis;
        this.status = status;
        this.comments = comments;
        this.updateStatus = updateStatus;
    }

    public static SearchResultRecord documentNotFound(String accountNumber) {
        return new SearchResultRecord(
                accountNumber,
                "",
                "",
                "",
                STATUS_DOCUMENT_NOT_FOUND,
                COMMENT_DOCUMENT_NOT_FOUND,
                ""
        );
    }

    public String getAccountNumber() {
        return accountNumber;
    }

    public String getDocumentClass() {
        return documentClass;
    }

    public String getDocumentGuid() {
        return documentGuid;
    }

    public String getCis() {
        return cis;
    }

    public String getStatus() {
        return status;
    }

    public String getComments() {
        return comments;
    }

    public String getUpdateStatus() {
        return updateStatus;
    }

    public void setUpdateStatus(String updateStatus) {
        this.updateStatus = updateStatus;
    }

    public void setComments(String comments) {
        this.comments = comments;
    }

    public void appendComment(String additionalComment) {
        if (additionalComment == null || additionalComment.trim().isEmpty()) {
            return;
        }
        if (comments == null || comments.trim().isEmpty()) {
            comments = additionalComment.trim();
        } else {
            comments = comments + " - " + additionalComment.trim();
        }
    }
}




