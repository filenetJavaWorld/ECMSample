		if (lang.isFunction(searchDefinition.setSearchTemplate)) {
			searchDefinition.setSearchTemplate(template, complete);
		} else {
			searchDefinition._searchTemplate = template;
			complete();
		}
		setTimeout(complete, 2000);
	}

	function populateBasicFieldsFromPayload(dialog, payload, metadata) {
