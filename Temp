.cnb-multi-repo-search-feature {
    width: 100%;
    height: 100%;
    margin: 0 !important;
    padding: 0 !important;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
}

.cnb-multi-repo-search-feature .idxBorderContainer,
.cnb-multi-repo-search-feature .dijitBorderContainer {
    margin: 0 !important;
