package com.cnb.search.filter;

import javax.servlet.http.HttpServletRequest;

import com.ibm.json.java.JSONArray;
import com.ibm.json.java.JSONObject;
import com.ibm.ecm.extension.PluginResponseFilter;
import com.ibm.ecm.extension.PluginServiceCallbacks;

/**
 * Response filter for the P8 ListFavorites service that hides the 'Repository'
 * column from the response. This filter is applied when the Favorites feature
 * retrieves items from a P8 repository.
 */
public class ListFavoritesRepositoryColumnFilter extends PluginResponseFilter {

    private static final String REPOSITORY_COLUMN_FIELD = "Repository";
    private static final String REPOSITORY_COLUMN_FIELD_ALT = "repository";

    @Override
    public String[] getFilteredServices() {
        return new String[] { "/p8/getFavorites" };
    }

    @Override
    public void filter(String serverType, PluginServiceCallbacks callbacks,
            HttpServletRequest request, JSONObject jsonResponse) throws Exception {
        if (jsonResponse == null) {
            return;
        }

        // Only filter for p8 server type
        if (serverType == null || !serverType.contains("p8")) {
            return;
        }

        // Remove Repository column values from rows first (while we can still find the index)
        removeColumnFromRows(jsonResponse);

        // Remove Repository column from columns definition
        removeColumnFromDefinition(jsonResponse);
    }

    /**
     * Removes the Repository column from the columns definition in the response.
     */
    private void removeColumnFromDefinition(JSONObject jsonResponse) {
        try {
            JSONObject columns = (JSONObject) jsonResponse.get("columns");
            if (columns == null) {
                return;
            }

            JSONArray cells = (JSONArray) columns.get("cells");
            if (cells == null || cells.size() == 0) {
                return;
            }

            // cells is typically an array of arrays - each inner array contains column definitions
            for (int i = 0; i < cells.size(); i++) {
                Object cellItem = cells.get(i);
                if (cellItem instanceof JSONArray) {
                    removeRepositoryColumnFromArray((JSONArray) cellItem);
                }
            }
        } catch (Exception e) {
            // Log but don't fail - response will be returned unchanged for that part
            System.err.println("[ListFavoritesRepositoryColumnFilter] Error removing column from definition: " + e.getMessage());
        }
    }

    /**
     * Removes Repository column entries from a column definition array.
     */
    private void removeRepositoryColumnFromArray(JSONArray columnArray) {
        for (int i = columnArray.size() - 1; i >= 0; i--) {
            Object col = columnArray.get(i);
            if (col instanceof JSONObject) {
                JSONObject column = (JSONObject) col;
                String field = (String) column.get("field");
                String name = (String) column.get("name");
                if (isRepositoryColumn(field, name)) {
                    columnArray.remove(i);
                }
            }
        }
    }

    /**
     * Removes the Repository column values from each row in the response.
     */
    private void removeColumnFromRows(JSONObject jsonResponse) {
        try {
            JSONArray rows = (JSONArray) jsonResponse.get("rows");
            if (rows == null || rows.size() == 0) {
                return;
            }

            // Find the Repository column index from the first row's structure
            Integer repoColumnIndex = findRepositoryColumnIndex(jsonResponse);
            if (repoColumnIndex == null) {
                return;
            }

            // Remove the column value from each row
            for (int i = 0; i < rows.size(); i++) {
                Object rowObj = rows.get(i);
                if (rowObj instanceof JSONArray) {
                    JSONArray row = (JSONArray) rowObj;
                    if (repoColumnIndex < row.size()) {
                        row.remove(repoColumnIndex);
                    }
                }
            }
        } catch (Exception e) {
            System.err.println("[ListFavoritesRepositoryColumnFilter] Error removing column from rows: " + e.getMessage());
        }
    }

    /**
     * Finds the index of the Repository column in the column definition.
     * Returns null if not found.
     */
    private Integer findRepositoryColumnIndex(JSONObject jsonResponse) {
        try {
            JSONObject columns = (JSONObject) jsonResponse.get("columns");
            if (columns == null) {
                return null;
            }

            JSONArray cells = (JSONArray) columns.get("cells");
            if (cells == null || cells.size() == 0) {
                return null;
            }

            // Get the first row of column definitions (typically index 0)
            Object cellItem = cells.get(0);
            if (!(cellItem instanceof JSONArray)) {
                return null;
            }

            JSONArray columnDefs = (JSONArray) cellItem;
            for (int i = 0; i < columnDefs.size(); i++) {
                Object col = columnDefs.get(i);
                if (col instanceof JSONObject) {
                    JSONObject column = (JSONObject) col;
                    String field = (String) column.get("field");
                    String name = (String) column.get("name");
                    if (isRepositoryColumn(field, name)) {
                        return Integer.valueOf(i);
                    }
                }
            }
        } catch (Exception e) {
            // Ignore
        }
        return null;
    }

    /**
     * Checks if the given field or name corresponds to the Repository column.
     */
    private boolean isRepositoryColumn(String field, String name) {
        if (field != null && (field.equals(REPOSITORY_COLUMN_FIELD) || field.equals(REPOSITORY_COLUMN_FIELD_ALT))) {
            return true;
        }
        if (name != null && (name.equals(REPOSITORY_COLUMN_FIELD) || name.equalsIgnoreCase(REPOSITORY_COLUMN_FIELD_ALT))) {
            return true;
        }
        return false;
    }
}
