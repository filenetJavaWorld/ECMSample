package com.filenet.loadtest.main;

import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.config.ConfigLoader;
import com.filenet.loadtest.search.SearchOrchestrator;
import com.filenet.loadtest.upload.UploadOrchestrator;
import com.filenet.loadtest.util.StartupValidator;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.lang.Thread.UncaughtExceptionHandler;

/**
 * Main entry point for the IBM FileNet CPE load testing utility.
 * Runs document upload load testing followed by optional search load testing.
 */
public final class LoadTestApplication {

    private static final Logger LOG = LogManager.getLogger(LoadTestApplication.class);

    private LoadTestApplication() {
    }

    /**
     * Application entry point.
     *
     * @param args optional config file path (defaults to config.properties)
     */
    public static void main(String[] args) {
        Thread.setDefaultUncaughtExceptionHandler(new UncaughtExceptionHandler() {
            @Override
            public void uncaughtException(Thread t, Throwable e) {
                LOG.error("Uncaught exception in thread {}: {}", t.getName(), e.getMessage(), e);
            }
        });

        LOG.info("IBM FileNet CPE Load Test Utility starting");

        try {
            AppConfig config = args.length > 0
                    ? ConfigLoader.load(args[0])
                    : ConfigLoader.load();

            StartupValidator.validate(config);

            long overallStart = System.currentTimeMillis();

            UploadOrchestrator uploadOrchestrator = new UploadOrchestrator(config);
            uploadOrchestrator.execute();

            SearchOrchestrator searchOrchestrator = new SearchOrchestrator(config);
            searchOrchestrator.execute();

            long overallEnd = System.currentTimeMillis();
            LOG.info("Load test utility completed. Total wall-clock time: {} ms",
                    overallEnd - overallStart);

        } catch (Exception ex) {
            LOG.error("Load test utility failed: {}", ex.getMessage(), ex);
            System.err.println("Load test failed: " + ex.getMessage());
            System.exit(1);
        }
    }
}



package com.filenet.loadtest.mapper;

import com.filenet.api.admin.ClassDefinition;
import com.filenet.api.admin.PropertyDefinition;
import com.filenet.api.admin.PropertyDefinitionBoolean;
import com.filenet.api.admin.PropertyDefinitionDateTime;
import com.filenet.api.admin.PropertyDefinitionFloat64;
import com.filenet.api.admin.PropertyDefinitionId;
import com.filenet.api.admin.PropertyDefinitionInteger32;
import com.filenet.api.admin.PropertyDefinitionObject;
import com.filenet.api.admin.PropertyDefinitionString;
import com.filenet.api.collection.DateTimeList;
import com.filenet.api.collection.Integer32List;
import com.filenet.api.collection.PropertyDefinitionList;
import com.filenet.api.collection.StringList;
import com.filenet.api.constants.Cardinality;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.Id;
import com.filenet.loadtest.util.DateTimeUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.Date;
import java.util.Iterator;
import java.util.Map;

/**
 * Maps CSV column values to FileNet document properties using class property definitions.
 */
public final class PropertyMapper {

    private static final Logger LOG = LogManager.getLogger(PropertyMapper.class);
    private static final String DOCUMENT_TITLE = "DocumentTitle";
    private static final String MULTI_VALUE_DELIMITER = "\\|";

    private PropertyMapper() {
    }

    /**
     * Applies CSV row values to document properties based on FileNet property definitions.
     *
     * @param document    target document
     * @param objectStore object store for fetching class definition
     * @param className   document class symbolic name
     * @param row         CSV row data
     * @throws Exception if property mapping fails
     */
    public static void applyProperties(Document document, ObjectStore objectStore,
                                       String className, Map<String, String> row) throws Exception {
        ClassDefinition classDefinition = Factory.ClassDefinition.fetchInstance(
                objectStore, className, null);

        for (Map.Entry<String, String> entry : row.entrySet()) {
            String propertyName = entry.getKey();
            String rawValue = entry.getValue();

            if (propertyName == null || propertyName.trim().isEmpty()) {
                continue;
            }

            if (DOCUMENT_TITLE.equalsIgnoreCase(propertyName)) {
                continue;
            }

            if (rawValue == null || rawValue.trim().isEmpty()) {
                continue;
            }

            PropertyDefinition propertyDefinition = findPropertyDefinition(classDefinition, propertyName);
            if (propertyDefinition == null) {
                LOG.warn("Property '{}' not found on class '{}'. Skipping.", propertyName, className);
                continue;
            }

            Object convertedValue = convertValue(rawValue, propertyDefinition);
            document.getProperties().putObjectValue(propertyName, convertedValue);
        }
    }

    private static PropertyDefinition findPropertyDefinition(ClassDefinition classDefinition,
                                                             String propertyName) {
        PropertyDefinitionList propertyDefinitions = classDefinition.get_PropertyDefinitions();
        Iterator<?> iterator = propertyDefinitions.iterator();
        while (iterator.hasNext()) {
            PropertyDefinition propertyDefinition = (PropertyDefinition) iterator.next();
            if (propertyName.equalsIgnoreCase(propertyDefinition.get_SymbolicName())) {
                return propertyDefinition;
            }
        }
        return null;
    }

    private static Object convertValue(String rawValue, PropertyDefinition propertyDefinition) throws Exception {
        boolean isList = propertyDefinition.get_Cardinality() == Cardinality.LIST;

        if (propertyDefinition instanceof PropertyDefinitionString) {
            return isList ? toStringList(rawValue) : rawValue.trim();
        }
        if (propertyDefinition instanceof PropertyDefinitionInteger32) {
            return isList ? toInteger32List(rawValue) : Integer.valueOf(rawValue.trim());
        }
        if (propertyDefinition instanceof PropertyDefinitionFloat64) {
            return isList ? toStringList(rawValue) : Double.valueOf(rawValue.trim());
        }
        if (propertyDefinition instanceof PropertyDefinitionBoolean) {
            return Boolean.valueOf(rawValue.trim());
        }
        if (propertyDefinition instanceof PropertyDefinitionDateTime) {
            return isList ? toDateTimeList(rawValue) : DateTimeUtil.parseDate(rawValue.trim());
        }
        if (propertyDefinition instanceof PropertyDefinitionId) {
            return new Id(rawValue.trim());
        }
        if (propertyDefinition instanceof PropertyDefinitionObject) {
            return new Id(rawValue.trim());
        }

        LOG.warn("Unsupported property definition type {}. Treating value as String.",
                propertyDefinition.getClass().getSimpleName());
        return rawValue.trim();
    }

    private static StringList toStringList(String rawValue) {
        StringList stringList = Factory.StringList.createList();
        for (String token : rawValue.split(MULTI_VALUE_DELIMITER)) {
            if (token != null && !token.trim().isEmpty()) {
                stringList.add(token.trim());
            }
        }
        return stringList;
    }

    private static Integer32List toInteger32List(String rawValue) {
        Integer32List integerList = Factory.Integer32List.createList();
        for (String token : rawValue.split(MULTI_VALUE_DELIMITER)) {
            if (token != null && !token.trim().isEmpty()) {
                integerList.add(Integer.valueOf(token.trim()));
            }
        }
        return integerList;
    }

    private static DateTimeList toDateTimeList(String rawValue) throws Exception {
        DateTimeList dateList = Factory.DateTimeList.createList();
        for (String token : rawValue.split(MULTI_VALUE_DELIMITER)) {
            if (token != null && !token.trim().isEmpty()) {
                Date date = DateTimeUtil.parseDate(token.trim());
                dateList.add(date);
            }
        }
        return dateList;
    }
}



package com.filenet.loadtest.metrics;

import com.filenet.loadtest.model.PerformanceSummary;
import com.filenet.loadtest.model.SearchMetricRecord;
import com.filenet.loadtest.model.UploadMetricRecord;
import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVPrinter;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.FileWriter;
import java.io.IOException;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

/**
 * Thread-safe collector for upload and search metrics with CSV export support.
 */
public class MetricsCollector {

    private static final Logger LOG = LogManager.getLogger(MetricsCollector.class);

    private final List<UploadMetricRecord> uploadRecords = Collections.synchronizedList(new ArrayList<>());
    private final List<SearchMetricRecord> searchRecords = Collections.synchronizedList(new ArrayList<>());

    /**
     * Records an upload metric entry.
     *
     * @param record upload metric record
     */
    public void recordUpload(UploadMetricRecord record) {
        uploadRecords.add(record);
    }

    /**
     * Records a search metric entry.
     *
     * @param record search metric record
     */
    public void recordSearch(SearchMetricRecord record) {
        searchRecords.add(record);
    }

    /**
     * Writes upload metrics to a CSV file.
     *
     * @param outputFile path to output CSV
     * @throws IOException if writing fails
     */
    public void writeUploadMetrics(String outputFile) throws IOException {
        try (FileWriter writer = new FileWriter(outputFile);
             CSVPrinter printer = new CSVPrinter(writer, CSVFormat.DEFAULT.withHeader(
                     "ThreadName", "Class", "CSV File", "Row Number", "Document ID",
                     "Status", "Elapsed Time", "Exception Message", "Start Time", "End Time"))) {

            synchronized (uploadRecords) {
                for (UploadMetricRecord record : uploadRecords) {
                    printer.printRecord(
                            record.getThreadName(),
                            record.getClassName(),
                            record.getCsvFile(),
                            record.getRowNumber(),
                            record.getDocumentId(),
                            record.getStatus(),
                            record.getElapsedMs(),
                            nullToEmpty(record.getExceptionMessage()),
                            record.getStartTime(),
                            record.getEndTime()
                    );
                }
            }
        }
        LOG.info("Upload metrics written to {}", outputFile);
    }

    /**
     * Writes search metrics to a CSV file.
     *
     * @param outputFile path to output CSV
     * @throws IOException if writing fails
     */
    public void writeSearchMetrics(String outputFile) throws IOException {
        try (FileWriter writer = new FileWriter(outputFile);
             CSVPrinter printer = new CSVPrinter(writer, CSVFormat.DEFAULT.withHeader(
                     "ThreadName", "SearchType", "Class", "PropertyName", "SearchValue",
                     "Iteration", "ResultCount", "Elapsed Time", "Status",
                     "Exception Message", "Start Time", "End Time"))) {

            synchronized (searchRecords) {
                for (SearchMetricRecord record : searchRecords) {
                    printer.printRecord(
                            record.getThreadName(),
                            record.getSearchType(),
                            record.getClassName(),
                            nullToEmpty(record.getPropertyName()),
                            nullToEmpty(record.getSearchValue()),
                            record.getIteration(),
                            record.getResultCount(),
                            record.getElapsedMs(),
                            record.getStatus(),
                            nullToEmpty(record.getExceptionMessage()),
                            record.getStartTime(),
                            record.getEndTime()
                    );
                }
            }
        }
        LOG.info("Search metrics written to {}", outputFile);
    }

    /**
     * Builds upload performance summary statistics.
     *
     * @param totalExecutionMs total wall-clock execution time
     * @param totalClasses     number of classes processed
     * @return performance summary
     */
    public PerformanceSummary buildUploadSummary(long totalExecutionMs, int totalClasses) {
        List<UploadMetricRecord> snapshot;
        synchronized (uploadRecords) {
            snapshot = new ArrayList<>(uploadRecords);
        }

        int total = snapshot.size();
        int success = 0;
        long totalElapsed = 0;
        long max = 0;
        long min = Long.MAX_VALUE;

        for (UploadMetricRecord record : snapshot) {
            if (record.isSuccess()) {
                success++;
            }
            long elapsed = record.getElapsedMs();
            totalElapsed += elapsed;
            max = Math.max(max, elapsed);
            min = Math.min(min, elapsed);
        }

        int failed = total - success;
        double average = total > 0 ? (double) totalElapsed / total : 0.0;
        if (min == Long.MAX_VALUE) {
            min = 0;
        }

        double opsPerSecond = totalExecutionMs > 0
                ? (total * 1000.0) / totalExecutionMs
                : 0.0;

        return new PerformanceSummary(
                "Upload",
                totalClasses,
                total,
                success,
                failed,
                average,
                max,
                min,
                totalExecutionMs,
                opsPerSecond
        );
    }

    /**
     * Builds search performance summary statistics.
     *
     * @param totalExecutionMs total wall-clock execution time
     * @return performance summary
     */
    public PerformanceSummary buildSearchSummary(long totalExecutionMs) {
        List<SearchMetricRecord> snapshot;
        synchronized (searchRecords) {
            snapshot = new ArrayList<>(searchRecords);
        }

        int total = snapshot.size();
        int success = 0;
        long totalElapsed = 0;
        long max = 0;
        long min = Long.MAX_VALUE;

        for (SearchMetricRecord record : snapshot) {
            if (record.isSuccess()) {
                success++;
            }
            long elapsed = record.getElapsedMs();
            totalElapsed += elapsed;
            max = Math.max(max, elapsed);
            min = Math.min(min, elapsed);
        }

        int failed = total - success;
        double average = total > 0 ? (double) totalElapsed / total : 0.0;
        if (min == Long.MAX_VALUE) {
            min = 0;
        }

        double opsPerSecond = totalExecutionMs > 0
                ? (total * 1000.0) / totalExecutionMs
                : 0.0;

        return new PerformanceSummary(
                "Search",
                0,
                total,
                success,
                failed,
                average,
                max,
                min,
                totalExecutionMs,
                opsPerSecond
        );
    }

    private static String nullToEmpty(String value) {
        return value == null ? "" : value;
    }
}



