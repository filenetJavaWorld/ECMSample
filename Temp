import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import com.filenet.api.constants.PropertyNames;

public final class ReportRequestEmailContextFactory {

    private ReportRequestEmailContextFactory() {
    }

    public static ReportRequestEmailContext from(AppConfig config, ObjectStore objectStore,
            ReportRequestSummary summary, ReportRequestPayload payload, String status) {
        ReportRequestEmailContext context = new ReportRequestEmailContext();
        context.setReportName(firstNonBlank(
                payload != null ? payload.getReportName() : null,
                summary != null ? summary.getDocumentTitle() : null));
        context.setTargetDocumentClass(firstNonBlank(
                payload != null ? payload.getTargetClassSymbolicName() : null,
                summary != null ? summary.getTargetDocumentClass() : null));
        context.setRepositoryName(firstNonBlank(
                payload != null ? payload.getRepositoryName() : null,
                summary != null ? summary.getRepositoryName() : null));
        context.setRepositoryId(firstNonBlank(
                payload != null ? payload.getRepositoryId() : null,
                summary != null ? summary.getRepositoryId() : null));
        context.setStatus(status);
        context.setSubmittedOn(payload != null ? payload.getSubmittedOn() : null);
        context.setExecutionStartDate(summary != null ? summary.getExecutionStartDate() : null);
        context.setExecutionEndDate(summary != null ? summary.getExecutionEndDate() : null);
        context.setDocumentId(summary != null ? summary.getDocumentId() : null);
        context.setLatestVersionId(resolveLatestVersionId(objectStore, summary != null ? summary.getDocumentId() : null));
        context.setSendEmailTo(firstNonEmpty(
                payload != null ? payload.getSendEmailTo() : null,
                summary != null ? summary.getSendEmailTo() : null));
        context.setSendEmailCc(firstNonEmpty(
                payload != null ? payload.getSendEmailCC() : null,
                summary != null ? summary.getSendEmailCC() : null));
        context.setBookmarkUrl(BookmarkUrlBuilder.build(config, context.getRepositoryId(), context.getLatestVersionId()));
        return context;
    }

    private static String resolveLatestVersionId(ObjectStore objectStore, String documentId) {
        if (documentId == null || objectStore == null) {
            return documentId;
        }
        try {
            PropertyFilter filter = new PropertyFilter();
            filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
            filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
            Document document = Factory.Document.fetchInstance(objectStore, new Id(documentId), filter);
            VersionSeries versionSeries = document.get_VersionSeries();
            if (versionSeries != null && versionSeries.get_CurrentVersion() instanceof Document) {
                return ((Document) versionSeries.get_CurrentVersion()).get_Id().toString();
            }
            return document.get_Id().toString();
        } catch (Exception ex) {
            return documentId;
        }
    }

    public static String formatPropertyDate(Properties props, String propertyName) {
        return P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, propertyName));
    }

    private static String firstNonBlank(String first, String second) {
        if (first != null && !first.isBlank()) {
            return first;
        }
        return second;
    }

    private static java.util.List<String> firstNonEmpty(java.util.List<String> first, java.util.List<String> second) {
        if (first != null && !first.isEmpty()) {
            return first;
        }
        return second != null ? second : java.util.List.of();
    }
}


package com.cnb.reports.email;

import com.cnb.reports.config.AppConfig;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import javax.mail.Message;
import javax.mail.Session;
import javax.mail.Transport;
import javax.mail.internet.InternetAddress;
import javax.mail.internet.MimeMessage;
import java.nio.file.Path;
import java.util.List;
import java.util.Properties;

public final class SmtpEmailSender {

    private static final Logger LOGGER = LogManager.getLogger(SmtpEmailSender.class);

    private final AppConfig config;

    public SmtpEmailSender(AppConfig config) {
        this.config = config;
    }

    public void send(String subject, String body, List<String> toRecipients, List<String> ccRecipients, Path attachment)
            throws Exception {
        if (!config.isMailEnabled()) {
            LOGGER.info("Mail disabled. Skipping email with subject '{}'.", subject);
            return;
        }

        List<String> to = EmailValidator.normalizeList(toRecipients);
        if (to.isEmpty()) {
            LOGGER.info("No valid SendEmailTo recipients. Skipping email with subject '{}'.", subject);
            return;
        }

        Session session = Session.getInstance(buildMailProperties(), null);
        MimeMessage message = new MimeMessage(session);
        message.setFrom(new InternetAddress(config.getMailFromAddress(), config.getMailFromName()));
        for (String recipient : to) {
            message.addRecipient(Message.RecipientType.TO, new InternetAddress(recipient));
        }
        for (String recipient : EmailValidator.normalizeList(ccRecipients)) {
            message.addRecipient(Message.RecipientType.CC, new InternetAddress(recipient));
        }
        message.setSubject(subject, "UTF-8");
        message.setText(body, "UTF-8");

        Transport transport = session.getTransport("smtp");
        try {
            if (config.isMailSmtpAuth()) {
                transport.connect(config.getMailSmtpHost(), config.getMailSmtpPort(),
                        config.getMailSmtpUsername(), config.getMailSmtpPassword());
            } else {
                transport.connect();
            }
            transport.sendMessage(message, message.getAllRecipients());
            LOGGER.info("Sent email '{}' to {}", subject, to);
        } finally {
            transport.close();
        }
    }

    private Properties buildMailProperties() {
        Properties props = new Properties();
        props.put("mail.smtp.host", config.getMailSmtpHost());
        props.put("mail.smtp.port", String.valueOf(config.getMailSmtpPort()));
        props.put("mail.smtp.auth", String.valueOf(config.isMailSmtpAuth()));
        props.put("mail.smtp.starttls.enable", String.valueOf(config.isMailSmtpStartTlsEnable()));
        return props;
    }
}


