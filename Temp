package com.cnb.reports.email;

import com.cnb.reports.config.AppConfig;
import org.apache.commons.lang3.StringUtils;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

public final class EmailService {

    private static final Logger LOGGER = LogManager.getLogger(EmailService.class);

    private static final String DEFAULT_ACK_BODY =
            "Hello,\n"
            + "\n"
            + "Your report request has been submitted successfully.\n"
            + "\n"
            + "Report Name: ${reportName}\n"
            + "Target Document Class: ${targetDocumentClass}\n"
            + "Repository Name: ${repositoryName}\n"
            + "Status: ${status}\n"
            + "Submitted On: ${submittedOn}\n"
            + "\n"
            + "You will receive another email once the report execution is completed.\n"
            + "\n"
            + "Thank you.\n";

    private static final String DEFAULT_COMPLETION_BODY =
            "Hello,\n"
            + "\n"
            + "Your report has been generated successfully.\n"
            + "\n"
            + "Report Name: ${reportName}\n"
            + "Target Document Class: ${targetDocumentClass}\n"
            + "Repository Name: ${repositoryName}\n"
            + "Status: ${status}\n"
            + "Execution Start Date: ${executionStartDate}\n"
            + "Execution End Date: ${executionEndDate}\n"
            + "\n"
            + "Open Report Request:\n"
            + "${bookmarkUrl}\n"
            + "\n"
            + "Please open the link and click Download to download the generated report.\n"
            + "\n"
            + "Thank you.\n";

    private static final String DEFAULT_COMPLETION_BODY_NO_BOOKMARK =
            "Hello,\n"
            + "\n"
            + "Your report has been generated successfully.\n"
            + "\n"
            + "Report Name: ${reportName}\n"
            + "Target Document Class: ${targetDocumentClass}\n"
            + "Repository Name: ${repositoryName}\n"
            + "Status: ${status}\n"
            + "Execution Start Date: ${executionStartDate}\n"
            + "Execution End Date: ${executionEndDate}\n"
            + "\n"
            + "The report can be accessed from the ICN Reports Feature.\n"
            + "\n"
            + "Thank you.\n";

    private static final String DEFAULT_FAILURE_BODY =
            "Hello,\n"
            + "\n"
            + "Your report request could not be completed.\n"
            + "\n"
            + "Report Name: ${reportName}\n"
            + "Target Document Class: ${targetDocumentClass}\n"
            + "Repository Name: ${repositoryName}\n"
            + "Status: ${status}\n"
            + "Execution Start Date: ${executionStartDate}\n"
            + "Execution End Date: ${executionEndDate}\n"
            + "\n"
            + "Please contact the support team for assistance.\n"
            + "\n"
            + "Thank you.\n";

    private final AppConfig config;
    private final SmtpEmailSender sender;

    public EmailService(AppConfig config) {
        this.config = config;
        this.sender = new SmtpEmailSender(config);
    }

    public void sendAcknowledgementEmail(ReportRequestEmailContext context) {
        sendSafely("acknowledgement", () -> {
            String subject = "Report Request Submitted - " + safe(context.getReportName());
            String body = EmailTemplateRenderer.render(
                    config.getAcknowledgementTemplatePath(), DEFAULT_ACK_BODY, context);
            sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc(), null);
        });
    }

    public void sendCompletionEmail(ReportRequestEmailContext context) {
        sendSafely("completion", () -> {
            String subject = "Report Completed - " + safe(context.getReportName());
            String defaultBody = StringUtils.isBlank(context.getBookmarkUrl())
                    ? DEFAULT_COMPLETION_BODY_NO_BOOKMARK
                    : DEFAULT_COMPLETION_BODY;
            String body = EmailTemplateRenderer.render(
                    config.getCompletionTemplatePath(), defaultBody, context);
            sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc(), null);
        });
    }

    public void sendFailureEmail(ReportRequestEmailContext context) {
        sendSafely("failure", () -> {
            String subject = "Report Failed - " + safe(context.getReportName());
            String body = EmailTemplateRenderer.render(
                    config.getFailureTemplatePath(), DEFAULT_FAILURE_BODY, context);
            sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc(), null);
        });
    }

    private void sendSafely(String type, EmailAction action) {
        try {
            action.run();
        } catch (Exception ex) {
            LOGGER.error("Failed to send {} email.", type, ex);
        }
    }

    private static String safe(String value) {
        return value != null ? value : "Report Request";
    }

    @FunctionalInterface
    private interface EmailAction {
        void run() throws Exception;
    }
}
