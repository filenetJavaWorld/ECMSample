			var self = this;

			function doneOne() {
				pending--;
				if (pending <= 0 && !failed) {
					callback(collected, null);
				}
			}

			function fail(message) {
				if (failed) {
					return;
				}
				failed = true;
				callback([], message || "Unable to retrieve repository information.");
			}

			function walk(contentClass) {
				try {
					contentClass.retrieveSubClasses(function(subClasses) {
						if (failed) {
							return;
						}
						array.forEach(subClasses || [], function(sub) {
							if (!sub || !sub.id) {
								return;
							}
							collected.push(sub);
							pending++;
							walk(sub);
						});
						doneOne();
					});
				} catch (e) {
					fail("Unable to retrieve repository information.");
				}
			}

			walk(rootClass);
		}
