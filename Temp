package com.cnb.updater.csv;

import com.cnb.updater.model.SearchResultRecord;
import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVParser;
import org.apache.commons.csv.CSVRecord;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.IOException;
import java.io.Reader;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.List;

public final class CsvReader {

    private static final Logger LOGGER = LogManager.getLogger(CsvReader.class);

    private CsvReader() {
    }

    public static List<SearchResultRecord> read(String csvFilePath) throws IOException {
        Path path = Paths.get(csvFilePath);
        List<SearchResultRecord> records = new ArrayList<>();

        try (Reader reader = Files.newBufferedReader(path, StandardCharsets.UTF_8);
             CSVParser parser = CSVFormat.DEFAULT
                     .builder()
                     .setHeader()
                     .setSkipHeaderRecord(true)
                     .setIgnoreEmptyLines(true)
                     .setTrim(true)
                     .build()
                     .parse(reader)) {

            for (CSVRecord csvRecord : parser) {
                records.add(new SearchResultRecord(
                        getValue(csvRecord, "ACCOUNT_NUMBER"),
                        getValue(csvRecord, "Document_Class"),
                        getValue(csvRecord, "Document_GUID"),
                        getValue(csvRecord, "CIS"),
                        getValue(csvRecord, "Status"),
                        getValue(csvRecord, "Comments"),
                        getValue(csvRecord, "Update_Status")
                ));
            }
        }

        LOGGER.info("Loaded {} row(s) from CSV file {}", records.size(), csvFilePath);
        return records;
    }

    private static String getValue(CSVRecord record, String columnName) {
        if (!record.isMapped(columnName)) {
            return "";
        }
        String value = record.get(columnName);
        return value == null ? "" : value.trim();
    }
}





package com.cnb.updater.csv;

import com.cnb.updater.model.SearchResultRecord;
import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVPrinter;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.BufferedWriter;
import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.List;

public final class CsvWriter {

    private static final Logger LOGGER = LogManager.getLogger(CsvWriter.class);

    private static final String[] HEADERS = {
            "ACCOUNT_NUMBER",
            "Document_Class",
            "Document_GUID",
            "CIS",
            "Status",
            "Comments",
            "Update_Status"
    };

    private CsvWriter() {
    }

    public static void write(String csvFilePath, List<SearchResultRecord> records) throws IOException {
        Path path = Paths.get(csvFilePath);
        if (path.getParent() != null) {
            Files.createDirectories(path.getParent());
        }

        try (BufferedWriter writer = Files.newBufferedWriter(path, StandardCharsets.UTF_8);
             CSVPrinter printer = new CSVPrinter(writer, CSVFormat.DEFAULT.builder().setHeader(HEADERS).build())) {

            for (SearchResultRecord record : records) {
                printer.printRecord(
                        record.getAccountNumber(),
                        record.getDocumentClass(),
                        record.getDocumentGuid(),
                        record.getCis(),
                        record.getStatus(),
                        record.getComments(),
                        record.getUpdateStatus()
                );
            }
        }

        LOGGER.info("Wrote {} row(s) to CSV file {}", records.size(), csvFilePath);
    }
}




package com.cnb.updater.excel;

import com.cnb.updater.config.ExcelColumnConfig;
import com.cnb.updater.model.InputRecord;
import org.apache.commons.lang3.StringUtils;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;
import org.apache.poi.ss.usermodel.Cell;
import org.apache.poi.ss.usermodel.DataFormatter;
import org.apache.poi.ss.usermodel.Row;
import org.apache.poi.ss.usermodel.Sheet;
import org.apache.poi.ss.usermodel.Workbook;
import org.apache.poi.ss.usermodel.WorkbookFactory;

import java.io.FileInputStream;
import java.io.IOException;
import java.io.InputStream;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Locale;
import java.util.Map;

public final class ExcelReader {

    private static final Logger LOGGER = LogManager.getLogger(ExcelReader.class);
    private static final DataFormatter DATA_FORMATTER = new DataFormatter();

    private ExcelReader() {
    }

    public static List<InputRecord> read(String excelFilePath, ExcelColumnConfig columnConfig) throws IOException {
        List<InputRecord> records = new ArrayList<>();

        try (InputStream inputStream = new FileInputStream(excelFilePath);
             Workbook workbook = WorkbookFactory.create(inputStream)) {

            Sheet sheet = workbook.getSheetAt(0);
            if (sheet == null) {
                throw new IllegalArgumentException("Excel file does not contain any sheets: " + excelFilePath);
            }

            Row headerRow = sheet.getRow(sheet.getFirstRowNum());
            if (headerRow == null) {
                throw new IllegalArgumentException("Excel sheet is empty: " + excelFilePath);
            }

            Map<String, Integer> columnIndex = mapHeaderColumns(headerRow, columnConfig);

            for (int rowIndex = sheet.getFirstRowNum() + 1; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
                Row row = sheet.getRow(rowIndex);
                if (row == null || isBlankRow(row, columnIndex)) {
                    continue;
                }

                String accountNumber = getCellValue(row, columnIndex.get(normalizeHeader(columnConfig.getAccountNumberColumn())));
                if (StringUtils.isBlank(accountNumber)) {
                    LOGGER.warn("Skipping row {} because {} is blank",
                            rowIndex + 1, columnConfig.getAccountNumberColumn());
                    continue;
                }

                records.add(new InputRecord(
                        accountNumber.trim(),
                        getCellValue(row, columnIndex.get(normalizeHeader(columnConfig.getAccountNameColumn()))),
                        getCellValue(row, columnIndex.get(normalizeHeader(columnConfig.getCisColumn()))),
                        getCellValue(row, columnIndex.get(normalizeHeader(columnConfig.getCisNameColumn())))
                ));
            }
        }

        LOGGER.info("Loaded {} input row(s) from Excel file {}", records.size(), excelFilePath);
        return records;
    }

    private static Map<String, Integer> mapHeaderColumns(Row headerRow, ExcelColumnConfig columnConfig) {
        Map<String, Integer> columnIndex = new HashMap<>();

        for (Cell cell : headerRow) {
            String header = normalizeHeader(getCellValue(headerRow, cell.getColumnIndex()));
            if (StringUtils.isNotBlank(header)) {
                columnIndex.put(header, cell.getColumnIndex());
            }
        }

        requireColumn(columnIndex, columnConfig.getAccountNumberColumn());
        requireColumn(columnIndex, columnConfig.getAccountNameColumn());
        requireColumn(columnIndex, columnConfig.getCisColumn());
        requireColumn(columnIndex, columnConfig.getCisNameColumn());

        return columnIndex;
    }

    private static void requireColumn(Map<String, Integer> columnIndex, String columnName) {
        String normalizedColumnName = normalizeHeader(columnName);
        if (!columnIndex.containsKey(normalizedColumnName)) {
            throw new IllegalArgumentException("Missing required Excel column: " + columnName
                    + ". Found headers: " + columnIndex.keySet());
        }
    }

    private static String normalizeHeader(String header) {
        return header == null ? "" : header.trim().toUpperCase(Locale.ENGLISH);
    }

    private static boolean isBlankRow(Row row, Map<String, Integer> columnIndex) {
        for (Integer index : columnIndex.values()) {
            if (StringUtils.isNotBlank(getCellValue(row, index))) {
                return false;
            }
        }
        return true;
    }

    private static String getCellValue(Row row, Integer columnIndex) {
        if (columnIndex == null) {
            return "";
        }
        return getCellValue(row, columnIndex.intValue());
    }

    private static String getCellValue(Row row, int columnIndex) {
        Cell cell = row.getCell(columnIndex);
        if (cell == null) {
            return "";
        }
        String value = DATA_FORMATTER.formatCellValue(cell);
        return value == null ? "" : value.trim();
    }
}





package com.cnb.updater.filenet;

import com.cnb.updater.config.AppConfig;
import com.filenet.api.core.Connection;
import com.filenet.api.core.Domain;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.UserContext;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import javax.security.auth.Subject;

public final class FileNetConnectionManager implements AutoCloseable {

    private static final Logger LOGGER = LogManager.getLogger(FileNetConnectionManager.class);

    private final AppConfig config;
    private final Connection connection;
    private final Subject subject;
    private final Domain domain;
    private final ObjectStore objectStore;

    public FileNetConnectionManager(AppConfig config) {
        this.config = config;
        LOGGER.info("Connecting to FileNet CE at {}", config.getFileNetUri());

        connection = Factory.Connection.getConnection(config.getFileNetUri());
        subject = UserContext.createSubject(
                connection,
                config.getFileNetUsername(),
                config.getFileNetPassword(),
                null
        );

        if (subject == null) {
            throw new IllegalStateException(
                    "FileNet authentication failed. Check filenet.username and filenet.password.");
        }

        UserContext.get().pushSubject(subject);
        domain = Factory.Domain.fetchInstance(connection, null, null);
        objectStore = Factory.ObjectStore.fetchInstance(domain, config.getFileNetObjectStore(), null);

        LOGGER.info("FileNet connection established for object store: {}", config.getFileNetObjectStore());
    }

    public ObjectStore getObjectStore() {
        return objectStore;
    }

    public Domain getDomain() {
        return domain;
    }

    public AppConfig getConfig() {
        return config;
    }

    public void testConnection() {
        ObjectStore os = Factory.ObjectStore.fetchInstance(domain, config.getFileNetObjectStore(), null);
        LOGGER.info("FileNet connection test succeeded for object store {}", os.get_Name());
    }

    @Override
    public void close() {
        try {
            UserContext.get().popSubject();
            LOGGER.info("FileNet connection closed.");
        } catch (Exception ex) {
            LOGGER.warn("Error while closing FileNet connection: {}", ex.getMessage(), ex);
        }
    }
}




package com.cnb.updater.main;

import com.cnb.updater.config.AppConfig;
import com.cnb.updater.csv.CsvWriter;
import com.cnb.updater.excel.ExcelReader;
import com.cnb.updater.filenet.FileNetConnectionManager;
import com.cnb.updater.model.InputRecord;
import com.cnb.updater.model.SearchResultRecord;
import com.cnb.updater.service.DocumentSearchService;
import com.cnb.updater.util.PropertyLoader;
import com.cnb.updater.util.ValidationUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.List;

public final class SearchAndGenerateCsvMain {

    private static final Logger LOGGER = LogManager.getLogger(SearchAndGenerateCsvMain.class);

    private SearchAndGenerateCsvMain() {
    }

    public static void main(String[] args) {
        LOGGER.info("Starting Utility 1 - SearchAndGenerateCsv");

        String configPath = PropertyLoader.resolveConfigPath(args);

        try {
            AppConfig config = PropertyLoader.load(configPath);
            LOGGER.info("Configuration loaded from {}", configPath);

            ValidationUtil.validateForSearchUtility(config);

            List<InputRecord> inputRecords = ExcelReader.read(config.getInputExcel(), config.getExcelColumns());
            if (inputRecords.isEmpty()) {
                LOGGER.warn("No input rows found in Excel file {}", config.getInputExcel());
            }

            List<SearchResultRecord> searchResults;
            try (FileNetConnectionManager connectionManager = new FileNetConnectionManager(config)) {
                connectionManager.testConnection();
                DocumentSearchService searchService = new DocumentSearchService(connectionManager);
                searchResults = searchService.searchAndBuildResults(inputRecords);
            }

            CsvWriter.write(config.getOutputSearchCsv(), searchResults);

            long existCount = searchResults.stream()
                    .filter(record -> SearchResultRecord.STATUS_EXIST.equals(record.getStatus()))
                    .count();
            long missingCount = searchResults.stream()
                    .filter(record -> SearchResultRecord.STATUS_DOES_NOT_EXIST.equals(record.getStatus()))
                    .count();
            long notFoundCount = searchResults.stream()
                    .filter(record -> SearchResultRecord.STATUS_DOCUMENT_NOT_FOUND.equals(record.getStatus()))
                    .count();

            LOGGER.info("Search processing summary: totalRows={}, exist={}, doesNotExist={}, documentNotFound={}",
                    searchResults.size(), existCount, missingCount, notFoundCount);
            LOGGER.info("Utility 1 completed successfully. Output CSV: {}", config.getOutputSearchCsv());
        } catch (Exception ex) {
            LOGGER.error("Utility 1 failed: {}", ex.getMessage(), ex);
            System.exit(1);
        }
    }
}



