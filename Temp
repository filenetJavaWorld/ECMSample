	function resolveDocumentId(item) {
		if (!item) {
			return null;
		}
		var id = item.id;
		if (!id) {
			return null;
		}
		var parts = String(id).split(",");
		if (parts.length >= 3) {
			return parts[2];
		}
		return String(id);
	}

	function resolveItemStatus(item) {
		if (!item) {
			return "";
		}
		var status = null;
		if (item.getValue) {
			status = item.getValue("Status");
		}
		if (status == null && item.attributes) {
			status = item.attributes.Status;
		}
		if (status == null && item.getDisplayValue) {
			status = item.getDisplayValue("Status");
		}
		return status != null ? String(status).trim() : "";
	}

	function isPendingStatus(status) {
		return status != null && String(status).toLowerCase() === "pending";
	}

	function isFailedStatus(status) {
		return status != null && String(status).toLowerCase() === "failed";
	}

	function showError(message) {
		new MessageDialog({
			text: message
		}).show();
	}

	function refreshAfterAction(resultSet, callback, items) {
		if (resultSet && lang.isFunction(resultSet.refresh)) {
			resultSet.refresh();
		}
		if (lang.isFunction(callback)) {
			callback({
				items: items
			});
		}
	}

	/**
	 * Opens Create Report Request dialog prefilled from Version 1.0 JSON (Copy / Reinitiate).
	 */
	function openCreateDialogFromVersionOne(repository, items, callback, resultSet, failureMessage) {
		if (!repository) {
			showError("Select a repository.");
			return;
		}
		if (!items || items.length !== 1) {
			showError("Select exactly one report request.");
			return;
		}
		var documentId = resolveDocumentId(items[0]);
		if (!documentId) {
			showError("Unable to determine the report request document id.");
			return;
		}

		reportService.getReportRequestDetails(repository.id, documentId, null, function(response) {
			var details = response.details || {};
			var reportRequest = details.reportRequest || {};
			if (!reportRequest.targetClassSymbolicName && !(reportRequest.criteria && reportRequest.criteria.length)) {
				showError(failureMessage || "Unable to load Version 1 request JSON for this report request.");
				return;
