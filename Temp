package com.cnb.reports.mail;

import com.ibm.ecm.extension.PluginServiceCallbacks;
import com.ibm.json.java.JSONObject;

public final class EmailService {

	private static final String DEFAULT_ACK_BODY = "Hello,\n\n"
			+ "Your report request has been submitted successfully.\n\n"
			+ "Report Name: ${reportName}\n"
			+ "Target Document Class: ${targetDocumentClass}\n"
			+ "Repository Name: ${repositoryName}\n"
			+ "Status: ${status}\n"
			+ "Submitted On: ${submittedOn}\n\n"
			+ "You will receive another email once the report execution is completed.\n\n"
			+ "Thank you.\n";

	private final MailConfig config;
	private final SmtpEmailSender sender;
	private final PluginServiceCallbacks callbacks;

	public EmailService(MailConfig config, PluginServiceCallbacks callbacks) {
		this.config = config;
		this.callbacks = callbacks;
		this.sender = new SmtpEmailSender(config, callbacks);
	}

	public void sendAcknowledgementEmail(ReportRequestEmailContext context) {
		try {
			if (context.getSendEmailTo().isEmpty()) {
				return;
			}
			String subject = "Report Request Submitted - " + safe(context.getReportName());
			String body = EmailTemplateRenderer.render(
					config.getAcknowledgementTemplateFile(), DEFAULT_ACK_BODY, context);
			sender.send(subject, body, context.getSendEmailTo(), context.getSendEmailCc());
		} catch (Exception ex) {
			logError("sendAcknowledgementEmail", ex);
		}
	}

	public static ReportRequestEmailContext buildAcknowledgementContext(JSONObject payloadJson) {
		ReportRequestEmailContext context = new ReportRequestEmailContext();
		context.setReportName(trim(payloadJson.get("reportName")));
		context.setTargetDocumentClass(trim(payloadJson.get("targetClassSymbolicName")));
		context.setRepositoryName(resolveRepositoryName(payloadJson));
		context.setStatus(trim(payloadJson.get("status")));
		context.setSubmittedOn(trim(payloadJson.get("submittedOn")));
		context.setSendEmailTo(readEmailArray(payloadJson, "sendEmailTo"));
		context.setSendEmailCc(readEmailArray(payloadJson, "sendEmailCC"));
		if (context.getSendEmailCc().isEmpty()) {
			context.setSendEmailCc(readEmailArray(payloadJson, "sendEmailCc"));
		}
		return context;
	}

	private static String resolveRepositoryName(JSONObject payloadJson) {
		String name = trim(payloadJson.get("repositoryName"));
		if (name != null) {
			return name;
		}
		name = trim(payloadJson.get("objectStoreName"));
		return name != null ? name : "";
	}

	private static java.util.List<String> readEmailArray(JSONObject payloadJson, String key) {
		Object raw = payloadJson.get(key);
		java.util.List<String> emails = new java.util.ArrayList<String>();
		if (raw instanceof com.ibm.json.java.JSONArray) {
			com.ibm.json.java.JSONArray arr = (com.ibm.json.java.JSONArray) raw;
			for (int i = 0; i < arr.size(); i++) {
				Object value = arr.get(i);
				if (value != null) {
					emails.add(String.valueOf(value));
				}
			}
		} else if (raw instanceof String) {
			emails.addAll(EmailValidator.parseSemicolonSeparated((String) raw));
		}
		return EmailValidator.normalizeList(emails);
	}

	private static String safe(String value) {
		return value != null && value.length() > 0 ? value : "Report Request";
	}

	private static String trim(Object value) {
		if (value == null) {
			return null;
		}
		String text = String.valueOf(value).trim();
		return text.length() == 0 ? null : text;
	}

	private void logError(String method, Exception ex) {
		if (callbacks != null && callbacks.getLogger() != null) {
			callbacks.getLogger().logError(this, method, "", ex);
		}
	}
}




package com.cnb.reports.mail;

import java.io.BufferedReader;
import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.io.InputStreamReader;
import java.nio.charset.Charset;

public final class EmailTemplateRenderer {

	private static final Charset UTF8 = Charset.forName("UTF-8");

	private EmailTemplateRenderer() {
	}

	public static String render(File templateFile, String defaultTemplate, ReportRequestEmailContext context)
			throws IOException {
		String template = defaultTemplate;
		if (templateFile != null && templateFile.isFile()) {
			template = readFile(templateFile);
		}
		return applyPlaceholders(template, context);
	}

	public static String applyPlaceholders(String template, ReportRequestEmailContext context) {
		if (template == null) {
			return "";
		}
		String rendered = template;
		rendered = replace(rendered, "reportName", context.getReportName());
		rendered = replace(rendered, "targetDocumentClass", context.getTargetDocumentClass());
		rendered = replace(rendered, "repositoryName", context.getRepositoryName());
		rendered = replace(rendered, "status", context.getStatus());
		rendered = replace(rendered, "submittedOn", context.getSubmittedOn());
		return rendered;
	}

	private static String replace(String template, String key, String value) {
		String replacement = value != null ? value : "";
		return template.replace("${" + key + "}", replacement);
	}

	private static String readFile(File file) throws IOException {
		StringBuilder sb = new StringBuilder();
		BufferedReader reader = null;
		try {
			reader = new BufferedReader(new InputStreamReader(new FileInputStream(file), UTF8));
			String line;
			while ((line = reader.readLine()) != null) {
				if (sb.length() > 0) {
					sb.append('\n');
				}
				sb.append(line);
			}
		} finally {
			if (reader != null) {
				try {
					reader.close();
				} catch (IOException e) {
					// ignore
				}
			}
		}
		return sb.toString();
	}
}






