import java.io.FileWriter;
import java.io.PrintWriter;
import java.util.*;

import javax.security.auth.Subject;

import com.filenet.api.collection.AccessPermissionList;
import com.filenet.api.core.Connection;
import com.filenet.api.core.Domain;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.meta.ClassDescription;
import com.filenet.api.property.FilterElement;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.security.AccessPermission;
import com.filenet.api.util.UserContext;

public class CompareClassDefaultSecurity {

    static class EnvConfig {
        String uri;
        String user;
        String password;
        String objectStore;

        EnvConfig(String uri, String user, String password, String objectStore) {
            this.uri = uri;
            this.user = user;
            this.password = password;
            this.objectStore = objectStore;
        }
    }

    static class SecurityEntry {
        String principal;
        Integer accessMask;
        Integer accessType;
        Integer inheritableDepth;

        SecurityEntry(String principal, Integer accessMask, Integer accessType, Integer inheritableDepth) {
            this.principal = principal == null ? "" : principal.trim();
            this.accessMask = accessMask;
            this.accessType = accessType;
            this.inheritableDepth = inheritableDepth;
        }

        String key() {
            return principal.toLowerCase();
        }

        String details() {
            return "Principal=" + principal
                    + "; AccessMask=" + accessMask
                    + "; AccessType=" + accessType
                    + "; InheritableDepth=" + inheritableDepth;
        }
    }

    public static void main(String[] args) throws Exception {

        EnvConfig uatConfig = new EnvConfig(
                "http://uat-server:9080/wsi/FNCEWS40MTOM/",
                "uat_user",
                "uat_password",
                "UAT_OBJECT_STORE"
        );

        EnvConfig prodConfig = new EnvConfig(
                "http://prod-server:9080/wsi/FNCEWS40MTOM/",
                "prod_user",
                "prod_password",
                "PROD_OBJECT_STORE"
        );

        String[] documentClasses = {
                "CNBAccounts",
                "CYA Document",
                "CYA Recovery Log",
                "Contact",
                "DC_ACHGuardian_Document"
        };

        Map<String, Map<String, SecurityEntry>> uatSecurity =
                getSecurityForClasses(uatConfig, documentClasses);

        Map<String, Map<String, SecurityEntry>> prodSecurity =
                getSecurityForClasses(prodConfig, documentClasses);

        compareSecurity(
                documentClasses,
                uatSecurity,
                prodSecurity,
                "Security_Comparison_Report.csv"
        );

        System.out.println("Security comparison completed successfully.");
    }

    private static Map<String, Map<String, SecurityEntry>> getSecurityForClasses(
            EnvConfig config,
            String[] classNames
    ) throws Exception {

        Map<String, Map<String, SecurityEntry>> result = new LinkedHashMap<>();

        Connection conn = Factory.Connection.getConnection(config.uri);
        Subject subject = UserContext.createSubject(
                conn,
                config.user,
                config.password,
                "FileNetP8WSI"
        );

        UserContext.get().pushSubject(subject);

        try {
            Domain domain = Factory.Domain.fetchInstance(conn, null, null);
            ObjectStore os = Factory.ObjectStore.fetchInstance(domain, config.objectStore, null);

            PropertyFilter pf = new PropertyFilter();
            pf.addIncludeProperty(new FilterElement(
                    null,
                    null,
                    null,
                    "DefaultInstancePermissions",
                    null
            ));

            for (String className : classNames) {

                Map<String, SecurityEntry> securityMap = new TreeMap<>();

                try {
                    ClassDescription classDesc =
                            Factory.ClassDescription.fetchInstance(os, className, pf);

                    AccessPermissionList permissionList =
                            classDesc.get_DefaultInstancePermissions();

                    if (permissionList != null) {
                        Iterator<?> iterator = permissionList.iterator();

                        while (iterator.hasNext()) {
                            AccessPermission permission = (AccessPermission) iterator.next();

                            SecurityEntry entry = new SecurityEntry(
                                    permission.get_GranteeName(),
                                    permission.get_AccessMask(),
                                    permission.get_AccessType().getValue(),
                                    permission.get_InheritableDepth()
                            );

                            securityMap.put(entry.key(), entry);
                        }
                    }

                    result.put(className, securityMap);

                } catch (Exception e) {
                    System.out.println("Failed to read class: " + className
                            + " from ObjectStore: " + config.objectStore
                            + " Error: " + e.getMessage());

                    result.put(className, null);
                }
            }

        } finally {
            UserContext.get().popSubject();
        }

        return result;
    }

    private static void compareSecurity(
            String[] documentClasses,
            Map<String, Map<String, SecurityEntry>> uatSecurity,
            Map<String, Map<String, SecurityEntry>> prodSecurity,
            String outputFile
    ) throws Exception {

        try (PrintWriter writer = new PrintWriter(new FileWriter(outputFile))) {

            writer.println("DocumentClassName,SecurityPrincipal,UAT_DefaultSecurity,PROD_DefaultSecurity,CompareStatus");

            for (String className : documentClasses) {

                Map<String, SecurityEntry> uatMap = uatSecurity.get(className);
                Map<String, SecurityEntry> prodMap = prodSecurity.get(className);

                if (uatMap == null && prodMap == null) {
                    writer.println(csv(className, "", "", "", "CLASS_NOT_FOUND_IN_BOTH"));
                    continue;
                }

                if (uatMap == null) {
                    for (SecurityEntry prodEntry : prodMap.values()) {
                        writer.println(csv(
                                className,
                                prodEntry.principal,
                                "",
                                prodEntry.details(),
                                "CLASS_NOT_FOUND_IN_UAT"
                        ));
                    }
                    continue;
                }

                if (prodMap == null) {
                    for (SecurityEntry uatEntry : uatMap.values()) {
                        writer.println(csv(
                                className,
                                uatEntry.principal,
                                uatEntry.details(),
                                "",
                                "CLASS_NOT_FOUND_IN_PROD"
                        ));
                    }
                    continue;
                }

                List<String> matchedRows = new ArrayList<>();
                List<String> unmatchedRows = new ArrayList<>();

                Set<String> allPrincipals = new TreeSet<>();
                allPrincipals.addAll(uatMap.keySet());
                allPrincipals.addAll(prodMap.keySet());

                for (String principalKey : allPrincipals) {

                    SecurityEntry uatEntry = uatMap.get(principalKey);
                    SecurityEntry prodEntry = prodMap.get(principalKey);

                    if (uatEntry != null && prodEntry != null) {

                        if (uatEntry.details().equals(prodEntry.details())) {
                            matchedRows.add(csv(
                                    className,
                                    uatEntry.principal,
                                    uatEntry.details(),
                                    prodEntry.details(),
                                    "MATCHED"
                            ));
                        } else {
                            unmatchedRows.add(csv(
                                    className,
                                    uatEntry.principal,
                                    uatEntry.details(),
                                    prodEntry.details(),
                                    "SECURITY_DIFFERENT"
                            ));
                        }

                    } else if (uatEntry != null) {

                        unmatchedRows.add(csv(
                                className,
                                uatEntry.principal,
                                uatEntry.details(),
                                "",
                                "ONLY_IN_UAT"
                        ));

                    } else {

                        unmatchedRows.add(csv(
                                className,
                                prodEntry.principal,
                                "",
                                prodEntry.details(),
                                "ONLY_IN_PROD"
                        ));
                    }
                }

                for (String row : matchedRows) {
                    writer.println(row);
                }

                for (String row : unmatchedRows) {
                    writer.println(row);
                }
            }
        }
    }

    private static String csv(
            String className,
            String principal,
            String uatSecurity,
            String prodSecurity,
            String status
    ) {
        return escape(className) + ","
                + escape(principal) + ","
                + escape(uatSecurity) + ","
                + escape(prodSecurity) + ","
                + escape(status);
    }

    private static String escape(String value) {
        if (value == null) {
            return "";
        }
        return "\"" + value.replace("\"", "\"\"") + "\"";
    }
}
