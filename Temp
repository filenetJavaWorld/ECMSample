package com.cnb.reports.p8;

import javax.security.auth.Subject;

import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.UserContext;
import com.ibm.ecm.extension.PluginServiceCallbacks;

public final class P8ContextUtil {

	private P8ContextUtil() {
	}

	/**
	 * Pushes the ICN user's P8 {@link Subject}, runs {@code work}, then pops the subject in a {@code finally} block.
	 */
	public static <T> T runWithP8Context(PluginServiceCallbacks callbacks, String repositoryId, P8Callback<T> work)
			throws Exception {
		if (repositoryId == null || repositoryId.trim().isEmpty()) {
			throw new IllegalArgumentException("repositoryId is required.");
		}
		Subject subject = callbacks.getP8Subject(repositoryId);
		ObjectStore objectStore = callbacks.getP8ObjectStore(repositoryId);
		if (subject == null || objectStore == null) {
			throw new IllegalStateException(
					"Cannot access repository '" + repositoryId + "'. Verify the desktop includes this P8 connection and you are logged in.");
		}
		UserContext.get().pushSubject(subject);
		try {
			return work.run(objectStore);
		} finally {
			UserContext.get().popSubject();
		}
	}

	public interface P8Callback<T> {
		T run(ObjectStore objectStore) throws Exception;
	}
}




package com.cnb.reports.p8;

import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

import com.filenet.api.property.Properties;

/**
 * Reads FileNet {@link Properties} using typed accessors. {@link Properties#get(String)} often returns a
 * {@code Property} wrapper; {@link String#valueOf(Object)} on that produces unusable grid / JSON text.
 */
public final class P8PropertyValues {

	private P8PropertyValues() {
	}

	public static String asString(Properties props, String name) {
		if (props == null || !props.isPropertyPresent(name)) {
			return "";
		}
		try {
			String s = props.getStringValue(name);
			return s != null ? s : "";
		} catch (Exception e) {
			try {
				Object o = props.getObjectValue(name);
				return o != null ? o.toString() : "";
			} catch (Exception e2) {
				return "";
			}
		}
	}

	/**
	 * Timestamp as plain text for {@link com.ibm.ecm.json.JSONResultSetRow} (matches typical ICN search display).
	 */
	public static String asDateTimeDisplay(Properties props, String name) {
		Date d = asDate(props, name);
		return d != null ? d.toString() : "";
	}

	/**
	 * Timestamp in UTC ISO-8601 for JSON metadata rows.
	 */
	public static String asDateTimeIsoUtc(Properties props, String name) {
		Date d = asDate(props, name);
		if (d == null) {
			return "";
		}
		SimpleDateFormat fmt = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss.SSS'Z'");
		fmt.setTimeZone(TimeZone.getTimeZone("UTC"));
		return fmt.format(d);
	}

	private static Date asDate(Properties props, String name) {
		if (props == null || !props.isPropertyPresent(name)) {
			return null;
		}
		try {
			return props.getDateTimeValue(name);
		} catch (Exception e) {
			try {
				Object o = props.getObjectValue(name);
				if (o instanceof Date) {
					return (Date) o;
				}
			} catch (Exception e2) {
				// ignore
			}
			return null;
		}
	}
}




