public final class ReportRequestDocumentHelper {

	private static final Charset UTF8 = Charset.forName("UTF-8");

	private ReportRequestDocumentHelper() {
	}

	public static JSONObject createReportRequestDocument(ObjectStore os, JSONObject payloadJson) throws Exception {
		String reportName = trim(payloadJson.get("reportName"));
		String reportRequestId = trim(payloadJson.get("reportRequestId"));
		if (reportRequestId == null || reportRequestId.length() == 0) {
			reportRequestId = UUID.randomUUID().toString();
			payloadJson.put("reportRequestId", reportRequestId);
		}

		String jsonText = payloadJson.serialize(true);
		byte[] bytes = jsonText.getBytes(UTF8);

		String retrievalName = ReportPluginConstants.JSON_FILENAME_PREFIX + reportRequestId
				+ ReportPluginConstants.JSON_FILENAME_SUFFIX;

		Document doc = Factory.Document.createInstance(os, ReportPluginConstants.REPORT_REQUEST_CLASS);
		Properties props = doc.getProperties();
		props.putValue("DocumentTitle", reportName);
		applyReportRequestMetadata(props, payloadJson);

		ContentTransfer ct = Factory.ContentTransfer.createInstance();
		ct.setCaptureSource(new ByteArrayInputStream(bytes));
		ct.set_RetrievalName(retrievalName);
		ct.set_ContentType(ReportPluginConstants.JSON_MIME_TYPE);

		ContentElementList cel = Factory.ContentElement.createList();
		cel.add(ct);
		doc.set_ContentElements(cel);
		doc.set_MimeType(ReportPluginConstants.JSON_MIME_TYPE);

		saveAsMajorVersion(doc);

		JSONObject out = new JSONObject();
		out.put("documentId", doc.get_Id().toString());
		out.put("reportRequestId", reportRequestId);
		return out;
	}

	private static JSONArray queryMyReportRequests(ObjectStore os, PluginServiceCallbacks callbacks, int maxResults)
			throws Exception {
		if (callbacks == null) {
			throw new IllegalArgumentException("callbacks is required.");
		}
		if (maxResults < 1) {
			maxResults = 1;
		}

		String sql = ReportPluginConstants.REPORT_REQUEST_LIST_SQL;

		PropertyFilter pf = newReportRequestListPropertyFilter();
		return fetchReportRequestRows(os, sql, maxResults, pf);
	}

	private static PropertyFilter newReportRequestListPropertyFilter() {
		PropertyFilter pf = new PropertyFilter();
		pf.addIncludeProperty(0, null, null, "This", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.ID, null);
		pf.addIncludeProperty(0, null, null, "DocumentTitle", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CREATOR, null);
		pf.addIncludeProperty(0, null, null, "DateCreated", null);
		pf.addIncludeProperty(0, null, null, "DateLastModified", null);
		pf.addIncludeProperty(0, null, null, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, null);
		pf.addIncludeProperty(0, null, null, "MimeType", null);
		return pf;
	}

	private static JSONArray fetchReportRequestRows(ObjectStore os, String sql, int maxRows, PropertyFilter pf)
			throws Exception {
		SearchSQL searchSQL = new SearchSQL(sql);
		SearchScope scope = new SearchScope(os);
		IndependentObjectSet set = scope.fetchObjects(searchSQL, maxRows, pf, Boolean.TRUE);
		JSONArray rows = new JSONArray();
		PageIterator pi = set.pageIterator();
		while (pi.nextPage()) {
			Object[] page = pi.getCurrentPage();
			if (page == null) {
				continue;
			}
			for (Object o : page) {
				if (!(o instanceof Document)) {
					continue;
				}
				rows.add(toListRow((Document) o));
			}
		}
		return rows;
	}

	private static JSONObject toListRow(Document d) {
		Properties p = d.getProperties();
		JSONObject row = new JSONObject();
		row.put("documentId", d.get_Id().toString());
		row.put("documentTitle", P8PropertyValues.asString(p, "DocumentTitle"));
		row.put("creator", P8PropertyValues.asString(p, PropertyNames.CREATOR));
		row.put("dateCreated", P8PropertyValues.asDateTimeIsoUtc(p, "DateCreated"));
		row.put("dateLastModified", P8PropertyValues.asDateTimeIsoUtc(p, "DateLastModified"));
		row.put("status", P8PropertyValues.asString(p, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS));
		row.put("contentType", ReportPluginConstants.JSON_MIME_TYPE);
		return row;
	}

	public static JSONObject updateReportRequestDocument(ObjectStore os, String documentId, JSONObject payloadJson)
			throws Exception {
		if (documentId == null || documentId.trim().isEmpty()) {
			throw new IllegalArgumentException("documentId is required.");
		}

		String reportRequestId = trim(payloadJson.get("reportRequestId"));
		if (reportRequestId == null || reportRequestId.length() == 0) {
			throw new IllegalArgumentException("reportRequestId is required to update report request content.");
		}
		payloadJson.put("reportRequestId", reportRequestId);

		String reportName = trim(payloadJson.get("reportName"));
		if (reportName == null) {
			throw new IllegalArgumentException("reportName is required.");
		}

		Document reservation = checkoutExclusiveReservation(os, documentId);
		Properties props = reservation.getProperties();
		props.putValue("DocumentTitle", reportName);
		applyReportRequestMetadata(props, payloadJson);
		replaceReservationJsonContent(reservation, payloadJson, reportRequestId);
		checkinReservationAsMajorVersion(reservation);

		JSONObject out = new JSONObject();
		out.put("documentId", reservation.get_Id().toString());
		out.put("reportRequestId", reportRequestId);
		return out;
	}

	/**
	 * Checks out the released document exclusively and returns its mutable reservation. Properties and content must
	 * only be updated on the reservation, not on the released document.
	 */
	private static Document checkoutExclusiveReservation(ObjectStore os, String documentId) throws Exception {
		Document existingDoc = Factory.Document.fetchInstance(os, new Id(documentId), null);
		assertPendingStatus(existingDoc);

		if (Boolean.TRUE.equals(existingDoc.get_IsReserved())) {
			throw new IllegalStateException(
					"Document is already checked out. Cannot update until it is checked in or checkout is cancelled.");
		}

		existingDoc.checkout(ReservationType.EXCLUSIVE, null, null, null);
		existingDoc.save(RefreshMode.REFRESH);

		Document reservation = (Document) existingDoc.get_Reservation();
		if (reservation == null) {
			throw new IllegalStateException(
					"Unable to obtain reservation after checkout for report request: " + documentId);
		}
		return reservation;
	}

	/**
	 * Replaces the reservation JSON payload using a new {@link ContentTransfer}, following the FileNet checkout/update
	 * pattern (content cannot be replaced on the released document).
	 */
	private static void replaceReservationJsonContent(Document reservation, JSONObject payloadJson, String reportRequestId)
			throws Exception {
		String jsonText = payloadJson.serialize(true);
		byte[] bytes = jsonText.getBytes(UTF8);
		String retrievalName = ReportPluginConstants.JSON_FILENAME_PREFIX + reportRequestId
				+ ReportPluginConstants.JSON_FILENAME_SUFFIX;

		ContentTransfer ct = Factory.ContentTransfer.createInstance();
		ct.setCaptureSource(new ByteArrayInputStream(bytes));
		ct.set_RetrievalName(retrievalName);
		ct.set_ContentType(ReportPluginConstants.JSON_MIME_TYPE);

		ContentElementList contentList = Factory.ContentElement.createList();
		contentList.add(ct);
		reservation.set_ContentElements(contentList);
		reservation.set_MimeType(ReportPluginConstants.JSON_MIME_TYPE);
	}

	private static void checkinReservationAsMajorVersion(Document reservation) {
		reservation.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
		reservation.save(RefreshMode.REFRESH);
	}

	private static void assertPendingStatus(Document doc) {
		String status = P8PropertyValues.asString(doc.getProperties(),
				ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS);
		if (!isPendingStatus(status)) {
			throw new IllegalStateException(
					"Only report requests in Pending status can be edited. Current status: " + status);
		}
	}

	private static boolean isPendingStatus(String status) {
		return status != null
				&& ReportPluginConstants.REPORT_REQUEST_INITIAL_STATUS.equalsIgnoreCase(status.trim());
	}

	public static JSONObject loadDocumentJson(ObjectStore os, String documentId) throws Exception {
		PropertyFilter pf = new PropertyFilter();
		pf.addIncludeProperty(0, null, null, PropertyNames.ID, null);
		pf.addIncludeProperty(0, null, null, "DocumentTitle", null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CREATOR, null);
		pf.addIncludeProperty(0, null, null, "DateCreated", null);
		pf.addIncludeProperty(0, null, null, "DateLastModified", null);
		pf.addIncludeProperty(0, null, null, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS, null);
		pf.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);

		Document doc = Factory.Document.fetchInstance(os, new Id(documentId), pf);
		JSONObject meta = new JSONObject();
		Properties mp = doc.getProperties();
		meta.put("documentId", doc.get_Id().toString());
		meta.put("documentTitle", P8PropertyValues.asString(mp, "DocumentTitle"));
		meta.put("creator", P8PropertyValues.asString(mp, PropertyNames.CREATOR));
		meta.put("dateCreated", P8PropertyValues.asDateTimeIsoUtc(mp, "DateCreated"));
		meta.put("dateLastModified", P8PropertyValues.asDateTimeIsoUtc(mp, "DateLastModified"));
		meta.put("status", P8PropertyValues.asString(mp, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS));

		JSONObject content = readFirstContentJson(doc);

		JSONObject out = new JSONObject();
		out.put("metadata", meta);
		out.put("reportRequest", content);
		return out;
	}

	public static JSONObject loadDocumentJsonByReportRequestId(ObjectStore os, PluginServiceCallbacks callbacks,
			String reportRequestId, int maxCandidates) throws Exception {
		JSONArray candidates = queryMyReportRequests(os, callbacks, maxCandidates);
		for (int i = 0; i < candidates.size(); i++) {
			JSONObject row = (JSONObject) candidates.get(i);
			String docId = trim(row.get("documentId"));
			if (docId == null) {
				continue;
			}
			try {
				JSONObject details = loadDocumentJson(os, docId);
				JSONObject rr = (JSONObject) details.get("reportRequest");
				if (rr != null && reportRequestId.equals(trim(rr.get("reportRequestId")))) {
					return details;
				}
			} catch (Exception e) {
				// skip unreadable rows
			}
		}
		return null;
	}

	private static JSONObject readFirstContentJson(Document doc) throws Exception {
		com.filenet.api.collection.ContentElementList cel = doc.get_ContentElements();
		if (cel == null || cel.size() == 0) {
			throw new IllegalStateException("Report request document has no content.");
		}
		Object first = cel.get(0);
		if (!(first instanceof ContentTransfer)) {
			throw new IllegalStateException("Unexpected content element type.");
		}
		ContentTransfer ct = (ContentTransfer) first;
		java.io.InputStream in = null;
		try {
			in = ct.accessContentStream();
			java.io.ByteArrayOutputStream bos = new java.io.ByteArrayOutputStream();
			byte[] buf = new byte[8192];
			int n;
			while ((n = in.read(buf)) != -1) {
				bos.write(buf, 0, n);
			}
			String text = bos.toString("UTF-8");
			Object parsed = JSON.parse(text);
			if (!(parsed instanceof JSONObject)) {
				throw new IllegalStateException("Report request content is not a JSON object.");
			}
			return (JSONObject) parsed;
		} finally {
			if (in != null) {
				try {
					in.close();
				} catch (Exception e) {
					// ignore
				}
			}
		}
	}

	/**
	 * Checks in as a major version so the document is released (not left in reservation) as version 1.0.
	 */
	private static void saveAsMajorVersion(Document doc) {
		doc.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
		doc.save(RefreshMode.REFRESH);
	}

	/**
	 * Sets {@link ReportPluginConstants} metadata on the new document. Full payload remains in JSON content.
	 */
	private static void applyReportRequestMetadata(Properties props, JSONObject payloadJson) throws Exception {
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_STATUS,
				ReportPluginConstants.REPORT_REQUEST_INITIAL_STATUS);

		String targetClass = trim(payloadJson.get("targetClassSymbolicName"));
		if (targetClass == null) {
			throw new IllegalArgumentException("targetClassSymbolicName is required to set TargetDocumentClass.");
		}
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_TARGET_DOCUMENT_CLASS, targetClass);

		String repositoryName = resolveRepositoryName(payloadJson);
		putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_REPOSITORY_NAME, repositoryName);

		Object critObj = payloadJson.get("criteria");
		JSONArray criteria = critObj instanceof JSONArray ? (JSONArray) critObj : new JSONArray();
		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEARCH_CRITERIA_PARAMS,
				buildSearchCriteriaParams(criteria));

		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_RESULT_SET_COLUMNS,
				buildResultSetColumns(payloadJson));

		String sqlQuery = trim(payloadJson.get("sqlQuery"));
		if (sqlQuery != null) {
			putStringProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SQL_QUERY, sqlQuery);
		}

		boolean sendEmails = resolveSendEmails(payloadJson);
		putBooleanProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEND_EMAILS, sendEmails);
		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEND_EMAIL_TO,
				sendEmails ? buildEmailList(payloadJson, ReportPluginConstants.JSON_SEND_EMAIL_TO) : new String[0]);
		putStringListProperty(props, ReportPluginConstants.REPORT_REQUEST_PROPERTY_SEND_EMAIL_CC,
				sendEmails ? buildEmailList(payloadJson, ReportPluginConstants.JSON_SEND_EMAIL_CC) : new String[0]);
	}

	private static boolean resolveSendEmails(JSONObject payloadJson) {
		Object raw = payloadJson.get(ReportPluginConstants.JSON_SEND_EMAILS);
		if (raw == null) {
			raw = payloadJson.get("sendEmail");
		}
		if (raw == null) {
			return true;
		}
		if (raw instanceof Boolean) {
			return ((Boolean) raw).booleanValue();
		}
		String text = trim(raw);
		if (text == null) {
			return true;
		}
		return "true".equalsIgnoreCase(text) || "yes".equalsIgnoreCase(text) || "1".equals(text);
	}

	private static String[] buildEmailList(JSONObject payloadJson, String jsonKey) {
		List<String> emails = new ArrayList<String>();
		Object raw = payloadJson.get(jsonKey);
		if (!(raw instanceof JSONArray)) {
			return new String[0];
		}
		JSONArray arr = (JSONArray) raw;
		java.util.HashSet<String> seen = new java.util.HashSet<String>();
		for (int i = 0; i < arr.size(); i++) {
			String email = trim(arr.get(i));
			if (email == null || !EmailValidator.isValid(email)) {
				continue;
			}
			String key = email.toLowerCase();
			if (seen.add(key)) {
				emails.add(email);
			}
		}
		return emails.toArray(new String[emails.size()]);
	}

	private static String resolveRepositoryName(JSONObject payloadJson) {
		String name = trim(payloadJson.get("repositoryName"));
		if (name != null) {
			return name;
		}
		name = trim(payloadJson.get("objectStoreName"));
		return name != null ? name : "";
	}

	private static String[] buildSearchCriteriaParams(JSONArray criteria) {
		List<String> entries = new ArrayList<String>();
		if (criteria == null) {
			return new String[0];
		}
		for (int i = 0; i < criteria.size(); i++) {
			Object row = criteria.get(i);
			if (!(row instanceof JSONObject)) {
				continue;
			}
			JSONObject c = (JSONObject) row;
			String prop = trim(c.get("propertySymbolicName"));
			String operator = trim(c.get("operator"));
			if (prop == null || operator == null) {
				continue;
			}
			String valuesPart = formatCriteriaValues(c.get("values"));
			entries.add(prop + "|" + operator + "|" + valuesPart);
		}
		return entries.toArray(new String[entries.size()]);
	}

	private static String formatCriteriaValues(Object valuesObj) {
		if (!(valuesObj instanceof JSONArray)) {
			return "";
		}
		JSONArray vals = (JSONArray) valuesObj;
		List<String> parts = new ArrayList<String>();
		for (int i = 0; i < vals.size(); i++) {
			Object v = vals.get(i);
			if (v == null) {
				continue;
			}
			String s = String.valueOf(v).trim();
			if (s.length() > 0) {
				parts.add(s);
			}
		}
		if (parts.isEmpty()) {
			return "";
		}
		StringBuilder sb = new StringBuilder();
		for (int i = 0; i < parts.size(); i++) {
			if (i > 0) {
				sb.append(',');
			}
			sb.append(parts.get(i));
		}
		return sb.toString();
	}

	private static String[] buildResultSetColumns(JSONObject payloadJson) {
		List<String> columns = new ArrayList<String>();
		Object rdObj = payloadJson.get("resultDisplay");
		if (!(rdObj instanceof JSONObject)) {
			return new String[0];
		}
		Object colsObj = ((JSONObject) rdObj).get("columns");
		if (!(colsObj instanceof JSONArray)) {
			return new String[0];
		}
		JSONArray cols = (JSONArray) colsObj;
		for (int i = 0; i < cols.size(); i++) {
			Object col = cols.get(i);
			if (col instanceof JSONObject) {
				String sym = trim(((JSONObject) col).get("propertySymbolicName"));
				if (sym != null) {
					columns.add(sym);
				}
			} else if (col != null) {
				String sym = String.valueOf(col).trim();
				if (sym.length() > 0) {
					columns.add(sym);
				}
			}
		}
		return columns.toArray(new String[columns.size()]);
	}

	private static void putBooleanProperty(Properties props, String propertyName, boolean value) throws Exception {
		try {
			props.putValue(propertyName, value);
		} catch (RuntimeException e) {
			throw metadataAssignmentError(propertyName, e);
		}
	}

	private static void putStringProperty(Properties props, String propertyName, String value) throws Exception {
		try {
			props.putValue(propertyName, value != null ? value : "");
		} catch (RuntimeException e) {
			throw metadataAssignmentError(propertyName, e);
		}
	}

	private static void putStringListProperty(Properties props, String propertyName, String[] values) throws Exception {
		try {
			StringList list = Factory.StringList.createList();
			if (values != null) {
				for (String v : values) {
					if (v != null && v.length() > 0) {
						list.add(v);
					}
				}
			}
			props.putValue(propertyName, list);
		} catch (RuntimeException e) {
			throw metadataAssignmentError(propertyName, e);
		}
	}

	private static IllegalStateException metadataAssignmentError(String propertyName, RuntimeException cause) {
		String detail = cause.getMessage() != null ? cause.getMessage() : cause.toString();
		return new IllegalStateException(
				"Failed to set ReportRequest property '" + propertyName + "': " + detail
						+ ". Verify the property exists on class ReportRequest and the user has write access.",
				cause);
	}

	private static String trim(Object o) {
		if (o == null) {
			return null;
		}
		String s = String.valueOf(o).trim();
		return s.length() == 0 ? null : s;
	}
}



