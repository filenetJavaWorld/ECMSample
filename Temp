define([
	"dojo/_base/declare",
	"dijit/layout/BorderContainer",
	"dijit/layout/ContentPane",
	"dijit/layout/TabContainer",
	"ecm/widget/layout/_LaunchBarPane",
	"dojo/text!./templates/RepoMetadataExportFeature.html",
	"./widgets/DocumentClassExportTab"
], function(declare, BorderContainer, ContentPane, TabContainer, _LaunchBarPane, template,
	DocumentClassExportTab) {
	/**
	 * @name cNBRepoMetadataExportPluginDojo.RepoMetadataExportFeature
	 * @class Repository Metadata Export feature pane (Phase 1 UI).
	 * @augments ecm.widget.layout._LaunchBarPane
	 */
	return declare("cNBRepoMetadataExportPluginDojo.RepoMetadataExportFeature", [
		_LaunchBarPane
	], {
		/** @lends cNBRepoMetadataExportPluginDojo.RepoMetadataExportFeature.prototype */

		templateString: template,
		widgetsInTemplate: true,

		postCreate: function() {
			this.logEntry("postCreate");
			this.inherited(arguments);
			this.logExit("postCreate");
		},

		/**
		 * Optional method that sets additional parameters when the user clicks on the launch button associated with
		 * this feature.
		 */
		setParams: function(params) {
			this.logEntry("setParams", params);
			if (params) {
				if (!this.isLoaded && this.selected) {
					this.loadContent();
				}
			}
			this.logExit("setParams");
		},

		/**
		 * Loads the content of the pane. This is a required method to insert a pane into the LaunchBarContainer.
		 */
		loadContent: function() {
			this.logEntry("loadContent");
			if (!this.isLoaded) {
				if (this.documentClassExportTab && this.documentClassExportTab.loadContent) {
					this.documentClassExportTab.loadContent();
				}
				this.isLoaded = true;
				this.needReset = false;
			}
			if (this.borderContainer) {
				this.borderContainer.resize();
			}
			if (this.tabContainer) {
				this.tabContainer.resize();
			}
			this.logExit("loadContent");
		},

		/**
