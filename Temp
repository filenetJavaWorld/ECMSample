ALTER PROCEDURE [dbo].[sp_IndexAndBatchClaimDocuments]
    @claimNumber NVARCHAR(100),
    @ccExtractFileName NVARCHAR(500),
    @setDocCount INT = 25,
    @forceSingleSet BIT = 0,
    @batchIDPrefix NVARCHAR(50) = 'WW',
    @jobIDPrefix NVARCHAR(50) = 'Migrate',
    @batchIDsCreated NVARCHAR(MAX) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @batchID NVARCHAR(100);
    DECLARE @jobID NVARCHAR(100);
    DECLARE @totalDocs INT;

    -- Generate Batch & Job ID
    SET @batchID = @batchIDPrefix + FORMAT(GETDATE(), 'yyyyMMddHHmmssfff');
    SET @jobID = @jobIDPrefix + @batchID;

    -- Count eligible rows
    SELECT @totalDocs = COUNT(*)
    FROM CC_Extract_Staging
    WHERE claimNumber = @claimNumber
      AND CC_Extract_file_Name = @ccExtractFileName
      AND claimID IS NOT NULL
      AND gwDocumentID IS NOT NULL
      AND isDataMerged = 1
      AND contentFilePath IS NOT NULL
      AND isIndexed = 0
      AND isProcessed = 0;

    IF @totalDocs = 0
    BEGIN
        SET @batchIDsCreated = '';
        RETURN 0;
    END;

    ;WITH OrderedDocs AS
    (
        SELECT 
            externalID,
            ROW_NUMBER() OVER (ORDER BY externalID) AS rowNum
        FROM CC_Extract_Staging
        WHERE claimNumber = @claimNumber
          AND CC_Extract_file_Name = @ccExtractFileName
          AND claimID IS NOT NULL
          AND gwDocumentID IS NOT NULL
          AND isDataMerged = 1
          AND contentFilePath IS NOT NULL
          AND isIndexed = 0
          AND isProcessed = 0
    )
    UPDATE s
    SET 
        s.batchID = @batchID,
        s.jobID = @jobID,
        s.batchDocCount = @totalDocs,
        s.setID = ((o.rowNum - 1) / @setDocCount) + 1,
        s.setDocCount = CASE 
                            WHEN ((o.rowNum - 1) / @setDocCount) + 1 =
                                 CEILING(CAST(@totalDocs AS FLOAT) / @setDocCount)
                            THEN @totalDocs - 
                                 ((CEILING(CAST(@totalDocs AS FLOAT) / @setDocCount) - 1) * @setDocCount)
                            ELSE @setDocCount
                        END,
        s.setDocIndex = ((o.rowNum - 1) % @setDocCount) + 1,
        s.isIndexed = 1
    FROM CC_Extract_Staging s
    INNER JOIN OrderedDocs o
        ON s.externalID = o.externalID;

    SET @batchIDsCreated = @batchID;

    RETURN @totalDocs;
END;
