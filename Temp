	function resolveDocumentId(item) {
		if (!item) {
			return null;
		}
		var id = item.id;
		if (!id) {
			return null;
		}
		var parts = String(id).split(",");
		if (parts.length >= 3) {
			return parts[2];
		}
		return String(id);
	}

	function resolveItemStatus(item) {
		if (!item) {
			return "";
		}
		var status = null;
		if (item.getValue) {
			status = item.getValue("Status");
		}
		if (status == null && item.attributes) {
			status = item.attributes.Status;
		}
		if (status == null && item.getDisplayValue) {
			status = item.getDisplayValue("Status");
		}
		return status != null ? String(status).trim() : "";
	}

	function isPendingStatus(status) {
		return status != null && String(status).toLowerCase() === "pending";
	}

	function showError(message) {
		new MessageDialog({
			text: message
		}).show();
	}

	lang.setObject("editReportRequest", function(repository, items, callback, teamspace, resultSet, parameterMap) {
		if (!repository) {
			showError("Select a repository.");
			return;
		}
		if (!items || items.length !== 1) {
			showError("Select exactly one report request to edit.");
			return;
		}

		var item = items[0];
		var status = resolveItemStatus(item);
		if (!isPendingStatus(status)) {
			showError("Only report requests in Pending status can be edited.");
			return;
		}

		var documentId = resolveDocumentId(item);
		if (!documentId) {
			showError("Unable to determine the report request document id.");
			return;
		}

		reportService.getReportRequestDetails(repository.id, documentId, null, function(response) {
			var details = response.details || {};
			var metaStatus = details.metadata ? details.metadata.status : null;
			if (metaStatus && !isPendingStatus(metaStatus)) {
				showError("Only report requests in Pending status can be edited.");
				return;
			}

			var dlg = new ReportRequestDialog({
				repository: repository,
				editMode: true,
				documentId: documentId,
				details: details,
				style: "width: 90%; height: 90%;"
			});
			dlg.onSubmitted = function() {
				if (resultSet && lang.isFunction(resultSet.refresh)) {
					resultSet.refresh();
				}
				if (lang.isFunction(callback)) {
					callback({
						items: items
					});
				}
			};
			dlg.show();
