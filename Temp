define([
	"dojo/_base/lang"
], function(lang) {

	var BLANK_GIF = require.toUrl("dojo/resources/blank.gif");

	/**
	 * Grid cell decorator for {@code reportDownload} column. Shows download icon when the row is Completed.
	 */
	var ReportDownloadDecorator = {
		DOWNLOAD_FIELD: "reportDownload",
		DOWNLOAD_TOKEN: "download",
		STATUS_FIELD: "Status",
		STATUS_COMPLETED: "completed",

		/**
		 * Invoked with {@code this} = {@code ecm.widget.listView.ContentList}.
		 */
		decorateCell: function(data, rowId, rowIndex) {
			if (!ReportDownloadDecorator.shouldShowDownload(this, data, rowId)) {
				return "&nbsp;";
			}
			return "<img role=\"button\" class=\"ecmMimeTypeIcon ecmDownloadIcon cnbReportDownloadIcon\" "
				+ "alt=\"Download report\" title=\"Download report\" tabindex=\"0\" src=\"" + BLANK_GIF + "\" />";
		},

		/**
		 * @param contentList {@code ecm.widget.listView.ContentList}
		 */
		shouldShowDownload: function(contentList, data, rowId) {
			if (ReportDownloadDecorator.cellShowsDownload(data)) {
				return true;
			}
			if (!contentList || !contentList.grid || !rowId) {
				return false;
			}
			try {
				var item = contentList.grid.row(rowId).item();
				if (!item || !item.attributes) {
					return false;
				}
				var status = item.attributes[ReportDownloadDecorator.STATUS_FIELD];
				if (status == null && item.getValue) {
					status = item.getValue(ReportDownloadDecorator.STATUS_FIELD);
				}
				if (status == null && item.getDisplayValue) {
					status = item.getDisplayValue(ReportDownloadDecorator.STATUS_FIELD);
				}
				return status != null
					&& String(status).trim().toLowerCase() === ReportDownloadDecorator.STATUS_COMPLETED;
			} catch (e) {
				return false;
			}
		},

		cellShowsDownload: function(data) {
			if (data === ReportDownloadDecorator.DOWNLOAD_TOKEN) {
				return true;
			}
			if (data != null && typeof data === "object") {
				return false;
			}
			var text = data != null ? String(data).trim() : "";
			return text.toLowerCase() === ReportDownloadDecorator.DOWNLOAD_TOKEN;
		}
	};

	lang.setObject("cNBReportsPluginDojo.ReportDownloadDecorator", ReportDownloadDecorator);

	return ReportDownloadDecorator;
});



