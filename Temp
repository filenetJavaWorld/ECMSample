	"dijit/form/CheckBox",
	"dojo/text!./templates/PropertyOptionsPane.html"
], function(array, declare, lang, domConstruct, _TemplatedMixin, _WidgetBase, _WidgetsInTemplateMixin, Button,
	CheckBox, template) {

	/** Column definitions: key matches Phase 1/2 payload selectedColumns values. */
	var PROPERTY_OPTIONS = [
		{
			key: "documentClassDisplayName",
			label: "Document Class Display Name",
			defaultSelected: false
		},
		{
			key: "documentClassSymbolicName",
			label: "Document Class Symbolic Name",
			defaultSelected: false
		},
		{
			key: "propertyDisplayName",
			label: "Property Display Name",
			defaultSelected: true
		},
		{
			key: "propertySymbolicName",
			label: "Property Symbolic Name",
			defaultSelected: true
		},
		{
			key: "propertyDescription",
			label: "Property Description",
			defaultSelected: false
		},
		{
			key: "dataType",
			label: "Data Type",
			defaultSelected: true
		},
		{
			key: "cardinality",
			label: "Cardinality",
			defaultSelected: true
		},
		{
			key: "required",
			label: "Required",
			defaultSelected: true
		},
		{
			key: "searchable",
			label: "Searchable",
			defaultSelected: false
		},
		{
			key: "hidden",
			label: "Hidden",
			defaultSelected: false
		},
		{
			key: "inherited",
			label: "Inherited",
			defaultSelected: false
		},
		{
			key: "settability",
			label: "Settability",
			defaultSelected: false
		},
		{
			key: "maximumLength",
			label: "Maximum Length",
			defaultSelected: false
		},
		{
			key: "minimumValue",
			label: "Minimum Value",
			defaultSelected: false
		},
		{
			key: "maximumValue",
			label: "Maximum Value",
			defaultSelected: false
		},
		{
			key: "defaultValue",
			label: "Default Value",
			defaultSelected: false
		},
		{
			key: "choiceListAssigned",
			label: "Choice List Assigned",
			defaultSelected: true
		},
		{
			key: "choiceListName",
			label: "Choice List Name",
			defaultSelected: true
		},
		{
			key: "choiceListSymbolicName",
			label: "Choice List Symbolic Name",
			defaultSelected: false
		}
	];

	return declare("cNBRepoMetadataExportPluginDojo.widgets.PropertyOptionsPane", [
		_WidgetBase,
		_TemplatedMixin,
		_WidgetsInTemplateMixin
	], {
		templateString: template,
		widgetsInTemplate: true,

		_checkboxesByKey: null,
		_optionDefs: null,

		postCreate: function() {
			this.inherited(arguments);
			this._checkboxesByKey = {};
			this._optionDefs = PROPERTY_OPTIONS;
			this._buildCheckboxes();
			this.own(this.selectAllButton.on("click", lang.hitch(this, "selectAll")));
			this.own(this.clearAllButton.on("click", lang.hitch(this, "clearAll")));
		},

		_buildCheckboxes: function() {
			domConstruct.empty(this.optionsContainer);
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var row = domConstruct.create("div", {
					"class": "cnbRmeCheckboxRow"
				}, this.optionsContainer);
				var cb = new CheckBox({
					checked: !!opt.defaultSelected,
					value: opt.key
				});
				this.own(cb);
				cb.placeAt(row);
				this.own(cb.on("change", lang.hitch(this, function() {
					this.onSelectionChange();
				})));
				domConstruct.create("label", {
					"for": cb.id,
					innerHTML: opt.label,
					"class": "cnbRmeCheckboxLabel"
				}, row);
				this._checkboxesByKey[opt.key] = cb;
			}));
		},

		selectAll: function() {
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var cb = this._checkboxesByKey[opt.key];
				if (cb) {
					cb.set("checked", true);
				}
			}));
			this.onSelectionChange();
		},

		clearAll: function() {
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var cb = this._checkboxesByKey[opt.key];
				if (cb) {
					cb.set("checked", false);
				}
			}));
			this.onSelectionChange();
		},

		restoreDefaults: function() {
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var cb = this._checkboxesByKey[opt.key];
				if (cb) {
					cb.set("checked", !!opt.defaultSelected);
				}
			}));
			this.onSelectionChange();
		},

		getSelectedColumns: function() {
			var selected = [];
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var cb = this._checkboxesByKey[opt.key];
				if (cb && cb.get("checked")) {
					selected.push(opt.key);
				}
			}));
			return selected;
		},

		getSelectedCount: function() {
			return this.getSelectedColumns().length;
		},

		setDisabled: function(disabled) {
			array.forEach(this._optionDefs, lang.hitch(this, function(opt) {
				var cb = this._checkboxesByKey[opt.key];
				if (cb) {
					cb.set("disabled", !!disabled);
				}
			}));
			this.selectAllButton.set("disabled", !!disabled);
			this.clearAllButton.set("disabled", !!disabled);
		},

		/** Extension point fired when checkbox selection changes. */
		onSelectionChange: function() {
		}
	});
});





