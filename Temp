package com.cnb.reports.mail;

import java.util.List;
import java.util.Properties;

import javax.mail.Message;
import javax.mail.Session;
import javax.mail.Transport;
import javax.mail.internet.InternetAddress;
import javax.mail.internet.MimeMessage;

import com.ibm.ecm.extension.PluginServiceCallbacks;

public final class SmtpEmailSender {

	private final MailConfig config;
	private final PluginServiceCallbacks callbacks;

	public SmtpEmailSender(MailConfig config, PluginServiceCallbacks callbacks) {
		this.config = config;
		this.callbacks = callbacks;
	}

	public void send(String subject, String body, List<String> toRecipients, List<String> ccRecipients)
			throws Exception {
		if (!config.isMailEnabled()) {
			logInfo("Mail disabled. Skipping email with subject '" + subject + "'.");
			return;
		}

		List<String> to = EmailValidator.normalizeList(toRecipients);
		if (to.isEmpty()) {
			logInfo("No valid SendEmailTo recipients. Skipping email with subject '" + subject + "'.");
			return;
		}

		Session session = Session.getInstance(buildMailProperties(), null);
		MimeMessage message = new MimeMessage(session);
		message.setFrom(new InternetAddress(config.getMailFromAddress(), config.getMailFromName()));
		for (int i = 0; i < to.size(); i++) {
			message.addRecipient(Message.RecipientType.TO, new InternetAddress(to.get(i)));
		}
		List<String> cc = EmailValidator.normalizeList(ccRecipients);
		for (int i = 0; i < cc.size(); i++) {
			message.addRecipient(Message.RecipientType.CC, new InternetAddress(cc.get(i)));
		}
		message.setSubject(subject, "UTF-8");
		message.setText(body, "UTF-8");

		Transport transport = session.getTransport("smtp");
		try {
			if (config.isMailSmtpAuth()) {
				transport.connect(config.getMailSmtpHost(), config.getMailSmtpPort(),
						config.getMailSmtpUsername(), config.getMailSmtpPassword());
			} else {
				transport.connect();
			}
			transport.sendMessage(message, message.getAllRecipients());
			logInfo("Sent email '" + subject + "' to " + to);
		} finally {
			transport.close();
		}
	}

	private Properties buildMailProperties() {
		Properties props = new Properties();
		props.put("mail.smtp.host", config.getMailSmtpHost());
		props.put("mail.smtp.port", String.valueOf(config.getMailSmtpPort()));
		props.put("mail.smtp.auth", String.valueOf(config.isMailSmtpAuth()));
		props.put("mail.smtp.starttls.enable", String.valueOf(config.isMailSmtpStartTlsEnable()));
		return props;
	}

	private void logInfo(String message) {
		if (callbacks != null && callbacks.getLogger() != null) {
			callbacks.getLogger().logInfo(this, "send", null, message);
		}
	}
}



package com.cnb.reports.p8;

import javax.security.auth.Subject;

import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.UserContext;
import com.ibm.ecm.extension.PluginServiceCallbacks;


public final class P8ContextUtil {

	private P8ContextUtil() {
	}

	/**
	 * Pushes the ICN user's P8 {@link Subject}, runs {@code work}, then pops the subject in a {@code finally} block.
	 */
	public static <T> T runWithP8Context(PluginServiceCallbacks callbacks, String repositoryId, P8Callback<T> work)
			throws Exception {
		if (repositoryId == null || repositoryId.trim().isEmpty()) {
			throw new IllegalArgumentException("repositoryId is required.");
		}
		Subject subject = callbacks.getP8Subject(repositoryId);
		ObjectStore objectStore = callbacks.getP8ObjectStore(repositoryId);
		if (subject == null || objectStore == null) {
			throw new IllegalStateException(
					"Cannot access repository '" + repositoryId + "'. Verify the desktop includes this P8 connection and you are logged in.");
		}
		UserContext.get().pushSubject(subject);
		try {
			return work.run(objectStore);
		} finally {
			UserContext.get().popSubject();
		}
	}

	public interface P8Callback<T> {
		T run(ObjectStore objectStore) throws Exception;
	}
}




package com.cnb.reports.p8;

import java.io.ByteArrayInputStream;
import java.nio.charset.Charset;
import java.util.ArrayList;
import java.util.List;
