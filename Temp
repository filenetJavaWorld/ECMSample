package com.filenet.loadtest.search;

import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import com.filenet.loadtest.model.SearchQueryConfig;
import com.filenet.loadtest.util.DateTimeUtil;
import com.filenet.loadtest.util.SqlEscapeUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.Date;

/**
 * Executes FileNet searches for load testing.
 */
public class SearchExecutor {

    private static final Logger LOG = LogManager.getLogger(SearchExecutor.class);

    private final ObjectStore objectStore;

    public SearchExecutor(ObjectStore objectStore) {
        this.objectStore = objectStore;
    }

    /**
     * Executes a configured search and returns the number of results.
     *
     * @param query search query configuration
     * @return result count
     * @throws Exception if search execution fails
     */
    public int executeSearch(SearchQueryConfig query) throws Exception {
        SearchSQL searchSQL = buildSearchSql(query);
        LOG.debug("Executing search SQL: {}", searchSQL.toString());

        SearchScope searchScope = new SearchScope(objectStore);
        IndependentObjectSet resultSet = searchScope.fetchObjects(searchSQL, null, null, Boolean.TRUE);

        int count = 0;
        PageIterator pageIterator = resultSet.pageIterator();
        if (pageIterator.nextPage()) {
            Integer totalCount = pageIterator.getTotalCount();
            if (totalCount != null) {
                return totalCount;
            }
            count += pageIterator.getCurrentPage().length;
            while (pageIterator.nextPage()) {
                count += pageIterator.getCurrentPage().length;
            }
        }

        LOG.debug("Search {} returned {} results", query.getSearchType(), count);
        return count;
    }

    private SearchSQL buildSearchSql(SearchQueryConfig query) throws Exception {
        SearchSQL searchSQL = new SearchSQL();
        searchSQL.setSelectList("Id, DocumentTitle");
        searchSQL.setFromClauseInitialValue(query.getClassName(), null, true);

        String whereClause = buildWhereClause(query);
        if (whereClause != null && !whereClause.isEmpty()) {
            searchSQL.setWhereClause(whereClause);
        }

        return searchSQL;
    }

    private String buildWhereClause(SearchQueryConfig query) throws Exception {
        switch (query.getSearchType()) {
            case TITLE:
                return "DocumentTitle = '" + SqlEscapeUtil.escape(query.getSearchValue()) + "'";

            case PROPERTY:
                validateProperty(query);
                return query.getPropertyName() + " = '"
                        + SqlEscapeUtil.escape(query.getSearchValue()) + "'";

            case CLASS:
                return null;

            case DATE:
                validateProperty(query);
                Date date = DateTimeUtil.parseDate(query.getSearchValue());
                long timestamp = date.getTime();
                return query.getPropertyName() + " = " + timestamp;

            case MULTIVALUE:
                validateProperty(query);
                return query.getPropertyName() + " = '"
                        + SqlEscapeUtil.escape(query.getSearchValue()) + "'";

            default:
                throw new IllegalArgumentException("Unsupported search type: " + query.getSearchType());
        }
    }

    private void validateProperty(SearchQueryConfig query) {
        if (query.getPropertyName() == null || query.getPropertyName().trim().isEmpty()) {
            throw new IllegalArgumentException("PropertyName is required for search type: "
                    + query.getSearchType());
        }
        if (query.getSearchValue() == null || query.getSearchValue().trim().isEmpty()) {
            throw new IllegalArgumentException("SearchValue is required for search type: "
                    + query.getSearchType());
        }
    }
}



package com.filenet.loadtest.search;

import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.csv.CsvDataReader;
import com.filenet.loadtest.metrics.MetricsCollector;
import com.filenet.loadtest.model.PerformanceSummary;
import com.filenet.loadtest.model.SearchQueryConfig;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.List;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.TimeUnit;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * Orchestrates concurrent search load testing using a fixed thread pool.
 */
public class SearchOrchestrator {

    private static final Logger LOG = LogManager.getLogger(SearchOrchestrator.class);

    private final AppConfig config;

    public SearchOrchestrator(AppConfig config) {
        this.config = config;
    }

    /**
     * Executes the search load test if enabled in configuration.
     *
     * @return performance summary, or null if search is disabled
     * @throws Exception if orchestration fails
     */
    public PerformanceSummary execute() throws Exception {
        if (!config.isSearchEnabled()) {
            LOG.info("Search load testing is disabled (search.enabled=false)");
            return null;
        }

        List<SearchQueryConfig> searchQueries = CsvDataReader.readSearchConfig(config.getSearchConfigFile());
        if (searchQueries.isEmpty()) {
            throw new IllegalStateException("No search queries configured in " + config.getSearchConfigFile());
        }

        int threadCount = config.getSearchThreadCount();
        LOG.info("Starting search load test - Queries: {}, Threads: {}, Iterations per thread: {}",
                searchQueries.size(), threadCount, config.getSearchIterations());

        MetricsCollector metricsCollector = new MetricsCollector();
        AtomicInteger iterationCounter = new AtomicInteger(0);

        ExecutorService executorService = Executors.newFixedThreadPool(threadCount);

        long startMs = System.currentTimeMillis();

        for (int i = 0; i < threadCount; i++) {
            executorService.submit(new SearchWorker(config, searchQueries, metricsCollector, iterationCounter));
        }

        executorService.shutdown();
        boolean finished = executorService.awaitTermination(Long.MAX_VALUE, TimeUnit.NANOSECONDS);
        if (!finished) {
            LOG.warn("Search executor did not terminate cleanly");
        }

        long totalExecutionMs = System.currentTimeMillis() - startMs;

        metricsCollector.writeSearchMetrics(config.getSearchMetricsOutputFile());
        PerformanceSummary summary = metricsCollector.buildSearchSummary(totalExecutionMs);
        summary.printSummary();

        LOG.info("Search load test completed");
        return summary;
    }
}




package com.filenet.loadtest.search;

import com.filenet.loadtest.config.AppConfig;
import com.filenet.loadtest.connection.FileNetSession;
import com.filenet.loadtest.metrics.MetricsCollector;
import com.filenet.loadtest.model.SearchMetricRecord;
import com.filenet.loadtest.model.SearchQueryConfig;
import com.filenet.loadtest.util.DateTimeUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.List;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * Worker thread that repeatedly executes configured searches using its own FileNet session.
 */
public class SearchWorker implements Runnable {

    private static final Logger LOG = LogManager.getLogger(SearchWorker.class);

    private final AppConfig config;
    private final List<SearchQueryConfig> searchQueries;
    private final MetricsCollector metricsCollector;
    private final AtomicInteger iterationCounter;

    public SearchWorker(AppConfig config, List<SearchQueryConfig> searchQueries,
                        MetricsCollector metricsCollector, AtomicInteger iterationCounter) {
        this.config = config;
        this.searchQueries = searchQueries;
        this.metricsCollector = metricsCollector;
        this.iterationCounter = iterationCounter;
    }

    @Override
    public void run() {
        String threadName = Thread.currentThread().getName();
        LOG.info("Search thread started: {}", threadName);

        try {
            try (FileNetSession session = FileNetSession.create(config)) {
                SearchExecutor searchExecutor = new SearchExecutor(session.getObjectStore());

                for (int iteration = 1; iteration <= config.getSearchIterations(); iteration++) {
                    for (SearchQueryConfig query : searchQueries) {
                        executeSearch(threadName, iteration, query, searchExecutor);
                    }
                    iterationCounter.incrementAndGet();
                }
            }
        } catch (Throwable ex) {
            LOG.error("Search thread {} failed: {} - {}", threadName, ex.getClass().getName(), ex.getMessage(), ex);
        } finally {
            LOG.info("Search thread completed: {}", threadName);
        }
    }

    private void executeSearch(String threadName, int iteration, SearchQueryConfig query,
                               SearchExecutor searchExecutor) {
        long startMs = System.currentTimeMillis();
        String startTime = DateTimeUtil.formatTimestamp(startMs);
        String status = "SUCCESS";
        String errorMessage = "";
        int resultCount = 0;

        try {
            resultCount = searchExecutor.executeSearch(query);
            LOG.debug("Search completed - Thread: {}, Type: {}, Results: {}",
                    threadName, query.getSearchType(), resultCount);
        } catch (Exception ex) {
            status = "FAILED";
            errorMessage = ex.getMessage() != null ? ex.getMessage() : ex.getClass().getSimpleName();
            LOG.error("Search failed - Thread: {}, Type: {}, Class: {}: {}",
                    threadName, query.getSearchType(), query.getClassName(), errorMessage, ex);
        }

        long endMs = System.currentTimeMillis();
        String endTime = DateTimeUtil.formatTimestamp(endMs);

        metricsCollector.recordSearch(new SearchMetricRecord(
                threadName,
                query.getSearchType().name(),
                query.getClassName(),
                query.getPropertyName(),
                query.getSearchValue(),
                iteration,
                resultCount,
                endMs - startMs,
                status,
                errorMessage,
                startTime,
                endTime
        ));
    }
}



