package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.model.ResultColumn;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;
import org.apache.poi.ss.usermodel.Cell;
import org.apache.poi.ss.usermodel.Row;
import org.apache.poi.ss.usermodel.Sheet;
import org.apache.poi.xssf.streaming.SXSSFWorkbook;

import java.io.OutputStream;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.List;
import java.util.Map;
import java.util.concurrent.atomic.AtomicInteger;
import java.util.concurrent.atomic.AtomicLong;
import java.util.function.Consumer;

/**
 * Streams query results into an Excel workbook using Apache POI SXSSF.
 */
public final class ExcelReportWriter {

    private static final Logger LOGGER = LogManager.getLogger(ExcelReportWriter.class);

    private final AppConfig config;

    public ExcelReportWriter(AppConfig config) {
        this.config = config;
    }

    public WriteResult writeReport(Path outputFile, String reportName, List<ResultColumn> columns,
            Consumer<Consumer<Map<String, Object>>> rowSource) throws Exception {
        Files.createDirectories(outputFile.getParent());
        int maxRowsPerSheet = config.getExcelMaxRowsPerSheet();
        AtomicLong totalRows = new AtomicLong();
        AtomicInteger sheetIndex = new AtomicInteger(1);
        AtomicInteger rowsOnSheet = new AtomicInteger(maxRowsPerSheet);

        try (SXSSFWorkbook workbook = new SXSSFWorkbook(200);
                OutputStream out = Files.newOutputStream(outputFile)) {
            Sheet[] currentSheet = new Sheet[] { createSheet(workbook, sheetIndex.get()) };
            writeHeader(currentSheet[0], columns);
            rowsOnSheet.set(0);

            rowSource.accept(row -> {
                if (rowsOnSheet.get() >= maxRowsPerSheet) {
                    sheetIndex.incrementAndGet();
                    currentSheet[0] = createSheet(workbook, sheetIndex.get());
                    writeHeader(currentSheet[0], columns);
                    rowsOnSheet.set(0);
                }
                writeRow(currentSheet[0], columns, row, rowsOnSheet.get() + 1);
                rowsOnSheet.incrementAndGet();
                totalRows.incrementAndGet();
            });

            workbook.write(out);
            workbook.dispose();
        }

        LOGGER.info("Excel report written to {} ({} rows, {} sheets)", outputFile, totalRows.get(), sheetIndex.get());
        return new WriteResult(outputFile, totalRows.get(), sheetIndex.get());
    }

    private Sheet createSheet(SXSSFWorkbook workbook, int index) {
        return workbook.createSheet("Report Results " + index);
    }

    private void writeHeader(Sheet sheet, List<ResultColumn> columns) {
        Row header = sheet.createRow(0);
        for (int i = 0; i < columns.size(); i++) {
            Cell cell = header.createCell(i);
            cell.setCellValue(columns.get(i).displayHeader());
        }
    }

    private void writeRow(Sheet sheet, List<ResultColumn> columns, Map<String, Object> rowData, int rowIndex) {
        Row row = sheet.createRow(rowIndex);
        for (int i = 0; i < columns.size(); i++) {
            Object value = rowData.get(columns.get(i).getPropertySymbolicName());
            Cell cell = row.createCell(i);
            if (value == null) {
                cell.setBlank();
            } else if (value instanceof Number) {
                cell.setCellValue(((Number) value).doubleValue());
            } else if (value instanceof Boolean) {
                cell.setCellValue((Boolean) value);
            } else {
                cell.setCellValue(String.valueOf(value));
            }
        }
    }

    public static final class WriteResult {
        private final Path outputFile;
        private final long rowCount;
        private final int sheetCount;

        public WriteResult(Path outputFile, long rowCount, int sheetCount) {
            this.outputFile = outputFile;
            this.rowCount = rowCount;
            this.sheetCount = sheetCount;
        }

        public Path getOutputFile() {
            return outputFile;
        }

        public long getRowCount() {
            return rowCount;
        }

        public int getSheetCount() {
            return sheetCount;
        }
    }
}

package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.core.Connection;
import com.filenet.api.core.Domain;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.util.UserContext;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import javax.security.auth.Subject;

/**
 * Manages FileNet CE connection using configured service credentials.
 */
public final class FileNetConnectionManager implements AutoCloseable {

    private static final Logger LOGGER = LogManager.getLogger(FileNetConnectionManager.class);

    private final AppConfig config;
    private final Connection connection;
    private final Subject subject;
    private final Domain domain;
    private final ObjectStore objectStore;
    private final ThreadLocal<Boolean> subjectPushed = ThreadLocal.withInitial(() -> Boolean.FALSE);

    public FileNetConnectionManager(AppConfig config) {
        this.config = config;
        LOGGER.info("Connecting to FileNet CE at {}", config.getFileNetUri());
        connection = Factory.Connection.getConnection(config.getFileNetUri());
        subject = UserContext.createSubject(
                connection,
                config.getFileNetUsername(),
                config.getFileNetPassword(),
                config.getFileNetStanza());
        UserContext.get().pushSubject(subject);
        subjectPushed.set(Boolean.TRUE);
        domain = Factory.Domain.fetchInstance(connection, null, null);
        objectStore = Factory.ObjectStore.fetchInstance(domain, config.getFileNetObjectStoreName(), null);
        LOGGER.info("Connected to domain={} objectStore={}", domain.get_Name(), objectStore.get_Name());
    }

    public ObjectStore getObjectStore() {
        return objectStore;
    }

    public Domain getDomain() {
        return domain;
    }

    public AppConfig getConfig() {
        return config;
    }

    public void ensureSubjectOnCurrentThread() {
        if (!Boolean.TRUE.equals(subjectPushed.get())) {
            UserContext.get().pushSubject(subject);
            subjectPushed.set(Boolean.TRUE);
        }
    }

    public void clearSubjectOnCurrentThread() {
        if (Boolean.TRUE.equals(subjectPushed.get())) {
            UserContext.get().popSubject();
            subjectPushed.set(Boolean.FALSE);
        }
    }

    public void testConnection() {
        ensureSubjectOnCurrentThread();
        ObjectStore os = Factory.ObjectStore.fetchInstance(domain, config.getFileNetObjectStoreName(), null);
        LOGGER.info("FileNet connection test succeeded for object store {}", os.get_Name());
    }

    @Override
    public void close() {
        if (Boolean.TRUE.equals(subjectPushed.get())) {
            UserContext.get().popSubject();
            subjectPushed.set(Boolean.FALSE);
        }
        LOGGER.info("FileNet connection closed.");
    }
}


package com.cnb.reports;

import com.cnb.reports.model.ReportRequestPayload;
import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.model.SearchCriterion;
import com.cnb.reports.model.SortOption;
import com.cnb.reports.util.CePropertyNameResolver;
import com.cnb.reports.util.SqlValidationUtil;
import org.apache.commons.lang3.StringUtils;

import java.time.OffsetDateTime;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.ArrayList;
import java.util.List;
import java.util.Locale;
import java.util.stream.Collectors;

/**
 * Builds FileNet Content Engine Search SQL from report request payloads.
 */
public final class FileNetQueryBuilder {

    public String buildQuery(ReportRequestPayload payload) {
        if (SqlValidationUtil.isUsableSql(payload.getSqlQuery())) {
            return payload.getSqlQuery().trim();
        }
        return buildFromPayload(payload);
    }

    public String buildFromPayload(ReportRequestPayload payload) {
        String targetClass = payload.getTargetClassSymbolicName();
        SqlValidationUtil.validateClassName(targetClass);

        List<ResultColumn> columns = payload.getResultColumns();
        if (columns.isEmpty()) {
            throw new IllegalArgumentException("At least one result column is required.");
        }

        String selectClause = columns.stream()
                .map(ResultColumn::getPropertySymbolicName)
                .map(CePropertyNameResolver::resolve)
                .peek(SqlValidationUtil::validatePropertyName)
                .collect(Collectors.joining(", "));

        StringBuilder sql = new StringBuilder();
        sql.append("SELECT ").append(selectClause);
        sql.append(" FROM ").append(targetClass);
        if (payload.isIncludeSubclasses()) {
            sql.append(" SUBCLASSES");
        }

        List<String> conditions = buildConditions(payload.getCriteria());
        if (!conditions.isEmpty()) {
            sql.append(" WHERE ").append(String.join(" AND ", conditions));
        }

        String orderBy = buildOrderBy(payload.getSortOptions());
        if (StringUtils.isNotBlank(orderBy)) {
            sql.append(" ORDER BY ").append(orderBy);
        }
        return sql.toString();
    }

    private List<String> buildConditions(List<SearchCriterion> criteria) {
        List<String> conditions = new ArrayList<>();
        for (SearchCriterion criterion : criteria) {
            String condition = buildCondition(criterion);
            if (StringUtils.isNotBlank(condition)) {
                conditions.add(condition);
            }
        }
        return conditions;
    }

    private String buildCondition(SearchCriterion criterion) {
        String property = CePropertyNameResolver.resolve(criterion.getPropertySymbolicName());
        String operator = normalizeOperator(criterion.getOperator());
        SqlValidationUtil.validatePropertyName(property);

        if ("NULL".equals(operator)) {
            return property + " IS NULL";
        }
        if ("NOTNULL".equals(operator)) {
            return property + " IS NOT NULL";
        }

        List<String> values = criterion.getValues().stream()
                .filter(StringUtils::isNotBlank)
                .collect(Collectors.toList());
        if (values.isEmpty()) {
            return null;
        }

        switch (operator) {
            case "STARTSWITH":
                return property + " LIKE '" + SqlValidationUtil.escapeSqlString(values.get(0)) + "%'";
            case "ENDSWITH":
                return property + " LIKE '%" + SqlValidationUtil.escapeSqlString(values.get(0)) + "'";
            case "LIKE":
            case "NOTLIKE":
                String likeValue = values.get(0);
                if (!likeValue.contains("%") && !likeValue.contains("_")) {
                    likeValue = "%" + likeValue + "%";
                }
                String likeExpr = property + " LIKE '" + SqlValidationUtil.escapeSqlString(likeValue) + "'";
                return "NOTLIKE".equals(operator) ? "NOT (" + likeExpr + ")" : likeExpr;
            case "EQUAL":
                return property + " = " + formatValue(values.get(0), criterion.getDataType());
            case "NOTEQUAL":
                return property + " <> " + formatValue(values.get(0), criterion.getDataType());
            case "GREATERTHAN":
            case "GREATER":
                return property + " > " + formatValue(values.get(0), criterion.getDataType());
            case "GREATERTHANOREQUAL":
            case "GREATEROREQUAL":
                return property + " >= " + formatValue(values.get(0), criterion.getDataType());
            case "LESSTHAN":
            case "LESS":
                return property + " < " + formatValue(values.get(0), criterion.getDataType());
            case "LESSTHANOREQUAL":
            case "LESSOREQUAL":
                return property + " <= " + formatValue(values.get(0), criterion.getDataType());
            case "BETWEEN":
                if (values.size() < 2) {
                    throw new IllegalArgumentException("BETWEEN operator requires two values for " + property);
                }
                return property + " BETWEEN "
                        + formatValue(values.get(0), criterion.getDataType())
                        + " AND "
                        + formatValue(values.get(1), criterion.getDataType());
            case "INANY":
                return property + " IN (" + values.stream()
                        .map(value -> formatValue(value, criterion.getDataType()))
                        .collect(Collectors.joining(", ")) + ")";
            case "NOTIN":
                return property + " NOT IN (" + values.stream()
                        .map(value -> formatValue(value, criterion.getDataType()))
                        .collect(Collectors.joining(", ")) + ")";
            default:
                throw new IllegalArgumentException("Unsupported operator: " + criterion.getOperator());
        }
    }

    private String buildOrderBy(List<SortOption> sortOptions) {
        if (sortOptions == null || sortOptions.isEmpty()) {
            return null;
        }
        List<String> parts = new ArrayList<>();
        for (SortOption sortOption : sortOptions) {
            if (StringUtils.isBlank(sortOption.getPropertySymbolicName())) {
                continue;
            }
            SqlValidationUtil.validatePropertyName(CePropertyNameResolver.resolve(sortOption.getPropertySymbolicName()));
            String direction = "DESC".equalsIgnoreCase(sortOption.getDirection()) ? "DESC" : "ASC";
            parts.add(CePropertyNameResolver.resolve(sortOption.getPropertySymbolicName()) + " " + direction);
        }
        return parts.isEmpty() ? null : String.join(", ", parts);
    }

    private String normalizeOperator(String operator) {
        if (operator == null) {
            return "";
        }
        return operator.trim().toUpperCase(Locale.ROOT);
    }

    private String formatValue(String rawValue, String dataType) {
        if (isBooleanType(dataType)) {
            return Boolean.parseBoolean(rawValue) ? "TRUE" : "FALSE";
        }
        if (isNumericType(dataType)) {
            validateNumeric(rawValue);
            return rawValue.trim();
        }
        if (isDateType(dataType) || (StringUtils.isBlank(dataType) && looksLikeDate(rawValue))) {
            return formatDateLiteral(rawValue);
        }
        return "'" + SqlValidationUtil.escapeSqlString(rawValue) + "'";
    }

    private boolean isBooleanType(String dataType) {
        return dataType != null && dataType.toLowerCase(Locale.ROOT).contains("boolean");
    }

    private boolean isNumericType(String dataType) {
        if (dataType == null) {
            return false;
        }
        String lower = dataType.toLowerCase(Locale.ROOT);
        return lower.contains("int") || lower.contains("long") || lower.contains("double")
                || lower.contains("decimal") || lower.contains("float") || lower.contains("short");
    }

    private boolean isDateType(String dataType) {
        if (dataType == null) {
            return false;
        }
        String lower = dataType.toLowerCase(Locale.ROOT);
        return lower.contains("date") || lower.contains("time");
    }

    private boolean looksLikeDate(String value) {
        return value.contains("T") || value.matches("\\d{4}-\\d{2}-\\d{2}.*");
    }

    private void validateNumeric(String value) {
        try {
            Double.parseDouble(value.trim());
        } catch (NumberFormatException ex) {
            throw new IllegalArgumentException("Invalid numeric value: " + value, ex);
        }
    }

    private String formatDateLiteral(String rawValue) {
        String normalized = rawValue.trim();
        if (normalized.matches("\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}")) {
            return "{ts '" + normalized + "'}";
        }
        try {
            OffsetDateTime dateTime = OffsetDateTime.parse(normalized);
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
            return "{ts '" + dateTime.toLocalDateTime().format(formatter) + "'}";
        } catch (DateTimeParseException ex) {
            if (normalized.matches("\\d{4}-\\d{2}-\\d{2}")) {
                return "{ts '" + normalized + " 00:00:00'}";
            }
            throw new IllegalArgumentException("Invalid date value: " + rawValue, ex);
        }
    }
}


package com.cnb.reports;

import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.util.CePropertyNameResolver;
import com.cnb.reports.util.P8PropertyReader;
import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.core.IndependentObject;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.function.Consumer;

/**
 * Executes FileNet Search SQL and streams result rows.
 */
public final class FileNetQueryExecutor {

    private static final Logger LOGGER = LogManager.getLogger(FileNetQueryExecutor.class);
    private static final int PAGE_SIZE = 500;

    private final ObjectStore objectStore;

    public FileNetQueryExecutor(ObjectStore objectStore) {
        this.objectStore = objectStore;
    }

    public long execute(String sql, List<ResultColumn> columns, Consumer<Map<String, Object>> rowConsumer)
            throws Exception {
        LOGGER.info("Executing FileNet query: {}", sql);
        SearchSQL searchSQL = new SearchSQL(sql);
        SearchScope scope = new SearchScope(objectStore);
        PropertyFilter propertyFilter = buildPropertyFilter(columns);
        IndependentObjectSet resultSet = scope.fetchObjects(searchSQL, PAGE_SIZE, propertyFilter, Boolean.TRUE);

        long rowCount = 0;
        PageIterator pageIterator = resultSet.pageIterator();
        while (pageIterator.nextPage()) {
            Object[] page = pageIterator.getCurrentPage();
            if (page == null) {
                continue;
            }
            for (Object item : page) {
                if (!(item instanceof IndependentObject)) {
                    continue;
                }
                Properties properties = ((IndependentObject) item).getProperties();
                Map<String, Object> row = new LinkedHashMap<>();
                for (ResultColumn column : columns) {
                    String propertyName = column.getPropertySymbolicName();
                    row.put(propertyName,
                            formatCellValue(P8PropertyReader.readPropertyValue(properties, propertyName)));
                }
                rowConsumer.accept(row);
                rowCount++;
            }
        }
        LOGGER.info("Query returned {} rows", rowCount);
        return rowCount;
    }

    private PropertyFilter buildPropertyFilter(List<ResultColumn> columns) {
        PropertyFilter filter = new PropertyFilter();
        for (ResultColumn column : columns) {
            filter.addIncludeProperty(0, null, null, column.getPropertySymbolicName(), null);
        }
        filter.addIncludeProperty(0, null, null, "Id", null);
        return filter;
    }

    private Object formatCellValue(Object value) {
        if (value instanceof java.util.Date) {
            return P8PropertyReader.formatDateTime((java.util.Date) value);
        }
        return value != null ? value : "";
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.collection.ContentElementList;
import com.filenet.api.constants.AutoClassify;
import com.filenet.api.constants.CheckinType;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.constants.ReservationType;
import com.filenet.api.core.ContentTransfer;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.ByteArrayInputStream;
import java.io.ByteArrayOutputStream;
import java.io.FileInputStream;
import java.io.InputStream;
import java.nio.file.Path;
import java.util.Date;

/**
 * Checks out a ReportRequest and checks in the generated Excel report as the sole content element.
 */
public final class ReportAttachmentService {

    private static final Logger LOGGER = LogManager.getLogger(ReportAttachmentService.class);
    private static final String EXCEL_MIME =
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportAttachmentService(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public void attachExcelReport(String documentId, Path excelFile, String reportName,
            ReportStatusService statusService, Date completedAt) throws Exception {
        Document document = fetchDocument(documentId);
        String currentStatus = document.getProperties().getStringValue(config.getStatusProperty());
        LOGGER.info("Checking out ReportRequest {} for Excel attachment (current status={})", documentId, currentStatus);

        document.checkout(ReservationType.EXCLUSIVE, null, null, null);
        document.save(RefreshMode.REFRESH);

        Document reservation = fetchReservation(document);
        LOGGER.info("Using reservation {} for ReportRequest {}", reservation.get_Id(), documentId);

        byte[] excelBytes;
        try (InputStream inputStream = new FileInputStream(excelFile.toFile());
                ByteArrayOutputStream buffer = new ByteArrayOutputStream()) {
            inputStream.transferTo(buffer);
            excelBytes = buffer.toByteArray();
        }

        ContentTransfer excelTransfer = Factory.ContentTransfer.createInstance();
        excelTransfer.setCaptureSource(new ByteArrayInputStream(excelBytes));
        excelTransfer.set_ContentType(EXCEL_MIME);
        excelTransfer.set_RetrievalName(buildExcelRetrievalName(reportName));

        ContentElementList contentElements = Factory.ContentElement.createList();
        contentElements.add(excelTransfer);

        reservation.set_ContentElements(contentElements);
        reservation.set_MimeType(EXCEL_MIME);
        statusService.applyCompletedStatus(reservation, completedAt);
        reservation.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
        reservation.save(RefreshMode.REFRESH);

        LOGGER.info("Checked in ReportRequest {} with Excel-only content {}", documentId, excelFile);
    }

    private Document fetchReservation(Document document) {
        Document reservation = (Document) document.get_Reservation();
        if (reservation == null) {
            throw new IllegalStateException("Reservation was not created for document " + document.get_Id());
        }

        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getLastExecutionDateProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.MIME_TYPE, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        return Factory.Document.fetchInstance(objectStore, reservation.get_Id(), filter);
    }

    private Document fetchDocument(String documentId) {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), filter);
    }

    private String buildExcelRetrievalName(String reportName) {
        String safeName = reportName == null ? "report" : reportName.replaceAll("[\\\\/:*?\"<>|]", "_").trim();
        if (safeName.isEmpty()) {
            safeName = "report";
        }
        return safeName.endsWith(".xlsx") ? safeName : safeName + ".xlsx";
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.model.ReportExecutionResult;
import com.cnb.reports.model.ReportRequestSummary;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;
import org.apache.logging.log4j.core.config.Configurator;

import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.Future;
import java.util.concurrent.TimeUnit;

/**
 * Entry point for the standalone Report Execution Tool.
 */
public final class ReportExecutionToolMain {

    private static final Logger LOGGER = LogManager.getLogger(ReportExecutionToolMain.class);

    private ReportExecutionToolMain() {
    }

    public static void main(String[] args) {
        initializeLogging();
        int exitCode = 0;
        try {
            AppConfig config = AppConfig.loadFromSystemProperty();
            LOGGER.info("Report Execution Tool starting.");
            LOGGER.info("Configuration loaded from {}", System.getProperty("config.file"));
            LOGGER.info("Processable statuses: {}", config.getProcessableStatuses());
            LOGGER.info("Worker thread count: {}, poll batch size: {}", config.getWorkerThreadCount(),
                    config.getPollBatchSize());

            if (config.isPollingLoopEnabled()) {
                runPollingLoop(config);
            } else {
                exitCode = runOnce(config);
            }
        } catch (Exception ex) {
            LOGGER.error("Report Execution Tool failed to start.", ex);
            exitCode = 1;
        }
        LOGGER.info("Report Execution Tool finished with exit code {}", exitCode);
        System.exit(exitCode);
    }

    private static void initializeLogging() {
        String logConfig = System.getProperty("log4j.configurationFile");
        if (logConfig == null || logConfig.isBlank()) {
            logConfig = "D:/Rameshwar/ReportsExecutionTool/config/Log4j2.xml";
        }
        Configurator.initialize(null, logConfig);
    }

    private static void runPollingLoop(AppConfig config) throws Exception {
        LOGGER.info("Internal polling loop enabled. Interval={} minutes", config.getPollingIntervalMinutes());
        while (true) {
            runOnce(config);
            Thread.sleep(TimeUnit.MINUTES.toMillis(config.getPollingIntervalMinutes()));
        }
    }

    private static int runOnce(AppConfig config) throws Exception {
        try (FileNetConnectionManager connectionManager = new FileNetConnectionManager(config)) {
            connectionManager.testConnection();
            LOGGER.info("FileNet connection established successfully.");

            ReportRequestFinder finder = new ReportRequestFinder(config, connectionManager.getObjectStore());
            List<ReportRequestSummary> pendingRequests = finder.findProcessableRequests();
            if (pendingRequests.isEmpty()) {
                LOGGER.info("No processable ReportRequest documents found.");
                return 0;
            }

            ExecutorService executor = Executors.newFixedThreadPool(config.getWorkerThreadCount());
            List<Future<ReportExecutionResult>> futures = new ArrayList<>();
            for (ReportRequestSummary summary : pendingRequests) {
                futures.add(executor.submit(new ReportExecutionWorker(config, connectionManager, summary)));
            }

            executor.shutdown();
            if (!executor.awaitTermination(12, TimeUnit.HOURS)) {
                executor.shutdownNow();
                LOGGER.warn("Worker pool did not finish within timeout.");
            }

            int successCount = 0;
            int failureCount = 0;
            for (Future<ReportExecutionResult> future : futures) {
                ReportExecutionResult result = future.get();
                if (result.isSuccess()) {
                    successCount++;
                } else {
                    failureCount++;
                }
            }

            LOGGER.info("Batch complete. success={}, failed={}", successCount, failureCount);
            return failureCount > 0 ? 1 : 0;
        }
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.email.EmailService;
import com.cnb.reports.email.ReportRequestEmailContext;
import com.cnb.reports.email.ReportRequestEmailContextFactory;
import com.cnb.reports.model.ReportExecutionResult;
import com.cnb.reports.model.ReportRequestPayload;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.util.SqlValidationUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.nio.file.Path;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.Date;
import java.util.concurrent.Callable;

/**
 * Processes a single claimed ReportRequest end-to-end.
 */
public final class ReportExecutionWorker implements Callable<ReportExecutionResult> {

    private static final Logger LOGGER = LogManager.getLogger(ReportExecutionWorker.class);
    private static final DateTimeFormatter FILE_TS = DateTimeFormatter.ofPattern("yyyyMMddHHmmss");

    private final AppConfig config;
    private final FileNetConnectionManager connectionManager;
    private final ReportRequestSummary summary;
    private final EmailService emailService;

    public ReportExecutionWorker(AppConfig config, FileNetConnectionManager connectionManager,
            ReportRequestSummary summary) {
        this.config = config;
        this.connectionManager = connectionManager;
        this.summary = summary;
        this.emailService = new EmailService(config);
    }

    @Override
    public ReportExecutionResult call() {
        String documentId = summary.getDocumentId();
        connectionManager.ensureSubjectOnCurrentThread();
        ReportRequestSummary latestSummary = null;
        ReportRequestPayload payload = null;
        try {
            ReportRequestClaimService claimService =
                    new ReportRequestClaimService(config, connectionManager.getObjectStore());
            if (!claimService.tryClaim(documentId)) {
                return ReportExecutionResult.builder(documentId)
                        .success(false)
                        .message("ReportRequest was not claimed.")
                        .build();
            }

            ReportRequestPayloadReader payloadReader =
                    new ReportRequestPayloadReader(config, connectionManager.getObjectStore());
            latestSummary = payloadReader.readSummary(documentId);
            String jsonPayload = payloadReader.readJsonPayload(documentId);

            ReportRequestPayloadParser parser = new ReportRequestPayloadParser();
            payload = parser.parse(jsonPayload, latestSummary);

            if (!SqlValidationUtil.isUsableSql(payload.getSqlQuery())) {
                payload.setSqlQuery(latestSummary.getSqlQuery());
            }

            FileNetQueryBuilder queryBuilder = new FileNetQueryBuilder();
            final String sql = queryBuilder.buildQuery(payload);
            LOGGER.info("ReportRequest {} query: {}", documentId, sql);

            FileNetQueryExecutor queryExecutor = new FileNetQueryExecutor(connectionManager.getObjectStore());

            Path excelPath = buildExcelOutputPath(documentId, payload.getReportName());
            ExcelReportWriter excelWriter = new ExcelReportWriter(config);
            final java.util.List<ResultColumn> resultColumns = payload.getResultColumns();
            ExcelReportWriter.WriteResult writeResult =
                    excelWriter.writeReport(excelPath, payload.getReportName(), resultColumns,
                            rowConsumer -> {
                                try {
                                    queryExecutor.execute(sql, resultColumns, rowConsumer);
                                } catch (Exception ex) {
                                    throw new RuntimeException(ex);
                                }
                            });
            long rowCount = writeResult.getRowCount();

            Date completedAt = new Date();
            ReportStatusService statusService = new ReportStatusService(config, connectionManager.getObjectStore());
            ReportAttachmentService attachmentService =
                    new ReportAttachmentService(config, connectionManager.getObjectStore());
            attachmentService.attachExcelReport(documentId, writeResult.getOutputFile(), payload.getReportName(),
                    statusService, completedAt);

            ReportOutputArchiveService archiveService = new ReportOutputArchiveService(config);
            Path archivedCopy = archiveService.archiveCompletedReport(writeResult.getOutputFile());

            statusService.markCompleted(documentId, completedAt);

            ReportRequestSummary postSummary = payloadReader.readSummary(documentId);
            ReportRequestEmailContext emailContext = ReportRequestEmailContextFactory.from(
                    config, connectionManager.getObjectStore(), postSummary, payload, config.getCompletedStatus());
            emailService.sendCompletionEmail(emailContext);

            LOGGER.info("Completed ReportRequest {} with {} rows. Excel={} archived={}",
                    documentId, rowCount, excelPath, archivedCopy);
            return ReportExecutionResult.builder(documentId)
                    .success(true)
                    .message("Report execution completed.")
                    .generatedSql(sql)
                    .rowCount(rowCount)
                    .excelFilePath(archivedCopy.toString())
                    .build();
        } catch (Exception ex) {
            LOGGER.error("Failed processing ReportRequest {}", documentId, ex);
            try {
                ReportStatusService statusService = new ReportStatusService(config, connectionManager.getObjectStore());
                statusService.markFailed(documentId, new Date());
                sendFailureEmail(documentId, latestSummary, payload);
            } catch (Exception statusEx) {
                LOGGER.error("Failed to update failed status for ReportRequest {}", documentId, statusEx);
            }
            return ReportExecutionResult.builder(documentId)
                    .success(false)
                    .message(ex.getMessage())
                    .error(ex)
                    .build();
        } finally {
            connectionManager.clearSubjectOnCurrentThread();
        }
    }

    private void sendFailureEmail(String documentId, ReportRequestSummary latestSummary, ReportRequestPayload payload) {
        try {
            ReportRequestPayloadReader payloadReader =
                    new ReportRequestPayloadReader(config, connectionManager.getObjectStore());
            ReportRequestSummary failedSummary = payloadReader.readSummary(documentId);
            ReportRequestPayload emailPayload = payload;
            if (emailPayload == null && latestSummary != null) {
                try {
                    String jsonPayload = payloadReader.readJsonPayload(documentId);
                    emailPayload = new ReportRequestPayloadParser().parse(jsonPayload, failedSummary);
                } catch (Exception readEx) {
                    LOGGER.warn("Unable to read JSON payload for failure email on ReportRequest {}", documentId, readEx);
                }
            }
            ReportRequestEmailContext emailContext = ReportRequestEmailContextFactory.from(
                    config, connectionManager.getObjectStore(), failedSummary, emailPayload, config.getFailedStatus());
            emailService.sendFailureEmail(emailContext);
        } catch (Exception emailEx) {
            LOGGER.error("Failed to send failure email for ReportRequest {}", documentId, emailEx);
        }
    }

    private Path buildExcelOutputPath(String documentId, String reportName) {
        String safeName = reportName == null ? "report" : reportName.replaceAll("[\\\\/:*?\"<>|]", "_");
        if (safeName.isBlank()) {
            safeName = "report";
        }
        String fileName = safeName + "-" + documentId + "-" + LocalDateTime.now().format(FILE_TS) + ".xlsx";
        return config.getOutputTempFolder().resolve(fileName);
    }
}


