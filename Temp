		if (sendEmails) {
			dialog.sendEmailToField.set("value", formatEmailsForField(payload.sendEmailTo));
			dialog.sendEmailCcField.set("value", formatEmailsForField(payload.sendEmailCC || payload.sendEmailCc));
		}
	}

