package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.collection.ContentElementList;
import com.filenet.api.constants.AutoClassify;
import com.filenet.api.constants.CheckinType;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.constants.ReservationType;
import com.filenet.api.core.ContentTransfer;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.io.ByteArrayInputStream;
import java.io.ByteArrayOutputStream;
import java.io.FileInputStream;
import java.io.InputStream;
import java.nio.file.Path;
import java.util.Date;

/**
 * Creates Version 2 of a ReportRequest with the generated Excel report as content.
 * Version 1 retains the original request JSON for Copy / Reinitiate.
 */
public final class ReportAttachmentService {

    private static final Logger LOGGER = LogManager.getLogger(ReportAttachmentService.class);
    private static final String EXCEL_MIME =
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportAttachmentService(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public void attachExcelReport(String documentId, Path excelFile, String reportName,
            ReportStatusService statusService, Date completedAt) throws Exception {
        Document document = fetchDocument(documentId);
        String currentStatus = document.getProperties().getStringValue(config.getStatusProperty());
        LOGGER.info("Checking out ReportRequest {} for Excel attachment (current status={})", documentId, currentStatus);

        document.checkout(ReservationType.EXCLUSIVE, null, null, null);
        document.save(RefreshMode.REFRESH);

        Document reservation = fetchReservation(document);
        LOGGER.info("Using reservation {} for ReportRequest {}", reservation.get_Id(), documentId);

        byte[] excelBytes;
        try (InputStream inputStream = new FileInputStream(excelFile.toFile());
                ByteArrayOutputStream buffer = new ByteArrayOutputStream()) {
            inputStream.transferTo(buffer);
            excelBytes = buffer.toByteArray();
        }

        ContentTransfer excelTransfer = Factory.ContentTransfer.createInstance();
        excelTransfer.setCaptureSource(new ByteArrayInputStream(excelBytes));
        excelTransfer.set_ContentType(EXCEL_MIME);
        excelTransfer.set_RetrievalName(buildExcelRetrievalName(reportName));

        ContentElementList contentElements = Factory.ContentElement.createList();
        contentElements.add(excelTransfer);

        reservation.set_ContentElements(contentElements);
        reservation.set_MimeType(EXCEL_MIME);
        statusService.applyCompletedStatus(reservation, completedAt);
        reservation.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
        reservation.save(RefreshMode.REFRESH);

        LOGGER.info("Checked in ReportRequest {} with Excel-only content {}", documentId, excelFile);
    }

    private Document fetchReservation(Document document) {
        Document reservation = (Document) document.get_Reservation();
        if (reservation == null) {
            throw new IllegalStateException("Reservation was not created for document " + document.get_Id());
        }

        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getLastExecutionDateProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.MIME_TYPE, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        return Factory.Document.fetchInstance(objectStore, reservation.get_Id(), filter);
    }

    private Document fetchDocument(String documentId) {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), filter);
    }

    private String buildExcelRetrievalName(String reportName) {
        String safeName = reportName == null ? "report" : reportName.replaceAll("[\\\\/:*?\"<>|]", "_").trim();
        if (safeName.isEmpty()) {
            safeName = "report";
        }
        return safeName.endsWith(".xlsx") ? safeName : safeName + ".xlsx";
    }
}




package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.email.EmailService;
import com.cnb.reports.email.ReportRequestEmailContext;
import com.cnb.reports.email.ReportRequestEmailContextFactory;
import com.cnb.reports.model.ReportExecutionResult;
import com.cnb.reports.model.ReportRequestPayload;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.model.ResultColumn;
import com.cnb.reports.util.CePropertyMetadataResolver;
import com.cnb.reports.util.SqlValidationUtil;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.nio.file.Path;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.Date;
import java.util.concurrent.Callable;

/**
 * Processes a single claimed ReportRequest end-to-end.
 */
public final class ReportExecutionWorker implements Callable<ReportExecutionResult> {

    private static final Logger LOGGER = LogManager.getLogger(ReportExecutionWorker.class);
    private static final DateTimeFormatter FILE_TS = DateTimeFormatter.ofPattern("yyyyMMddHHmmss");

    private final AppConfig config;
    private final FileNetConnectionManager connectionManager;
    private final ReportRequestSummary summary;
    private final EmailService emailService;

    public ReportExecutionWorker(AppConfig config, FileNetConnectionManager connectionManager,
            ReportRequestSummary summary) {
        this.config = config;
        this.connectionManager = connectionManager;
        this.summary = summary;
        this.emailService = new EmailService(config);
    }

    @Override
    public ReportExecutionResult call() {
        String documentId = summary.getDocumentId();
        connectionManager.ensureSubjectOnCurrentThread();
        ReportRequestSummary latestSummary = null;
        ReportRequestPayload payload = null;
        try {
            ReportRequestClaimService claimService =
                    new ReportRequestClaimService(config, connectionManager.getObjectStore());
            if (!claimService.tryClaim(documentId)) {
                return ReportExecutionResult.builder(documentId)
                        .success(false)
                        .message("ReportRequest was not claimed.")
                        .build();
            }

            ReportRequestPayloadReader payloadReader =
                    new ReportRequestPayloadReader(config, connectionManager.getObjectStore());
            latestSummary = payloadReader.readSummary(documentId);
            String jsonPayload = payloadReader.readJsonPayload(documentId);

            ReportRequestPayloadParser parser = new ReportRequestPayloadParser();
            payload = parser.parse(jsonPayload, latestSummary);

            if (!SqlValidationUtil.isUsableSql(payload.getSqlQuery())) {
                payload.setSqlQuery(latestSummary.getSqlQuery());
            }

            LOGGER.info(
                    "Executing ReportRequest documentId={}, reportRequestId={}, reportName={}, objectStore={}, "
                            + "class={}, includeSubclasses={}, searchScope={}, folderId={}, folderPath={}, "
                            + "criteriaCount={}, resultColumnCount={}",
                    documentId,
                    payload.getReportRequestId(),
                    payload.getReportName(),
                    firstNonBlank(payload.getObjectStoreName(), payload.getRepositoryName()),
                    payload.getTargetClassSymbolicName(),
                    payload.isIncludeSubclasses(),
                    payload.getSearchScope(),
                    payload.getFolderId(),
                    payload.getFolderPath(),
                    payload.getCriteria().size(),
                    payload.getResultColumns().size());

            CePropertyMetadataResolver metadataResolver =
                    new CePropertyMetadataResolver(connectionManager.getObjectStore());
            FileNetQueryBuilder queryBuilder = new FileNetQueryBuilder(metadataResolver);
            final String sql = queryBuilder.buildQuery(payload);
            LOGGER.info("ReportRequest {} generated SQL: {}", documentId, sql);

            FileNetQueryExecutor queryExecutor = new FileNetQueryExecutor(connectionManager.getObjectStore());

            Path excelPath = buildExcelOutputPath(documentId, payload.getReportName());
            ExcelReportWriter excelWriter = new ExcelReportWriter(config);
            final java.util.List<ResultColumn> resultColumns = payload.getResultColumns();
            ExcelReportWriter.WriteResult writeResult =
                    excelWriter.writeReport(excelPath, payload.getReportName(), resultColumns,
                            rowConsumer -> {
                                try {
                                    queryExecutor.execute(sql, resultColumns, rowConsumer);
                                } catch (Exception ex) {
                                    throw new RuntimeException(ex);
                                }
                            });
            long rowCount = writeResult.getRowCount();

            Date completedAt = new Date();
            ReportStatusService statusService = new ReportStatusService(config, connectionManager.getObjectStore());
            ReportAttachmentService attachmentService =
                    new ReportAttachmentService(config, connectionManager.getObjectStore());
            // Version 2 = Excel + Completed. Version 1 keeps request JSON.
            attachmentService.attachExcelReport(documentId, writeResult.getOutputFile(), payload.getReportName(),
                    statusService, completedAt);

            ReportOutputArchiveService archiveService = new ReportOutputArchiveService(config);
            Path archivedCopy = archiveService.archiveCompletedReport(writeResult.getOutputFile());

            ReportRequestSummary postSummary = payloadReader.readSummary(documentId);
            ReportRequestEmailContext emailContext = ReportRequestEmailContextFactory.from(
                    config, connectionManager.getObjectStore(), postSummary, payload, config.getCompletedStatus());
            emailService.sendCompletionEmail(emailContext);

            LOGGER.info("Completed ReportRequest {} with {} rows. Excel={} archived={}",
                    documentId, rowCount, excelPath, archivedCopy);
            return ReportExecutionResult.builder(documentId)
                    .success(true)
                    .message("Report execution completed.")
                    .generatedSql(sql)
                    .rowCount(rowCount)
                    .excelFilePath(archivedCopy.toString())
                    .build();
        } catch (Exception ex) {
            LOGGER.error("Failed processing ReportRequest {}", documentId, ex);
            try {
                ReportStatusService statusService = new ReportStatusService(config, connectionManager.getObjectStore());
                statusService.markFailed(documentId, new Date());
                sendFailureEmail(documentId, latestSummary, payload);
            } catch (Exception statusEx) {
                LOGGER.error("Failed to update failed status for ReportRequest {}", documentId, statusEx);
            }
            return ReportExecutionResult.builder(documentId)
                    .success(false)
                    .message(ex.getMessage())
                    .error(ex)
                    .build();
        } finally {
            connectionManager.clearSubjectOnCurrentThread();
        }
    }

    private void sendFailureEmail(String documentId, ReportRequestSummary latestSummary, ReportRequestPayload payload) {
        try {
            ReportRequestPayloadReader payloadReader =
                    new ReportRequestPayloadReader(config, connectionManager.getObjectStore());
            ReportRequestSummary failedSummary = payloadReader.readSummary(documentId);
            ReportRequestPayload emailPayload = payload;
            if (emailPayload == null && latestSummary != null) {
                try {
                    String jsonPayload = payloadReader.readJsonPayload(documentId);
                    emailPayload = new ReportRequestPayloadParser().parse(jsonPayload, failedSummary);
                } catch (Exception readEx) {
                    LOGGER.warn("Unable to read JSON payload for failure email on ReportRequest {}", documentId, readEx);
                }
            }
            ReportRequestEmailContext emailContext = ReportRequestEmailContextFactory.from(
                    config, connectionManager.getObjectStore(), failedSummary, emailPayload, config.getFailedStatus());
            emailService.sendFailureEmail(emailContext);
        } catch (Exception emailEx) {
            LOGGER.error("Failed to send failure email for ReportRequest {}", documentId, emailEx);
        }
    }

    private Path buildExcelOutputPath(String documentId, String reportName) {
        String safeName = reportName == null ? "report" : reportName.replaceAll("[\\\\/:*?\"<>|]", "_");
        if (safeName.trim().isEmpty()) {
            safeName = "report";
        }
        String fileName = safeName + "-" + documentId + "-" + LocalDateTime.now().format(FILE_TS) + ".xlsx";
        return config.getOutputTempFolder().resolve(fileName);
    }

    private static String firstNonBlank(String first, String second) {
        if (first != null && !first.trim().isEmpty()) {
            return first.trim();
        }
        return second;
    }
}


package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.filenet.api.constants.AutoClassify;
import com.filenet.api.constants.CheckinType;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.constants.RefreshMode;
import com.filenet.api.constants.ReservationType;
import com.filenet.api.core.Document;
import com.filenet.api.core.Factory;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.core.VersionSeries;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.util.Id;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.Date;

/**
 * Updates ReportRequest status and execution date properties.
 */
public final class ReportStatusService {

    private static final Logger LOGGER = LogManager.getLogger(ReportStatusService.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportStatusService(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public void markInProgress(String documentId, Date startDate) throws Exception {
        updateStatus(fetchCurrentVersionDocument(documentId), config.getInProgressStatus(), startDate, null, null);
    }

    public void markCompleted(String documentId, Date endDate) throws Exception {
        updateStatus(fetchCurrentVersionDocument(documentId), config.getCompletedStatus(), null, endDate, endDate);
    }

    /**
     * Creates Version 2 for a failed execution (keeps Version 1 request JSON intact for Copy/Reinitiate).
     * Existing content is preserved on the reservation; only status/dates are updated before major checkin.
     */
    public void markFailed(String documentId, Date endDate) throws Exception {
        Document document = fetchCurrentVersionDocument(documentId);
        if (Boolean.TRUE.equals(document.get_IsReserved())) {
            throw new IllegalStateException("ReportRequest is already checked out: " + documentId);
        }

        document.checkout(ReservationType.EXCLUSIVE, null, null, null);
        document.save(RefreshMode.REFRESH);

        Document reservation = (Document) document.get_Reservation();
        if (reservation == null) {
            throw new IllegalStateException("Reservation was not created for failed ReportRequest " + documentId);
        }
        reservation = Factory.Document.fetchInstance(objectStore, reservation.get_Id(), statusPropertyFilter());

        applyFailedStatus(reservation, endDate);
        reservation.checkin(AutoClassify.DO_NOT_AUTO_CLASSIFY, CheckinType.MAJOR_VERSION);
        reservation.save(RefreshMode.REFRESH);
        LOGGER.info("Checked in Failed Version 2 for ReportRequest {}", documentId);
    }

    public void applyFailedStatus(Document document, Date endDate) {
        if (endDate != null) {
            document.getProperties().putValue(config.getEndDateProperty(), endDate);
            document.getProperties().putValue(config.getLastExecutionDateProperty(), endDate);
        }
        document.getProperties().putValue(config.getStatusProperty(), config.getFailedStatus());
    }

    public void markCompletedOnDocument(Document document, Date endDate) throws Exception {
        applyCompletedStatus(document, endDate);
        document.save(RefreshMode.REFRESH);
    }

    public void applyCompletedStatus(Document document, Date endDate) {
        if (endDate != null) {
            document.getProperties().putValue(config.getEndDateProperty(), endDate);
            document.getProperties().putValue(config.getLastExecutionDateProperty(), endDate);
        }
        document.getProperties().putValue(config.getStatusProperty(), config.getCompletedStatus());
    }

    private void updateStatus(Document document, String status, Date startDate, Date endDate, Date lastExecutionDate)
            throws Exception {
        if (startDate != null) {
            document.getProperties().putValue(config.getStartDateProperty(), startDate);
        }
        if (endDate != null) {
            document.getProperties().putValue(config.getEndDateProperty(), endDate);
        }
        if (lastExecutionDate != null) {
            document.getProperties().putValue(config.getLastExecutionDateProperty(), lastExecutionDate);
        }
        document.getProperties().putValue(config.getStatusProperty(), status);
        document.save(RefreshMode.REFRESH);
        LOGGER.info("Updated ReportRequest {} status to {}", document.get_Id(), status);
    }

    public String readStatus(String documentId) {
        Document document = fetchDocument(documentId);
        return document.getProperties().getStringValue(config.getStatusProperty());
    }

    private Document fetchCurrentVersionDocument(String documentId) {
        Document document = fetchDocument(documentId);
        VersionSeries versionSeries = document.get_VersionSeries();
        if (versionSeries != null) {
            Object currentVersion = versionSeries.get_CurrentVersion();
            if (currentVersion instanceof Document) {
                return fetchDocument(((Document) currentVersion).get_Id().toString());
            }
        }
        return document;
    }

    private Document fetchDocument(String documentId) {
        return Factory.Document.fetchInstance(objectStore, new Id(documentId), statusPropertyFilter());
    }

    private PropertyFilter statusPropertyFilter() {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getLastExecutionDateProperty(), null);
        filter.addIncludeProperty(0, null, null, PropertyNames.VERSION_SERIES, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.RESERVATION, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.IS_RESERVED, null);
        filter.addIncludeProperty(0, null, null, PropertyNames.CONTENT_ELEMENTS, null);
        return filter;
    }
}



package com.cnb.reports;

import com.cnb.reports.config.AppConfig;
import com.cnb.reports.model.ReportRequestSummary;
import com.cnb.reports.util.P8PropertyReader;
import com.cnb.reports.util.SqlValidationUtil;
import com.filenet.api.collection.IndependentObjectSet;
import com.filenet.api.collection.PageIterator;
import com.filenet.api.collection.StringList;
import com.filenet.api.constants.PropertyNames;
import com.filenet.api.core.Document;
import com.filenet.api.core.ObjectStore;
import com.filenet.api.property.Properties;
import com.filenet.api.property.PropertyFilter;
import com.filenet.api.query.SearchSQL;
import com.filenet.api.query.SearchScope;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import java.util.ArrayList;
import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

/**
 * Finds processable ReportRequest documents in FileNet.
 */
public final class ReportRequestFinder {

    private static final Logger LOGGER = LogManager.getLogger(ReportRequestFinder.class);

    private final AppConfig config;
    private final ObjectStore objectStore;

    public ReportRequestFinder(AppConfig config, ObjectStore objectStore) {
        this.config = config;
        this.objectStore = objectStore;
    }

    public List<ReportRequestSummary> findProcessableRequests() throws Exception {
        String sql = buildFindSql(config.getProcessableStatuses());
        LOGGER.info("Searching for processable ReportRequest documents using SQL: {}", sql);

        SearchSQL searchSQL = new SearchSQL(sql);
        SearchScope scope = new SearchScope(objectStore);
        PropertyFilter filter = buildPropertyFilter();
        IndependentObjectSet resultSet = scope.fetchObjects(searchSQL, config.getPollBatchSize(), filter, Boolean.TRUE);

        List<ReportRequestSummary> summaries = new ArrayList<>();
        PageIterator pageIterator = resultSet.pageIterator();
        if (pageIterator.nextPage()) {
            Object[] page = pageIterator.getCurrentPage();
            if (page != null) {
                for (Object item : page) {
                    if (item instanceof Document) {
                        summaries.add(toSummary((Document) item));
                    }
                }
            }
        }
        LOGGER.info("Found {} processable ReportRequest documents", summaries.size());
        return summaries;
    }

    private String buildFindSql(Set<String> statuses) {
        String statusClause;
        if (statuses.size() == 1) {
            statusClause = config.getStatusProperty() + " = '"
                    + SqlValidationUtil.escapeSqlString(statuses.iterator().next()) + "'";
        } else {
            statusClause = config.getStatusProperty() + " IN ("
                    + statuses.stream()
                            .map(status -> "'" + SqlValidationUtil.escapeSqlString(status) + "'")
                            .collect(Collectors.joining(", "))
                    + ")";
        }

        return "SELECT [This], Id, DocumentTitle, DateCreated, "
                + config.getStatusProperty() + ", "
                + config.getTargetClassProperty() + ", "
                + config.getRepositoryNameProperty() + ", "
                + config.getCriteriaProperty() + ", "
                + config.getResultColumnsProperty() + ", "
                + config.getSqlQueryProperty() + ", "
                + config.getSendEmailToProperty() + ", "
                + config.getSendEmailCcProperty() + ", "
                + config.getStartDateProperty() + ", "
                + config.getEndDateProperty()
                + " FROM " + config.getReportClass()
                + " WHERE " + statusClause
                + " AND IsCurrentVersion = TRUE"
                + " ORDER BY DateCreated ASC";
    }

    private PropertyFilter buildPropertyFilter() {
        PropertyFilter filter = new PropertyFilter();
        filter.addIncludeProperty(0, null, null, PropertyNames.ID, null);
        filter.addIncludeProperty(0, null, null, "DocumentTitle", null);
        filter.addIncludeProperty(0, null, null, config.getStatusProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getTargetClassProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getRepositoryNameProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getCriteriaProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getResultColumnsProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSqlQueryProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSendEmailToProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getSendEmailCcProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getStartDateProperty(), null);
        filter.addIncludeProperty(0, null, null, config.getEndDateProperty(), null);
        return filter;
    }

    private ReportRequestSummary toSummary(Document document) {
        Properties props = document.getProperties();
        return new ReportRequestSummary(
                document.get_Id().toString(),
                P8PropertyReader.asString(props, "DocumentTitle"),
                P8PropertyReader.asString(props, config.getStatusProperty()),
                P8PropertyReader.asString(props, config.getTargetClassProperty()),
                P8PropertyReader.asString(props, config.getRepositoryNameProperty()),
                "",
                readStringList(props, config.getCriteriaProperty()),
                readStringList(props, config.getResultColumnsProperty()),
                P8PropertyReader.asString(props, config.getSqlQueryProperty()),
                readStringList(props, config.getSendEmailToProperty()),
                readStringList(props, config.getSendEmailCcProperty()),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getStartDateProperty())),
                P8PropertyReader.formatDateTime(P8PropertyReader.asDate(props, config.getEndDateProperty())));
    }

    private List<String> readStringList(Properties props, String propertyName) {
        List<String> values = new ArrayList<>();
        if (!props.isPropertyPresent(propertyName)) {
            return values;
        }
        try {
            StringList list = props.getStringListValue(propertyName);
            if (list != null) {
                for (Object item : list) {
                    if (item != null) {
                        String text = String.valueOf(item).trim();
                        if (!text.isEmpty()) {
                            values.add(text);
                        }
                    }
                }
            }
        } catch (Exception ex) {
            String single = P8PropertyReader.asString(props, propertyName);
            if (!single.isEmpty()) {
                values.add(single);
            }
        }
        return values;
    }
}




package com.cnb.reports.util;

import com.filenet.api.property.Properties;

import java.lang.reflect.Method;
import java.text.SimpleDateFormat;
import java.util.ArrayList;
import java.util.Collection;
import java.util.Date;
import java.util.Iterator;
import java.util.List;
import java.util.Map;
import java.util.TimeZone;

public final class P8PropertyReader {

    private static final String MULTI_VALUE_SEPARATOR = " | ";

    private P8PropertyReader() {
    }

    public static String asString(Properties props, String name) {
        if (props == null || !props.isPropertyPresent(name)) {
            return "";
        }
        try {
            String value = props.getStringValue(name);
            return value != null ? value : "";
        } catch (Exception ex) {
            try {
                Object value = props.getObjectValue(name);
                return value != null ? String.valueOf(formatDisplayValue(value)) : "";
            } catch (Exception ignored) {
                return "";
            }
        }
    }

    public static Date asDate(Properties props, String name) {
        if (props == null || !props.isPropertyPresent(name)) {
            return null;
        }
        try {
            return props.getDateTimeValue(name);
        } catch (Exception ex) {
            try {
                Object value = props.getObjectValue(name);
                if (value instanceof Date) {
                    return (Date) value;
                }
            } catch (Exception ignored) {
                // ignore
            }
            return null;
        }
    }

    public static String formatDateTime(Date date) {
        if (date == null) {
            return "";
        }
        SimpleDateFormat fmt = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
        fmt.setTimeZone(TimeZone.getDefault());
        return fmt.format(date);
    }

    public static Object readPropertyValue(Properties props, String propertyName) {
        if (props == null || !props.isPropertyPresent(propertyName)) {
            return "";
        }
        try {
            return props.getObjectValue(propertyName);
        } catch (Exception ex) {
            return asString(props, propertyName);
        }
    }

    /**
     * Converts a FileNet property value into a report-friendly display value.
     * Multi-valued lists become pipe-separated text (e.g. {@code a | b | c}).
     */
    public static Object formatDisplayValue(Object value) {
        if (value == null) {
            return "";
        }
        if (value instanceof Date) {
            return formatDateTime((Date) value);
        }
        if (value instanceof Number || value instanceof Boolean) {
            return value;
        }
        if (value instanceof CharSequence) {
            return value.toString();
        }
        if (value.getClass().isArray()) {
            return joinValues(arrayToList(value));
        }
        List<Object> multiValues = extractMultiValues(value);
        if (multiValues != null) {
            return joinValues(multiValues);
        }
        String asText = String.valueOf(value);
        String fromEngineToString = extractCurrentListFromEngineToString(asText);
        return fromEngineToString != null ? fromEngineToString : asText;
    }

    private static List<Object> extractMultiValues(Object value) {
        if (value instanceof Map) {
            return null;
        }
        if (value instanceof Collection) {
            return new ArrayList<Object>((Collection<?>) value);
        }
        if (value instanceof Iterable) {
            List<Object> values = new ArrayList<>();
            for (Object item : (Iterable<?>) value) {
                values.add(item);
            }
            return values;
        }
        if (value instanceof Iterator) {
            List<Object> values = new ArrayList<>();
            Iterator<?> iterator = (Iterator<?>) value;
            while (iterator.hasNext()) {
                values.add(iterator.next());
            }
            return values;
        }
        try {
            Method iteratorMethod = value.getClass().getMethod("iterator");
            Object iteratorObj = iteratorMethod.invoke(value);
            if (iteratorObj instanceof Iterator) {
                List<Object> values = new ArrayList<>();
                Iterator<?> iterator = (Iterator<?>) iteratorObj;
                while (iterator.hasNext()) {
                    values.add(iterator.next());
                }
                return values;
            }
        } catch (Exception ignored) {
            // Not a FileNet-style list collection.
        }
        return null;
    }

    private static List<Object> arrayToList(Object array) {
        int length = java.lang.reflect.Array.getLength(array);
        List<Object> values = new ArrayList<>(length);
        for (int i = 0; i < length; i++) {
            values.add(java.lang.reflect.Array.get(array, i));
        }
        return values;
    }

    private static String joinValues(List<Object> values) {
        if (values == null || values.isEmpty()) {
            return "";
        }
        List<String> parts = new ArrayList<>(values.size());
        for (Object item : values) {
            if (item == null) {
                continue;
            }
            if (item instanceof Date) {
                parts.add(formatDateTime((Date) item));
            } else {
                String text = String.valueOf(item).trim();
                if (!text.isEmpty()) {
                    parts.add(text);
                }
            }
        }
        return String.join(MULTI_VALUE_SEPARATOR, parts);
    }

    /**
     * Fallback for FileNet list implementations whose {@code toString()} looks like:
     * {@code Class=... CurrentList=[a, b, c] DeletedList=[] ...}
     */
    private static String extractCurrentListFromEngineToString(String text) {
        if (text == null || !text.contains("CurrentList=[")) {
            return null;
        }
        int start = text.indexOf("CurrentList=[");
        if (start < 0) {
            return null;
        }
        start += "CurrentList=[".length();
        int end = text.indexOf(']', start);
        if (end < start) {
            return null;
        }
        String inner = text.substring(start, end).trim();
        if (inner.isEmpty()) {
            return "";
        }
        String[] parts = inner.split("\\s*,\\s*");
        List<String> cleaned = new ArrayList<>();
        for (String part : parts) {
            if (part != null && !part.trim().isEmpty()) {
                cleaned.add(part.trim());
            }
        }
        return String.join(MULTI_VALUE_SEPARATOR, cleaned);
    }
}


