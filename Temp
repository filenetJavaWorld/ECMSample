define([
	"dojo/_base/lang",
	"ecm/model/Request",
	"ecm/Messages"
], function(lang, Request, Messages) {

	var PLUGIN_ID = "CNBReportsPlugin";

	/**
	 * Invokes a plugin service with a JSON body using HTTP POST.
	 * <p>
	 * {@link ecm.model.Request.postPluginService} chooses GET when the service URL ends with {@code .json}, which
	 * drops the request body on the server. Plugin services that expect a JSON body must use POST explicitly.
	 * </p>
	 */
	function postPluginServiceWithJsonBody(pluginName, pluginServiceName, repositoryId, requestBodyObject, onSuccess, onError) {
		var params = {
			repositoryId: repositoryId,
			desktop: ecm.model.desktop && ecm.model.desktop.id ? ecm.model.desktop.id : null,
			plugin: pluginName,
			action: pluginServiceName
		};
		var requestUrl = Request.getServiceRequestUrl("plugin", "", params);
		var body = lang.isObject(requestBodyObject) ? JSON.stringify(requestBodyObject) : String(requestBodyObject || "{}");
		var pluginParams = {
			requestUrl: requestUrl,
			requestMethod: "POST",
			requestBody: body,
			synchronous: false,
			progressMessage: Messages["progress_message_" + pluginName + "_" + pluginServiceName]
				|| Messages["progress_message_" + pluginServiceName]
				|| Messages.progress_message_general,
			cancelMessage: Messages["cancel_message_" + pluginName + "_" + pluginServiceName]
				|| Messages["cancel_message_" + pluginServiceName]
				|| Messages.cancel_message_general,
			requestHeaders: {
				"Cache-Control": "no-cache",
				"Content-Type": "application/json; charset=UTF-8"
			},
			requestCompleteCallback: function(response) {
				if (response && response.success) {
					if (lang.isFunction(onSuccess)) {
						onSuccess(response);
					}
				} else if (lang.isFunction(onError)) {
					onError(response);
				}
			},
			requestFailedCallback: function(response) {
				if (lang.isFunction(onError)) {
					onError(response);
				}
			}
		};
		if (Request.enableSecureService) {
			pluginParams.requestHeaders["security_token"] = Request._security_token;
		}
		var req = new Request(pluginParams);
		if (repositoryId && ecm.model.desktop) {
			req.repository = ecm.model.desktop.getRepository(repositoryId);
		}
		req.send();
	}

	return {
		submitReportRequest: function(repositoryId, payload, onSuccess, onError) {
			postPluginServiceWithJsonBody(PLUGIN_ID, "submitReportRequest", repositoryId, payload, onSuccess, onError);
		},

		listReportRequests: function(repositoryId, onSuccess, onError) {
			Request.invokePluginService(PLUGIN_ID, "reportRequestsSearchService", {
				requestParams: {
					repositoryId: repositoryId,
					repositoryType: "p8",
					query: ""
				},
				requestCompleteCallback: function(response) {
					if (lang.isFunction(onSuccess)) {
						onSuccess(response);
					}
				},
				requestFailedCallback: function(response) {
					if (lang.isFunction(onError)) {
						onError(response);
					}
				}
			});
		},

		getReportRequestDetails: function(repositoryId, documentId, reportRequestId, onSuccess, onError) {
			var params = {
				repositoryId: repositoryId,
				desktop: ecm.model.desktop && ecm.model.desktop.id ? ecm.model.desktop.id : null
			};
			if (documentId) {
				params.documentId = documentId;
			}
			if (reportRequestId) {
				params.reportRequestId = reportRequestId;
			}
			Request.invokePluginService(PLUGIN_ID, "getReportRequestDetails", {
				requestParams: params,
				requestCompleteCallback: function(response) {
					if (response && response.success) {
						if (lang.isFunction(onSuccess)) {
							onSuccess(response);
						}
					} else if (lang.isFunction(onError)) {
						onError(response);
					}
				},
				requestFailedCallback: function(response) {
					if (lang.isFunction(onError)) {
						onError(response);
					}
				}
			});
		}
	};
});




