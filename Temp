define([
	"dojo/_base/array",
	"dojo/_base/lang"
], function(array, lang) {

	/**
	 * Known FileNet OOTB / system document-class symbolic names to exclude from
	 * the custom document-class dropdown (Phase 1 frontend filter).
	 */
	var OOTB_DOCUMENT_CLASS_IDS = {
		Document: true,
		Email: true,
		CompoundDocument: true,
		StoredSearch: true,
		PublishTemplate: true,
		PublishRequest: true,
		CodeModule: true,
		WorkflowDefinition: true,
		WorkflowPolicy: true,
		FormTemplate: true,
		FormData: true,
		FormPolicy: true,
		EntryTemplate: true,
		DocumentEntryTemplate: true,
		FolderEntryTemplate: true,
		DeclareRecordEntryTemplate: true,
		CmAbstractDocument: true,
		ICMDocument: true,
		ICMDocumentVersion: true
	};

	var DocumentClassService = {

		/**
		 * Loads custom document classes under Document for the given P8 repository.
		 * @param {ecm.model.Repository} repository
		 * @param {Function} callback function(classes, errorMessage)
		 *   classes: [{ id, symbolicName, displayName, contentClass }]
		 */
		loadCustomDocumentClasses: function(repository, callback) {
			callback = callback || function() {
			};

			if (!repository) {
				callback([], "Unable to retrieve repository information.");
				return;
			}
			if (repository.type !== "p8") {
				callback([], "Only FileNet P8 repositories are supported.");
				return;
			}
			if (!repository.connected) {
				callback([], "The selected object store is not connected. Please sign in to the repository.");
				return;
			}

			var documentClass;
			try {
				documentClass = repository.getContentClass("Document");
			} catch (e) {
				callback([], "Unable to retrieve repository information.");
				return;
			}
			if (!documentClass) {
				callback([], "Unable to retrieve repository information.");
				return;
			}

			this._collectSubClasses(documentClass, lang.hitch(this, function(allClasses, errorMessage) {
				if (errorMessage) {
					callback([], errorMessage);
					return;
				}
				var custom = [];
				var seen = {};
				array.forEach(allClasses || [], function(cc) {
					if (!cc || !cc.id || seen[cc.id]) {
						return;
					}
					seen[cc.id] = true;
					if (OOTB_DOCUMENT_CLASS_IDS[cc.id]) {
						return;
					}
					custom.push({
						id: cc.id,
						symbolicName: cc.id,
						displayName: cc.name || cc.id,
						contentClass: cc
					});
				});
				custom.sort(function(a, b) {
