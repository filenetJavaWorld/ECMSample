import java.io.*;
import java.nio.charset.StandardCharsets;
import java.nio.file.*;
import java.util.*;

public class DynamicCsvDocumentTitleGenerator {

    private static final String[] CSV_FILES = {
            "C:/temp/DC_VendorRiskAssessment_Document.csv",
            "C:/temp/DC_Customer.csv"
    };

    private static final int LIMIT_COUNT = 10000;

    private static final String DOCUMENT_TITLE_PREFIX = "TestDocument";

    public static void main(String[] args) {

        for (String csvFile : CSV_FILES) {

            try {
                generateRows(csvFile, LIMIT_COUNT);
                System.out.println("Updated successfully: " + csvFile);
            } catch (Exception e) {
                System.err.println("Failed to update file: " + csvFile);
                e.printStackTrace();
            }
        }
    }

    private static void generateRows(String csvFilePath, int limitCount) throws IOException {

        Path path = Paths.get(csvFilePath);

        List<String> lines = Files.readAllLines(path, StandardCharsets.UTF_8);

        if (lines.size() < 2) {
            throw new RuntimeException(
                    "CSV must have header row and one sample data row: " + csvFilePath
            );
        }

        String headerLine = lines.get(0);
        String sampleRowLine = lines.get(1);

        List<String> sampleColumns = parseCsvLine(sampleRowLine);

        if (sampleColumns.isEmpty()) {
            throw new RuntimeException("Sample row is empty: " + csvFilePath);
        }

        List<String> outputLines = new ArrayList<>();

        outputLines.add(headerLine);

        for (int i = 1; i <= limitCount; i++) {

            List<String> newRow = new ArrayList<>(sampleColumns);

            // Only first column will change dynamically
            newRow.set(0, DOCUMENT_TITLE_PREFIX + i);

            outputLines.add(toCsvLine(newRow));
        }

        Files.write(
                path,
                outputLines,
                StandardCharsets.UTF_8,
                StandardOpenOption.CREATE,
                StandardOpenOption.TRUNCATE_EXISTING
        );
    }

    private static List<String> parseCsvLine(String line) {

        List<String> values = new ArrayList<>();
        StringBuilder currentValue = new StringBuilder();

        boolean insideQuotes = false;

        for (int i = 0; i < line.length(); i++) {

            char ch = line.charAt(i);

            if (ch == '"') {

                if (insideQuotes && i + 1 < line.length() && line.charAt(i + 1) == '"') {
                    currentValue.append('"');
                    i++;
                } else {
                    insideQuotes = !insideQuotes;
                }

            } else if (ch == ',' && !insideQuotes) {

                values.add(currentValue.toString());
                currentValue.setLength(0);

            } else {
                currentValue.append(ch);
            }
        }

        values.add(currentValue.toString());

        return values;
    }

    private static String toCsvLine(List<String> values) {

        List<String> escapedValues = new ArrayList<>();

        for (String value : values) {
            escapedValues.add(escapeCsv(value));
        }

        return String.join(",", escapedValues);
    }

    private static String escapeCsv(String value) {

        if (value == null) {
            return "";
        }

        String escaped = value.replace("\"", "\"\"");

        boolean needsQuotes =
                escaped.contains(",") ||
                escaped.contains("\"") ||
                escaped.contains("\n") ||
                escaped.contains("\r");

        if (needsQuotes) {
            return "\"" + escaped + "\"";
        }

        return escaped;
    }
}
